    add.u64         %rd25, %rd25, 32;
    cvt.rn.bf16.f32 %h0, %f10;  cvt.rn.bf16.f32 %h1, %f11;
    mov.b32         %r100, {%h0, %h1};
    @%p4 st.global.b32 [%rd25], %r100;

    // ng3: col_off = 48
    add.u64         %rd25, %rd21, %rd24;
    add.u64         %rd25, %rd25, 48;
    cvt.rn.bf16.f32 %h0, %f12;  cvt.rn.bf16.f32 %h1, %f13;
    mov.b32         %r100, {%h0, %h1};
    @%p3 st.global.b32 [%rd25], %r100;
    add.u64         %rd25, %rd23, %rd24;
    add.u64         %rd25, %rd25, 48;
    cvt.rn.bf16.f32 %h0, %f14;  cvt.rn.bf16.f32 %h1, %f15;
    mov.b32         %r100, {%h0, %h1};
    @%p4 st.global.b32 [%rd25], %r100;

    // ng4: col_off = 64
    add.u64         %rd25, %rd21, %rd24;
    add.u64         %rd25, %rd25, 64;
    cvt.rn.bf16.f32 %h0, %f16;  cvt.rn.bf16.f32 %h1, %f17;
    mov.b32         %r100, {%h0, %h1};
    @%p3 st.global.b32 [%rd25], %r100;
    add.u64         %rd25, %rd23, %rd24;
    add.u64         %rd25, %rd25, 64;
    cvt.rn.bf16.f32 %h0, %f18;  cvt.rn.bf16.f32 %h1, %f19;
    mov.b32         %r100, {%h0, %h1};
    @%p4 st.global.b32 [%rd25], %r100;

    // ng5: col_off = 80
    add.u64         %rd25, %rd21, %rd24;
