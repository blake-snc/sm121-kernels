    setp.gt.u32     %p5, %r156, %r150;
    setp.gt.u32     %p6, %r155, %r151;
    setp.gt.u32     %p7, %r156, %r151;
    @%p4 mov.b32    %f72, 0xff800000;
    @%p5 mov.b32    %f73, 0xff800000;
    @%p6 mov.b32    %f74, 0xff800000;
    @%p7 mov.b32    %f75, 0xff800000;

    // ng3
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p4, %r155, %r150;
    setp.gt.u32     %p5, %r156, %r150;
    setp.gt.u32     %p6, %r155, %r151;
    setp.gt.u32     %p7, %r156, %r151;
    @%p4 mov.b32    %f76, 0xff800000;
    @%p5 mov.b32    %f77, 0xff800000;
    @%p6 mov.b32    %f78, 0xff800000;
    @%p7 mov.b32    %f79, 0xff800000;

    // ng4
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p4, %r155, %r150;
    setp.gt.u32     %p5, %r156, %r150;
    setp.gt.u32     %p6, %r155, %r151;
    setp.gt.u32     %p7, %r156, %r151;
    @%p4 mov.b32    %f80, 0xff800000;
    @%p5 mov.b32    %f81, 0xff800000;
    @%p6 mov.b32    %f82, 0xff800000;
    @%p7 mov.b32    %f83, 0xff800000;

    // ng5
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p4, %r155, %r150;
    setp.gt.u32     %p5, %r156, %r150;
    setp.gt.u32     %p6, %r155, %r151;
    setp.gt.u32     %p7, %r156, %r151;
    @%p4 mov.b32    %f84, 0xff800000;
    @%p5 mov.b32    %f85, 0xff800000;
    @%p6 mov.b32    %f86, 0xff800000;
    @%p7 mov.b32    %f87, 0xff800000;

    // ng6
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p4, %r155, %r150;
    setp.gt.u32     %p5, %r156, %r150;
    setp.gt.u32     %p6, %r155, %r151;
    setp.gt.u32     %p7, %r156, %r151;
    @%p4 mov.b32    %f88, 0xff800000;
    @%p5 mov.b32    %f89, 0xff800000;
    @%p6 mov.b32    %f90, 0xff800000;
    @%p7 mov.b32    %f91, 0xff800000;

    // ng7
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p4, %r155, %r150;
    setp.gt.u32     %p5, %r156, %r150;
    setp.gt.u32     %p6, %r155, %r151;
    setp.gt.u32     %p7, %r156, %r151;
    @%p4 mov.b32    %f92, 0xff800000;
    @%p5 mov.b32    %f93, 0xff800000;
    @%p6 mov.b32    %f94, 0xff800000;
    @%p7 mov.b32    %f95, 0xff800000;

    // ================================================================
    // Online softmax: find row max, rescale O, compute P = exp(S - max)
    // ================================================================
    // Each thread has 2 rows of S: row0 (d0,d1 per ng) and row1 (d2,d3 per ng).
    // row0 elements: d0,d1 from each of 8 n-groups = 16 values
    // row1 elements: d2,d3 from each of 8 n-groups = 16 values

    // Step 1: Thread-local row max
    // row0: max across all d0,d1 values
    mov.f32         %f96, %f64;                // start with ng0.d0
    max.f32         %f96, %f96, %f65;          // ng0.d1
    max.f32         %f96, %f96, %f68;          // ng1.d0
    max.f32         %f96, %f96, %f69;          // ng1.d1
    max.f32         %f96, %f96, %f72;          // ng2.d0
    max.f32         %f96, %f96, %f73;          // ng2.d1
    max.f32         %f96, %f96, %f76;          // ng3.d0
    max.f32         %f96, %f96, %f77;          // ng3.d1
    max.f32         %f96, %f96, %f80;          // ng4.d0
    max.f32         %f96, %f96, %f81;          // ng4.d1
    max.f32         %f96, %f96, %f84;          // ng5.d0
    max.f32         %f96, %f96, %f85;          // ng5.d1
    max.f32         %f96, %f96, %f88;          // ng6.d0
    max.f32         %f96, %f96, %f89;          // ng6.d1
    max.f32         %f96, %f96, %f92;          // ng7.d0
    max.f32         %f96, %f96, %f93;          // ng7.d1

    // row1: max across all d2,d3 values
    mov.f32         %f97, %f66;
    max.f32         %f97, %f97, %f67;
    max.f32         %f97, %f97, %f70;
    max.f32         %f97, %f97, %f71;
    max.f32         %f97, %f97, %f74;
    max.f32         %f97, %f97, %f75;
    max.f32         %f97, %f97, %f78;
    max.f32         %f97, %f97, %f79;
    max.f32         %f97, %f97, %f82;
    max.f32         %f97, %f97, %f83;
    max.f32         %f97, %f97, %f86;
    max.f32         %f97, %f97, %f87;
    max.f32         %f97, %f97, %f90;
    max.f32         %f97, %f97, %f91;
    max.f32         %f97, %f97, %f94;
    max.f32         %f97, %f97, %f95;

    // Step 2: Reduce across 4 threads per row (GROUP4)
    GROUP4_REDUCE_MAX_F32(%f96, %f98)
    GROUP4_REDUCE_MAX_F32(%f97, %f98)

    // %f96 = new_max[row0], %f97 = new_max[row1]

    // Step 3: Combine with running max
    max.f32         %f99, %f192, %f96;         // new_max[row0] = max(old_max, block_max)
    max.f32         %f100, %f193, %f97;        // new_max[row1]

    // NaN guard: clamp -inf max to 0.0 to prevent -inf - (-inf) = NaN
    // in the exp computation below. With max=0.0, exp(-inf) = 0.0.
    mov.b32 %f98, 0xff800000; setp.eq.f32 %p10, %f99, %f98;
    @%p10 mov.f32   %f99, 0f00000000;
    mov.b32 %f98, 0xff800000; setp.eq.f32 %p10, %f100, %f98;
    @%p10 mov.f32   %f100, 0f00000000;

    // Step 4: Compute correction factors: exp(old_max - new_max)
    sub.f32         %f101, %f192, %f99;        // old_max - new_max (row0)
    mul.f32         %f101, %f101, LOG2E;
    ex2.approx.f32  %f101, %f101;              // correction[row0]
    sub.f32         %f102, %f193, %f100;       // old_max - new_max (row1)
    mul.f32         %f102, %f102, LOG2E;
    ex2.approx.f32  %f102, %f102;              // correction[row1]

    // Step 5: Rescale O accumulators by correction
    // O has 16 n-groups x 4 regs. d0,d1 -> row0 correction; d2,d3 -> row1 correction.
    mul.f32 %f0, %f0, %f101;    mul.f32 %f1, %f1, %f101;
    mul.f32 %f2, %f2, %f102;    mul.f32 %f3, %f3, %f102;
    mul.f32 %f4, %f4, %f101;    mul.f32 %f5, %f5, %f101;
    mul.f32 %f6, %f6, %f102;    mul.f32 %f7, %f7, %f102;
    mul.f32 %f8, %f8, %f101;    mul.f32 %f9, %f9, %f101;
    mul.f32 %f10, %f10, %f102;  mul.f32 %f11, %f11, %f102;
    mul.f32 %f12, %f12, %f101;  mul.f32 %f13, %f13, %f101;
    mul.f32 %f14, %f14, %f102;  mul.f32 %f15, %f15, %f102;
    mul.f32 %f16, %f16, %f101;  mul.f32 %f17, %f17, %f101;
    mul.f32 %f18, %f18, %f102;  mul.f32 %f19, %f19, %f102;
    mul.f32 %f20, %f20, %f101;  mul.f32 %f21, %f21, %f101;
    mul.f32 %f22, %f22, %f102;  mul.f32 %f23, %f23, %f102;
    mul.f32 %f24, %f24, %f101;  mul.f32 %f25, %f25, %f101;
    mul.f32 %f26, %f26, %f102;  mul.f32 %f27, %f27, %f102;
    mul.f32 %f28, %f28, %f101;  mul.f32 %f29, %f29, %f101;
    mul.f32 %f30, %f30, %f102;  mul.f32 %f31, %f31, %f102;
    mul.f32 %f32, %f32, %f101;  mul.f32 %f33, %f33, %f101;
    mul.f32 %f34, %f34, %f102;  mul.f32 %f35, %f35, %f102;
    mul.f32 %f36, %f36, %f101;  mul.f32 %f37, %f37, %f101;
    mul.f32 %f38, %f38, %f102;  mul.f32 %f39, %f39, %f102;
    mul.f32 %f40, %f40, %f101;  mul.f32 %f41, %f41, %f101;
    mul.f32 %f42, %f42, %f102;  mul.f32 %f43, %f43, %f102;
    mul.f32 %f44, %f44, %f101;  mul.f32 %f45, %f45, %f101;
    mul.f32 %f46, %f46, %f102;  mul.f32 %f47, %f47, %f102;
    mul.f32 %f48, %f48, %f101;  mul.f32 %f49, %f49, %f101;
    mul.f32 %f50, %f50, %f102;  mul.f32 %f51, %f51, %f102;
    mul.f32 %f52, %f52, %f101;  mul.f32 %f53, %f53, %f101;
    mul.f32 %f54, %f54, %f102;  mul.f32 %f55, %f55, %f102;
    mul.f32 %f56, %f56, %f101;  mul.f32 %f57, %f57, %f101;
    mul.f32 %f58, %f58, %f102;  mul.f32 %f59, %f59, %f102;
    mul.f32 %f60, %f60, %f101;  mul.f32 %f61, %f61, %f101;
    mul.f32 %f62, %f62, %f102;  mul.f32 %f63, %f63, %f102;

    // Rescale row_sum
    mul.f32         %f194, %f194, %f101;       // row_sum[0] *= correction
    mul.f32         %f195, %f195, %f102;       // row_sum[1] *= correction

    // Update running max
    mov.f32         %f192, %f99;               // row_max[0] = new_max
    mov.f32         %f193, %f100;              // row_max[1] = new_max

    // Step 6: Compute P = exp(S - new_max) and accumulate row_sum
    // For each S element: p = exp(s - max) = ex2((s - max) * log2e)
    // row0 elements use %f99 (new_max[row0]), row1 use %f100

    // Also simultaneously convert to bf16 and write to SMEM_P.
    // P layout in SMEM: 16 rows x 64 cols, row stride 128 bytes.
    // Store address computed earlier: %r74 (row0), %r75 (row1), ng offset = ng*16

    // ng0: S regs %f64..%f67
    sub.f32 %f64, %f64, %f99;  mul.f32 %f64, %f64, LOG2E;  ex2.approx.f32 %f64, %f64;
    sub.f32 %f65, %f65, %f99;  mul.f32 %f65, %f65, LOG2E;  ex2.approx.f32 %f65, %f65;
    sub.f32 %f66, %f66, %f100; mul.f32 %f66, %f66, LOG2E;  ex2.approx.f32 %f66, %f66;
    sub.f32 %f67, %f67, %f100; mul.f32 %f67, %f67, LOG2E;  ex2.approx.f32 %f67, %f67;
    // Accumulate row_sum
    add.f32 %f194, %f194, %f64;  add.f32 %f194, %f194, %f65;
    add.f32 %f195, %f195, %f66;  add.f32 %f195, %f195, %f67;
    // Convert to bf16 and store to SMEM_P
    cvt.rn.bf16.f32 %h0, %f64;  cvt.rn.bf16.f32 %h1, %f65;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74], %r100;
    cvt.rn.bf16.f32 %h0, %f66;  cvt.rn.bf16.f32 %h1, %f67;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75], %r100;

    // ng1: S regs %f68..%f71, P store offset +16 bytes
    sub.f32 %f68, %f68, %f99;  mul.f32 %f68, %f68, LOG2E;  ex2.approx.f32 %f68, %f68;
    sub.f32 %f69, %f69, %f99;  mul.f32 %f69, %f69, LOG2E;  ex2.approx.f32 %f69, %f69;
    sub.f32 %f70, %f70, %f100; mul.f32 %f70, %f70, LOG2E;  ex2.approx.f32 %f70, %f70;
    sub.f32 %f71, %f71, %f100; mul.f32 %f71, %f71, LOG2E;  ex2.approx.f32 %f71, %f71;
    add.f32 %f194, %f194, %f68;  add.f32 %f194, %f194, %f69;
    add.f32 %f195, %f195, %f70;  add.f32 %f195, %f195, %f71;
    cvt.rn.bf16.f32 %h0, %f68;  cvt.rn.bf16.f32 %h1, %f69;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 16], %r100;
    cvt.rn.bf16.f32 %h0, %f70;  cvt.rn.bf16.f32 %h1, %f71;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 16], %r100;

    // ng2: S regs %f72..%f75
    sub.f32 %f72, %f72, %f99;  mul.f32 %f72, %f72, LOG2E;  ex2.approx.f32 %f72, %f72;
    sub.f32 %f73, %f73, %f99;  mul.f32 %f73, %f73, LOG2E;  ex2.approx.f32 %f73, %f73;
    sub.f32 %f74, %f74, %f100; mul.f32 %f74, %f74, LOG2E;  ex2.approx.f32 %f74, %f74;
    sub.f32 %f75, %f75, %f100; mul.f32 %f75, %f75, LOG2E;  ex2.approx.f32 %f75, %f75;
    add.f32 %f194, %f194, %f72;  add.f32 %f194, %f194, %f73;
    add.f32 %f195, %f195, %f74;  add.f32 %f195, %f195, %f75;
    cvt.rn.bf16.f32 %h0, %f72;  cvt.rn.bf16.f32 %h1, %f73;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 32], %r100;
    cvt.rn.bf16.f32 %h0, %f74;  cvt.rn.bf16.f32 %h1, %f75;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 32], %r100;

    // ng3: S regs %f76..%f79
    sub.f32 %f76, %f76, %f99;  mul.f32 %f76, %f76, LOG2E;  ex2.approx.f32 %f76, %f76;
    sub.f32 %f77, %f77, %f99;  mul.f32 %f77, %f77, LOG2E;  ex2.approx.f32 %f77, %f77;
    sub.f32 %f78, %f78, %f100; mul.f32 %f78, %f78, LOG2E;  ex2.approx.f32 %f78, %f78;
    sub.f32 %f79, %f79, %f100; mul.f32 %f79, %f79, LOG2E;  ex2.approx.f32 %f79, %f79;
    add.f32 %f194, %f194, %f76;  add.f32 %f194, %f194, %f77;
    add.f32 %f195, %f195, %f78;  add.f32 %f195, %f195, %f79;
    cvt.rn.bf16.f32 %h0, %f76;  cvt.rn.bf16.f32 %h1, %f77;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 48], %r100;
    cvt.rn.bf16.f32 %h0, %f78;  cvt.rn.bf16.f32 %h1, %f79;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 48], %r100;

    // ng4: S regs %f80..%f83
    sub.f32 %f80, %f80, %f99;  mul.f32 %f80, %f80, LOG2E;  ex2.approx.f32 %f80, %f80;
    sub.f32 %f81, %f81, %f99;  mul.f32 %f81, %f81, LOG2E;  ex2.approx.f32 %f81, %f81;
    sub.f32 %f82, %f82, %f100; mul.f32 %f82, %f82, LOG2E;  ex2.approx.f32 %f82, %f82;
    sub.f32 %f83, %f83, %f100; mul.f32 %f83, %f83, LOG2E;  ex2.approx.f32 %f83, %f83;
    add.f32 %f194, %f194, %f80;  add.f32 %f194, %f194, %f81;
    add.f32 %f195, %f195, %f82;  add.f32 %f195, %f195, %f83;
    cvt.rn.bf16.f32 %h0, %f80;  cvt.rn.bf16.f32 %h1, %f81;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 64], %r100;
    cvt.rn.bf16.f32 %h0, %f82;  cvt.rn.bf16.f32 %h1, %f83;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 64], %r100;

    // ng5: S regs %f84..%f87
    sub.f32 %f84, %f84, %f99;  mul.f32 %f84, %f84, LOG2E;  ex2.approx.f32 %f84, %f84;
    sub.f32 %f85, %f85, %f99;  mul.f32 %f85, %f85, LOG2E;  ex2.approx.f32 %f85, %f85;
    sub.f32 %f86, %f86, %f100; mul.f32 %f86, %f86, LOG2E;  ex2.approx.f32 %f86, %f86;
    sub.f32 %f87, %f87, %f100; mul.f32 %f87, %f87, LOG2E;  ex2.approx.f32 %f87, %f87;
    add.f32 %f194, %f194, %f84;  add.f32 %f194, %f194, %f85;
    add.f32 %f195, %f195, %f86;  add.f32 %f195, %f195, %f87;
    cvt.rn.bf16.f32 %h0, %f84;  cvt.rn.bf16.f32 %h1, %f85;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 80], %r100;
    cvt.rn.bf16.f32 %h0, %f86;  cvt.rn.bf16.f32 %h1, %f87;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 80], %r100;

    // ng6: S regs %f88..%f91
    sub.f32 %f88, %f88, %f99;  mul.f32 %f88, %f88, LOG2E;  ex2.approx.f32 %f88, %f88;
    sub.f32 %f89, %f89, %f99;  mul.f32 %f89, %f89, LOG2E;  ex2.approx.f32 %f89, %f89;
    sub.f32 %f90, %f90, %f100; mul.f32 %f90, %f90, LOG2E;  ex2.approx.f32 %f90, %f90;
    sub.f32 %f91, %f91, %f100; mul.f32 %f91, %f91, LOG2E;  ex2.approx.f32 %f91, %f91;
    add.f32 %f194, %f194, %f88;  add.f32 %f194, %f194, %f89;
    add.f32 %f195, %f195, %f90;  add.f32 %f195, %f195, %f91;
    cvt.rn.bf16.f32 %h0, %f88;  cvt.rn.bf16.f32 %h1, %f89;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 96], %r100;
    cvt.rn.bf16.f32 %h0, %f90;  cvt.rn.bf16.f32 %h1, %f91;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 96], %r100;

    // ng7: S regs %f92..%f95
    sub.f32 %f92, %f92, %f99;  mul.f32 %f92, %f92, LOG2E;  ex2.approx.f32 %f92, %f92;
    sub.f32 %f93, %f93, %f99;  mul.f32 %f93, %f93, LOG2E;  ex2.approx.f32 %f93, %f93;
    sub.f32 %f94, %f94, %f100; mul.f32 %f94, %f94, LOG2E;  ex2.approx.f32 %f94, %f94;
    sub.f32 %f95, %f95, %f100; mul.f32 %f95, %f95, LOG2E;  ex2.approx.f32 %f95, %f95;
    add.f32 %f194, %f194, %f92;  add.f32 %f194, %f194, %f93;
    add.f32 %f195, %f195, %f94;  add.f32 %f195, %f195, %f95;
    cvt.rn.bf16.f32 %h0, %f92;  cvt.rn.bf16.f32 %h1, %f93;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r74 + 112], %r100;
    cvt.rn.bf16.f32 %h0, %f94;  cvt.rn.bf16.f32 %h1, %f95;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 112], %r100;

    bar.sync 0;

    // ================================================================
    // Load V tile [BC=64, D=128] to SMEM (reuses K's SMEM at offset 0)
    // ================================================================
    // V has same layout as K: [seq_kv, 128] row-major
    // Same loading pattern as K: 4 sub-passes of 16 rows each

    // Sub-pass 0
    add.u32         %r83, %r82, %r62;          // kv_base + lane/2
    mul.lo.u32      %r84, %r83, D;
    add.u32         %r84, %r84, %r19;
    add.u32         %r84, %r84, %r85;
    mul.wide.u32    %rd14, %r84, 2;
    add.u64         %rd15, %rd2, %rd14;         // V global addr (note: %rd2 = V base)
    setp.lt.u32     %p2, %r83, %r7;
    mov.u32         %r86, %r67;

