    // ================================================================
    // Epilogue: O /= row_sum, convert to bf16, store
    // ================================================================
    // O accumulators: %f0..%f63 (16 n-groups x 4 regs)
    // d0,d1 -> row0 (groupID), d2,d3 -> row1 (groupID+8)
    // Reduce row_sum across GROUP4 (done once in epilogue, not per KV block)
    GROUP4_REDUCE_SUM_F32(%f194, %f98)
    GROUP4_REDUCE_SUM_F32(%f195, %f98)

    // Divide by row_sum

