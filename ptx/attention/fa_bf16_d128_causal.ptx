// fa_bf16_d128_causal.ptx
//
// Flash Attention (CAUSAL) for BF16 with d=128.
// FlashAttention-2 online softmax algorithm with causal masking.
//
// 1 warp (32 threads), Br=16, Bc=64, d=128.
// Grid: (ceil(seq_q/Br), num_heads, batch_size)
//
// Q,K,V: [batch, num_heads, seq, 128] row-major bf16
// O:     [batch, num_heads, seq, 128] row-major bf16
//
// Causal mask: S[i,j] = -inf when kv_pos_j > q_pos_i
//
// MMA: mma.sync.aligned.m16n8k16.row.col.f32.bf16.bf16.f32
//
// SMEM layout (18432 bytes):
//   [0 ..  16383]  K/V tile: 64 rows x 128 cols x 2B = 16384 bytes
//   [16384..18431]  P tile:  16 rows x 64 cols x 2B  = 2048 bytes
//
// Register budget per thread:
//   Q fragments:      8 k-chunks x 4 regs = 32 regs (.b32)
//   S accumulators:   8 n-groups x 4 regs = 32 regs (.f32) [reused per KV block]
//   O accumulators:  16 n-groups x 4 regs = 64 regs (.f32)
//   Softmax state:   row_max(2) + row_sum(2) = 4 regs (.f32)
//   Temps + addrs:   ~24 regs
//   Total:           ~156 regs (within 256 limit)

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

// Tile dimensions
#define BR 16
#define BC 64
#define D  128

// SMEM offsets
#define SMEM_KV   0
#define SMEM_P    16384

// SMEM sizes: K/V tile row stride = 128 cols * 2B = 256 bytes
#define KV_ROW_STRIDE 256

// P tile row stride = 64 cols * 2B = 128 bytes
#define P_ROW_STRIDE 128

.visible .entry flash_attn_bf16_d128_causal(
    .param .u64 param_Q,        // [B, H, Sq, 128] bf16
    .param .u64 param_K,        // [B, H, Skv, 128] bf16
    .param .u64 param_V,        // [B, H, Skv, 128] bf16
    .param .u64 param_O,        // [B, H, Sq, 128] bf16 (output)
    .param .u32 param_seq_q,    // sequence length Q
    .param .u32 param_seq_kv,   // sequence length KV
    .param .u32 param_num_heads,
    .param .f32 param_scale     // 1/sqrt(d)
)
{
    // ================================================================
    // Register declarations
    // ================================================================
    .reg .b32  %r<160>;
    .reg .b64  %rd<48>;
    .reg .f32  %f<200>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    // Shared memory: K/V tile (16384) + P tile (2048) = 18432 bytes
    .shared .align 128 .b8 smem[18432];

    // ================================================================
    // Thread/block identification
    // ================================================================
    mov.u32         %r0, %tid.x;               // lane [0..31]
    mov.u32         %r1, %ctaid.x;             // q_block_idx
    mov.u32         %r2, %ctaid.y;             // head_idx
    mov.u32         %r3, %ctaid.z;             // batch_idx

    // MMA thread decomposition
    shr.b32         %r4, %r0, 2;              // groupID = lane / 4  [0..7]
    and.b32         %r5, %r0, 3;              // tidInGroup = lane % 4  [0..3]

    // ================================================================
    // Load parameters
    // ================================================================
    ld.param.u64    %rd0, [param_Q];
    ld.param.u64    %rd1, [param_K];
    ld.param.u64    %rd2, [param_V];
    ld.param.u64    %rd3, [param_O];
    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f196, [param_scale];

    // ================================================================
    // Compute base pointers for this (batch, head, q_block)
    // ================================================================
    // stride_batch = num_heads * seq * 128 (elements)
    // stride_head  = seq * 128 (elements)

    // Q base: param_Q + (batch * num_heads * seq_q * 128 + head * seq_q * 128 + q_block * BR * 128) * 2
    mul.lo.u32      %r10, %r6, D;             // seq_q * 128
    mul.lo.u32      %r11, %r8, %r10;          // num_heads * seq_q * 128 (batch stride in elements)
    mul.lo.u32      %r12, %r3, %r11;          // batch * batch_stride
    mul.lo.u32      %r13, %r2, %r10;          // head * head_stride
    add.u32         %r12, %r12, %r13;         // batch_off + head_off (Q/O)

    shl.b32         %r14, %r1, 4;             // q_block * BR (q_block * 16)
    mul.lo.u32      %r15, %r14, D;            // q_block * BR * 128
    add.u32         %r16, %r12, %r15;         // total Q element offset

    mul.wide.u32    %rd4, %r16, 2;            // byte offset
    add.u64         %rd5, %rd0, %rd4;         // Q base ptr for this block

    // O base: batch+head offset only (no q_block offset — store uses global row)
    mul.wide.u32    %rd40, %r12, 2;           // batch+head byte offset
    add.u64         %rd6, %rd3, %rd40;        // O base ptr (no q_block)

    // K/V base: param_K + (batch * num_heads * seq_kv * 128 + head * seq_kv * 128) * 2
    mul.lo.u32      %r17, %r7, D;             // seq_kv * 128
    mul.lo.u32      %r18, %r8, %r17;          // num_heads * seq_kv * 128 (batch stride)
    mul.lo.u32      %r19, %r3, %r18;          // batch * batch_stride
    mul.lo.u32      %r20, %r2, %r17;          // head * head_stride
    add.u32         %r19, %r19, %r20;         // batch_off + head_off (K/V)
    mul.wide.u32    %rd7, %r19, 2;            // byte offset
    add.u64         %rd8, %rd1, %rd7;         // K base ptr
    add.u64         %rd9, %rd2, %rd7;         // V base ptr

    // smem base
    mov.u32         %r21, smem;

    // ================================================================
    // Causal: precompute q_pos for this thread's two rows
    // ================================================================
    // q_pos_r0 = q_block_start + groupID = %r14 + %r4
    // q_pos_r1 = q_block_start + groupID + 8 = %r14 + %r4 + 8
    // max_q_pos = q_block_start + BR - 1 = %r14 + 15
    add.u32         %r150, %r14, %r4;          // q_pos_r0
    add.u32         %r151, %r150, 8;           // q_pos_r1
    add.u32         %r152, %r14, 15;           // max_q_pos (last row in this Q block)
    // kv_col_in_ng = tidInGroup * 2
    shl.b32         %r153, %r5, 1;             // tidInGroup * 2

    // ================================================================
    // Precompute ldmatrix addresses for Q (constant across KV loop)
    // ================================================================
    // Q tile is 16 x 128 bf16 = 16 rows, loaded to SMEM then via ldmatrix.
    // For m16n8k16 A-operand: ldmatrix.x4
    //   lane < 16: smem + lane * 32
    //   lane >= 16: smem + (lane-16)*32 + 16
    setp.lt.u32     %p0, %r0, 16;
    @%p0 mul.lo.u32 %r22, %r0, 32;
    @!%p0 sub.u32   %r22, %r0, 16;
    @!%p0 mad.lo.u32 %r22, %r22, 32, 16;
    // %r22 now holds the base ldmatrix offset for Q (reused for K too)

    // ================================================================
    // Load Q tile to registers via SMEM
    // ================================================================
    // Q tile: 16 rows x 128 cols. We load it to SMEM, then ldmatrix 8 k-chunks.
    // Each thread loads via global -> smem, then ldmatrix into registers.
    //
    // Global load: 32 threads load 16 rows x 128 cols = 4096 bytes
    //   lane < 16: loads row = lane, 256 bytes (128 bf16)
    //   lane >= 16: loads row = lane - 16, second half
    // Actually simpler: each thread loads one 256-byte row or we split differently.
    //
    // For 16 rows x 128 cols x 2B = 4096 bytes with 32 threads:
    //   Each thread loads 128 bytes = 4 x v4.b32 = 8 x 16B loads
    //   thread t loads row (t / 2), half (t % 2) = 128 bytes each
    //   row = lane / 2, half = lane % 2
    //   Each half = 64 bf16 = 128 bytes

    // We'll process Q in 8 k-chunks (k=0,16,32,...,112).
    // For each k-chunk, load 16x16 bf16 to SMEM, then ldmatrix.
    // But it's simpler to load ALL of Q to registers at once (32 regs).

    // Strategy: loop over 8 k-chunks, load Q[16x16] to SMEM, ldmatrix to regs.
    // Q fragment registers: %r30..%r61 (32 regs for 8 k-chunks x 4 regs each)

    // For each k-chunk kc = 0..7:
    //   Load Q[0:16, kc*16 : (kc+1)*16] to SMEM (512 bytes)
    //   ldmatrix.x4 -> 4 regs

    // Q load to SMEM: 16 rows x 16 cols x 2B = 512 bytes
    // 32 threads: thread t loads row (t % 16), col_group (t / 16)
    // Each thread loads 16 bytes (8 bf16) = 1 x v4.b32
    // row = lane % 16, half = lane / 16
    // smem_addr = row * 32 + half * 16
    // global_addr = Q_base + row * D * 2 + (kc * 16 + half * 8) * 2

    and.b32         %r23, %r0, 15;            // q_load_row = lane % 16
    shr.b32         %r24, %r0, 4;             // q_load_half = lane / 16 (0 or 1)

    // Q global row stride in bytes = D * 2 = 256
    mul.lo.u32      %r25, %r23, 256;          // q_load_row * 256
    cvt.u64.u32     %rd10, %r25;
    add.u64         %rd11, %rd5, %rd10;       // &Q[q_row][0] for this thread's row

    // SMEM store address for Q load: row * 32 + half * 16
    mul.lo.u32      %r26, %r23, 32;           // row * 32
    shl.b32         %r27, %r24, 4;            // half * 16
    add.u32         %r26, %r26, %r27;
    add.u32         %r28, %r21, %r26;         // smem + row*32 + half*16

    // ldmatrix base address (already computed in %r22)
    add.u32         %r29, %r21, %r22;         // smem + ldmatrix_offset

    // Load Q k-chunk 0 (k=0..15)
    // Global: Q_base + q_load_row * 256 + q_load_half * 16
    shl.b32         %r27, %r24, 4;            // half * 16 bytes
    cvt.u64.u32     %rd12, %r27;
    add.u64         %rd13, %rd11, %rd12;      // &Q[row][half*8] (byte addr)
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r30, %r31, %r32, %r33}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 1 (k=16..31)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 32;         // +32 bytes = +16 bf16 cols
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r34, %r35, %r36, %r37}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 2 (k=32..47)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 64;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r38, %r39, %r40, %r41}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 3 (k=48..63)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 96;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r42, %r43, %r44, %r45}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 4 (k=64..79)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 128;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r46, %r47, %r48, %r49}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 5 (k=80..95)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 160;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r50, %r51, %r52, %r53}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 6 (k=96..111)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 192;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r54, %r55, %r56, %r57}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 7 (k=112..127)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 224;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r58, %r59, %r60, %r61}, [%r29];
    bar.sync 0;

    // Q is now in registers:
    //   k-chunk 0: %r30..%r33, k-chunk 1: %r34..%r37
    //   k-chunk 2: %r38..%r41, k-chunk 3: %r42..%r45
    //   k-chunk 4: %r46..%r49, k-chunk 5: %r50..%r53
    //   k-chunk 6: %r54..%r57, k-chunk 7: %r58..%r61

    // ================================================================
    // Initialize O accumulators and softmax state
    // ================================================================
    // O accumulators: %f0..%f63 (16 n-groups x 4 regs)
    //   ng0: %f0..%f3, ng1: %f4..%f7, ..., ng15: %f60..%f63
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    // Softmax state: row_max and row_sum for 2 rows (groupID, groupID+8)
    // %f192 = row_max[row0], %f193 = row_max[row1]
    // %f194 = row_sum[row0], %f195 = row_sum[row1]
    mov.b32         %f192, 0xff800000;         // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;         // row_max[1] = -inf
    mov.f32         %f194, 0.0;                // row_sum[0] = 0
    mov.f32         %f195, 0.0;                // row_sum[1] = 0

    // ================================================================
    // Precompute K/V SMEM load helpers
    // ================================================================
    // K/V tile: 64 rows x 128 cols x 2B = 16384 bytes at SMEM_KV
    // 32 threads load 16384 bytes = 512 bytes/thread = 32 x 16B loads
    // Strategy: each thread loads 2 complete rows (256 bytes each)
    //   thread t loads rows (2*t) and (2*t+1) when t < 16, else rows (2*(t-16)+32) and (2*(t-16)+33)
    // Actually simpler: iterate. Each thread loads 512 B in a loop.
    //
    // Simpler: load in 4 passes of 16 rows each.
    //   Pass p: 32 threads load 16 rows. Thread t loads row (16*p + t/2), half (t%2).
    //   Each loads 128 bytes = 8 x v4.b32 = 2 x 16B. Wait, 128/16 = 8 loads.
    //   Actually 64 cols of bf16 per half = 128 bytes. Use 2 x v4.b32 (32B each) = 64B.
    //   Hmm, 128 cols per row, half = 64 cols = 128 bytes. Need 8 x 16B or 4 x 32B loads.
    //   But that's a lot per thread. Let's just do 4 passes of 16 rows.
    //
    // SIMPLIFIED: Load K tile in 4 passes. Each pass loads 16 rows x 128 cols.
    //   32 threads, each loads half a row (64 bf16 = 128 bytes = 4 x v4.b32).
    //   pass p, thread t: row = 16*p + t/2, half = t%2
    //   smem_addr = SMEM_KV + row * 256 + half * 128
    //   global_addr = K_base + (kv_block * BC + row) * D * 2 + half * 128

    // KV block stride in bytes
    // kv_row_start_byte_offset = kv_block * BC * D * 2 = kv_block * 64 * 128 * 2 = kv_block * 16384
    // We'll compute this in the loop.

    // Precompute: thread's row offset within 16-row sub-pass
    shr.b32         %r62, %r0, 1;             // lane / 2 = row within sub-pass [0..15]
    and.b32         %r63, %r0, 1;             // lane % 2 = half [0 or 1]
    // SMEM offset for sub-pass row: row * 256 + half * 128
    mul.lo.u32      %r64, %r62, KV_ROW_STRIDE;  // row * 256
    shl.b32         %r65, %r63, 7;            // half * 128
    add.u32         %r66, %r64, %r65;         // row_smem_off = row*256 + half*128
    add.u32         %r67, %r21, %r66;         // smem + row_smem_off (sub-pass 0 base)

    // ================================================================
    // Precompute ldmatrix addresses for K (B-operand of QK^T)
    // ================================================================
    // K is [64, 128] in SMEM (row-major). For QK^T, B-operand = K^T.
    // Key insight: K[seq, d] row-major IS K^T[d, seq] col-major.
    // MMA B-operand needs col-major data, so NO transpose needed.
    // Use ldmatrix.x2 (without .trans) to load K subtiles.
    //
    // Each (kc, ng) subtile: K[ng*8:(ng+1)*8, kc*16:(kc+1)*16] = 8 rows x 16 cols.
    // ldmatrix.x2 loads this as two 8x8 matrices (no transpose):
    //   Matrix 0 (lanes 0-7): K[ng*8+lane, kc*16 : kc*16+8]  (first 8 d-cols)
    //   Matrix 1 (lanes 8-15): K[ng*8+(lane-8), kc*16+8 : kc*16+16] (second 8 d-cols)
    // Address: smem + (ng*8 + sub_lane)*256 + kc*32 + half*16
    //   where sub_lane = lane % 8, half = (lane/8) % 2

    and.b32         %r68, %r0, 7;             // sub_lane = lane % 8
    mul.lo.u32      %r69, %r68, KV_ROW_STRIDE; // sub_lane * 256
    shr.b32         %r94, %r0, 3;
    and.b32         %r94, %r94, 1;            // half = (lane/8) % 2
    shl.b32         %r94, %r94, 4;            // half * 16 bytes
    add.u32         %r69, %r69, %r94;         // sub_lane*256 + half*16
    // %r69 = per-thread K ldmatrix offset (add ng*2048 + kc*32 per tile)

    // Precompute V ldmatrix base (B-operand of PV)
    // V is [64, 128] in SMEM. For PV, B-operand is V itself (not transposed).
    // Each (kp, ng) subtile: V[kp*16:(kp+1)*16, ng*8:(ng+1)*8] = 16 rows x 8 cols.
    // ldmatrix.x2.trans: lane%16 addresses 16 consecutive V rows.
    //   Address: smem + (kp*16 + lane%16)*256 + ng*16
    and.b32         %r95, %r0, 15;            // lane % 16
    mul.lo.u32      %r96, %r95, KV_ROW_STRIDE; // (lane%16) * 256
    // %r96 = per-thread V ldmatrix row offset (add kp*4096 + ng*16 per tile)

    // ================================================================
    // Precompute P SMEM store/load addresses
    // ================================================================
    // P tile: 16 x 64 bf16 at SMEM_P. Row stride = 128 bytes.
    // After computing S = Q*K^T and softmax -> P, we store P to SMEM
    // then reload via ldmatrix for the P*V MMA.
    //
    // P store: MMA C-operand layout.
    // Each thread holds 4 f32 per (mg=0, ng) MMA tile:
    //   d0 -> P[groupID, ng*8 + tidInGroup*2]
    //   d1 -> P[groupID, ng*8 + tidInGroup*2 + 1]
    //   d2 -> P[groupID+8, ng*8 + tidInGroup*2]
    //   d3 -> P[groupID+8, ng*8 + tidInGroup*2 + 1]

    // P store addresses (within SMEM_P):
    // row0 = groupID, row1 = groupID + 8
    // col_base = tidInGroup * 2
    mul.lo.u32      %r70, %r4, P_ROW_STRIDE;  // groupID * 128 (row0 byte offset)
    add.u32         %r71, %r70, 1024;          // (groupID+8) * 128 = row1 byte offset
    shl.b32         %r72, %r5, 2;              // tidInGroup * 2 * 2 = col byte offset

    // smem_p_r0 = SMEM_P + groupID * 128 + tidInGroup * 4
    add.u32         %r73, %r21, SMEM_P;        // smem + SMEM_P
    add.u32         %r74, %r73, %r70;
    add.u32         %r74, %r74, %r72;          // P store base for row0
    // smem_p_r1 = SMEM_P + (groupID+8) * 128 + tidInGroup * 4
    add.u32         %r75, %r73, %r71;
    add.u32         %r75, %r75, %r72;          // P store base for row1

    // P ldmatrix addresses (A-operand for P*V MMA):
    // P is 16 x 64 bf16. For k-chunk kp (each 16 cols of P -> 16 k-dim for MMA):
    //   ldmatrix.x4: need base addr per thread
    //   lane < 16: SMEM_P + lane * 128 (row stride for P) + kp * 32
    //   lane >= 16: SMEM_P + (lane-16) * 128 + kp * 32 + 16
    // Wait -- ldmatrix.x4 loads a 16x16 tile. P rows = 16, P cols = 64.
    // kp iterates over 4 k-chunks of 16 cols each.
    //
    // For ldmatrix A-operand address:
    //   lane < 16: smem_P + lane * P_ROW_STRIDE + kp * 32
    //   lane >= 16: smem_P + (lane-16) * P_ROW_STRIDE + kp * 32 + 16

    @%p0 mul.lo.u32 %r76, %r0, P_ROW_STRIDE;              // lane * 128
    @!%p0 sub.u32   %r76, %r0, 16;
    @!%p0 mul.lo.u32 %r76, %r76, P_ROW_STRIDE;            // (lane-16)*128
    @!%p0 add.u32   %r76, %r76, 16;
    add.u32         %r77, %r73, %r76;          // P ldmatrix base (add kp*32 per chunk)

    // ================================================================
    // KV BLOCK LOOP
    // ================================================================
    mov.u32         %r80, 0;                   // kv_block = 0
    // num_kv_blocks = ceil(seq_kv / BC) = (seq_kv + 63) / 64
    add.u32         %r81, %r7, 63;
    shr.b32         %r81, %r81, 6;             // num_kv_blocks

kv_loop:
    setp.ge.u32     %p1, %r80, %r81;
    @%p1 bra        kv_done;

    // Causal early exit: if kv_block_start > max_q_pos, all positions masked
    shl.b32         %r154, %r80, 6;            // kv_block_start = kv_block * 64
    setp.gt.u32     %p3, %r154, %r152;         // kv_block_start > max_q_pos?
    @%p3 bra        kv_done;

    // ================================================================
    // Load K tile [BC=64, D=128] to SMEM
    // ================================================================
    // kv_row_base = kv_block * 64
    shl.b32         %r82, %r80, 6;             // kv_block * 64

    // 4 sub-passes of 16 rows each
    // Sub-pass 0: rows 0..15
    add.u32         %r83, %r82, %r62;          // global_row = kv_base + lane/2
    mul.lo.u32      %r84, %r83, D;             // global_row * 128
    add.u32         %r84, %r84, %r19;          // + batch/head offset
    shl.b32         %r85, %r63, 6;             // half * 64 (element offset)
    add.u32         %r84, %r84, %r85;          // + half*64 elements
    mul.wide.u32    %rd14, %r84, 2;            // byte offset
    add.u64         %rd15, %rd1, %rd14;        // K global addr

    // bounds check: global_row < seq_kv
    setp.lt.u32     %p2, %r83, %r7;

    // smem addr = smem + 0*16*256 + row_smem_off
    mov.u32         %r86, %r67;                // sub-pass 0 smem addr

    // Load 128 bytes: 4 x v4.b32 = 4 x 16B
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 16];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 16], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 32];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 32], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 48];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 48], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 64];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 64], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 80];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 80], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 96];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 96], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 112];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 112], {%r100, %r101, %r102, %r103};

    // Sub-pass 1: rows 16..31
    add.u32         %r83, %r82, %r62;
    add.u32         %r83, %r83, 16;
    mul.lo.u32      %r84, %r83, D;
    add.u32         %r84, %r84, %r19;
    add.u32         %r84, %r84, %r85;
    mul.wide.u32    %rd14, %r84, 2;
    add.u64         %rd15, %rd1, %rd14;
    setp.lt.u32     %p2, %r83, %r7;
    add.u32         %r86, %r67, 4096;          // +16 rows * 256B

    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 16];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 16], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 32];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 32], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 48];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 48], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 64];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 64], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 80];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 80], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 96];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 96], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 112];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 112], {%r100, %r101, %r102, %r103};

    // Sub-pass 2: rows 32..47
    add.u32         %r83, %r82, %r62;
    add.u32         %r83, %r83, 32;
    mul.lo.u32      %r84, %r83, D;
    add.u32         %r84, %r84, %r19;
    add.u32         %r84, %r84, %r85;
    mul.wide.u32    %rd14, %r84, 2;
    add.u64         %rd15, %rd1, %rd14;
    setp.lt.u32     %p2, %r83, %r7;
    add.u32         %r86, %r67, 8192;

    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 16];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 16], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 32];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 32], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 48];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 48], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 64];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 64], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 80];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 80], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 96];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 96], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 112];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 112], {%r100, %r101, %r102, %r103};

    // Sub-pass 3: rows 48..63
    add.u32         %r83, %r82, %r62;
    add.u32         %r83, %r83, 48;
    mul.lo.u32      %r84, %r83, D;
    add.u32         %r84, %r84, %r19;
    add.u32         %r84, %r84, %r85;
    mul.wide.u32    %rd14, %r84, 2;
    add.u64         %rd15, %rd1, %rd14;
    setp.lt.u32     %p2, %r83, %r7;
    add.u32         %r86, %r67, 12288;

    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 16];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 16], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 32];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 32], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 48];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 48], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 64];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 64], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 80];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 80], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 96];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 96], {%r100, %r101, %r102, %r103};
    @%p2 ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd15 + 112];
    @!%p2 mov.b32 %r100, 0; @!%p2 mov.b32 %r101, 0; @!%p2 mov.b32 %r102, 0; @!%p2 mov.b32 %r103, 0;
    st.shared.v4.b32 [%r86 + 112], {%r100, %r101, %r102, %r103};

    bar.sync 0;

    // ================================================================
    // Compute S = Q * K^T  (16x128) x (128x64)^T = 16x64
    // ================================================================
    // S accumulators: %f64..%f95 (8 n-groups x 4 regs)
    //   ng0: %f64..%f67, ng1: %f68..%f71, ..., ng7: %f92..%f95
    // Zero S accumulators
    mov.f32 %f64, 0.0;  mov.f32 %f65, 0.0;  mov.f32 %f66, 0.0;  mov.f32 %f67, 0.0;
    mov.f32 %f68, 0.0;  mov.f32 %f69, 0.0;  mov.f32 %f70, 0.0;  mov.f32 %f71, 0.0;
    mov.f32 %f72, 0.0;  mov.f32 %f73, 0.0;  mov.f32 %f74, 0.0;  mov.f32 %f75, 0.0;
    mov.f32 %f76, 0.0;  mov.f32 %f77, 0.0;  mov.f32 %f78, 0.0;  mov.f32 %f79, 0.0;
    mov.f32 %f80, 0.0;  mov.f32 %f81, 0.0;  mov.f32 %f82, 0.0;  mov.f32 %f83, 0.0;
    mov.f32 %f84, 0.0;  mov.f32 %f85, 0.0;  mov.f32 %f86, 0.0;  mov.f32 %f87, 0.0;
    mov.f32 %f88, 0.0;  mov.f32 %f89, 0.0;  mov.f32 %f90, 0.0;  mov.f32 %f91, 0.0;
    mov.f32 %f92, 0.0;  mov.f32 %f93, 0.0;  mov.f32 %f94, 0.0;  mov.f32 %f95, 0.0;

    // QK^T: 8 k-chunks x 8 n-groups = 64 MMAs
    // S = Q * K^T where Q:[16,128], K^T:[128,64], S:[16,64]
    // MMA m16n8k16: k-dim=16 (d-chunks), n-dim=8 (KV-position groups)
    //
    // K is stored row-major K[seq, d] in SMEM. Row-major K[seq, d] is
    // equivalent to col-major K^T[d, seq]. Since MMA B-operand needs
    // col-major data, K is ALREADY in the correct format — NO .trans needed.
    // (Contrast with GEMM where B is stored K-major row-major and needs .trans
    //  to convert to col-major; and with PV where V is also K-major and needs .trans.)
    //
    // ldmatrix.x2 (no .trans) loads K[ng*8..+7, kc*16..+15] as two 8x8 tiles:
    //   Matrix 0 (lanes 0-7): K[ng*8+lane, kc*16..+7] (first 8 d-cols)
    //   Matrix 1 (lanes 8-15): K[ng*8+(lane-8), kc*16+8..+15] (second 8 d-cols)
    // Address: smem + (ng*8 + sub_lane)*256 + kc*32 + half*16

    // Precompute per-thread K ldmatrix base for QK^T
    // K base = smem + sub_lane*256 + half*16 (from precomputed %r69)
    add.u32         %r89, %r21, %r69;            // smem + K ldmatrix offset

    // Precompute per-thread V ldmatrix base for PV
    // V base = smem + (lane%16)*256 (from precomputed %r96)
    add.u32         %r120, %r21, %r96;           // smem + V ldmatrix offset

    // k-chunk 0 (kc=0): Q regs %r30..%r33
    // K B-operand base = %r89 + ng*2048 + kc*32
    // ng0: %r89 + 0*2048
    ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r104, %r105}, [%r89];
    MMA_BF16_M16N8K16(%f64, %f65, %f66, %f67, %r30, %r31, %r32, %r33, %r104, %r105)
    // ng1: + 2048
    add.u32         %r90, %r89, 2048;
    ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f68, %f69, %f70, %f71, %r30, %r31, %r32, %r33, %r104, %r105)
    // ng2: + 4096
    add.u32         %r90, %r89, 4096;
    ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f72, %f73, %f74, %f75, %r30, %r31, %r32, %r33, %r104, %r105)
    // ng3: + 6144
    add.u32         %r90, %r89, 6144;
    ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f76, %f77, %f78, %f79, %r30, %r31, %r32, %r33, %r104, %r105)
    // ng4: + 8192
    add.u32         %r90, %r89, 8192;
    ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f80, %f81, %f82, %f83, %r30, %r31, %r32, %r33, %r104, %r105)
    // ng5: + 10240
    add.u32         %r90, %r89, 10240;
    ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f84, %f85, %f86, %f87, %r30, %r31, %r32, %r33, %r104, %r105)
    // ng6: + 12288
