    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p6, %r155, %r150;
    setp.gt.u32     %p7, %r156, %r150;
    setp.gt.u32     %p8, %r155, %r151;
    setp.gt.u32     %p9, %r156, %r151;
    @%p6 mov.b32    %f84, 0xff800000;
    @%p7 mov.b32    %f85, 0xff800000;
    @%p8 mov.b32    %f86, 0xff800000;
    @%p9 mov.b32    %f87, 0xff800000;

    // ng6
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p6, %r155, %r150;
    setp.gt.u32     %p7, %r156, %r150;
    setp.gt.u32     %p8, %r155, %r151;
    setp.gt.u32     %p9, %r156, %r151;
    @%p6 mov.b32    %f88, 0xff800000;
    @%p7 mov.b32    %f89, 0xff800000;
    @%p8 mov.b32    %f90, 0xff800000;
    @%p9 mov.b32    %f91, 0xff800000;

    // ng7
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p6, %r155, %r150;
    setp.gt.u32     %p7, %r156, %r150;
    setp.gt.u32     %p8, %r155, %r151;
    setp.gt.u32     %p9, %r156, %r151;
    @%p6 mov.b32    %f92, 0xff800000;
    @%p7 mov.b32    %f93, 0xff800000;
    @%p8 mov.b32    %f94, 0xff800000;
    @%p9 mov.b32    %f95, 0xff800000;

    // ================================================================
    // Online softmax: find row max, rescale O, compute P = exp(S - max)
    // ================================================================
    // row0: max across all d0,d1 values
    mov.f32         %f96, %f64;
    max.f32         %f96, %f96, %f65;
    max.f32         %f96, %f96, %f68;
    max.f32         %f96, %f96, %f69;
    max.f32         %f96, %f96, %f72;
    max.f32         %f96, %f96, %f73;
    max.f32         %f96, %f96, %f76;
    max.f32         %f96, %f96, %f77;
    max.f32         %f96, %f96, %f80;
    max.f32         %f96, %f96, %f81;
    max.f32         %f96, %f96, %f84;
    max.f32         %f96, %f96, %f85;
    max.f32         %f96, %f96, %f88;
    max.f32         %f96, %f96, %f89;
    max.f32         %f96, %f96, %f92;
    max.f32         %f96, %f96, %f93;

    // row1: max across all d2,d3 values
    mov.f32         %f97, %f66;
    max.f32         %f97, %f97, %f67;
    max.f32         %f97, %f97, %f70;
    max.f32         %f97, %f97, %f71;
    max.f32         %f97, %f97, %f74;
    max.f32         %f97, %f97, %f75;
    max.f32         %f97, %f97, %f78;
    max.f32         %f97, %f97, %f79;
    max.f32         %f97, %f97, %f82;
    max.f32         %f97, %f97, %f83;
    max.f32         %f97, %f97, %f86;
    max.f32         %f97, %f97, %f87;
    max.f32         %f97, %f97, %f90;
    max.f32         %f97, %f97, %f91;
    max.f32         %f97, %f97, %f94;
    max.f32         %f97, %f97, %f95;

    // Reduce across 4 threads per row (GROUP4)
    GROUP4_REDUCE_MAX_F32(%f96, %f98)
    GROUP4_REDUCE_MAX_F32(%f97, %f98)

    // Combine with running max
    max.f32         %f99, %f192, %f96;
    max.f32         %f100, %f193, %f97;

    // NaN guard: clamp -inf max to 0.0 to prevent -inf - (-inf) = NaN
    // in the exp computation below. With max=0.0, exp(-inf) = 0.0.
    mov.b32 %f98, 0xff800000; setp.eq.f32 %p10, %f99, %f98;
