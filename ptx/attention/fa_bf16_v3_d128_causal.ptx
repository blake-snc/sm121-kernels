    mul.f32 %f84, %f84, %f196;   mul.f32 %f85, %f85, %f196;
    mul.f32 %f86, %f86, %f196;   mul.f32 %f87, %f87, %f196;
    mul.f32 %f88, %f88, %f196;   mul.f32 %f89, %f89, %f196;
    mul.f32 %f90, %f90, %f196;   mul.f32 %f91, %f91, %f196;
    mul.f32 %f92, %f92, %f196;   mul.f32 %f93, %f93, %f196;
    mul.f32 %f94, %f94, %f196;   mul.f32 %f95, %f95, %f196;

    // ================================================================
    // Causal mask: set S[i,j] = -inf where kv_pos_j > q_pos_i
    // ================================================================
    // S layout per ng: d0=S[row0, ng*8+tidInGroup*2]
    //                  d1=S[row0, ng*8+tidInGroup*2+1]
    //                  d2=S[row1, ng*8+tidInGroup*2]
    //                  d3=S[row1, ng*8+tidInGroup*2+1]
    // kv_pos_even = kv_block_start + ng*8 + tidInGroup*2 = %r82 + ng*8 + %r153
    // kv_pos_odd  = kv_pos_even + 1
    // Mask d0 if kv_pos_even > q_pos_r0, d1 if kv_pos_odd > q_pos_r0
    // Mask d2 if kv_pos_even > q_pos_r1, d3 if kv_pos_odd > q_pos_r1

    // ng0: kv_pos_base = kv_block_start + 0 + tidInGroup*2
    add.u32         %r155, %r82, %r153;        // kv_block_start + tidInGroup*2
    add.u32         %r156, %r155, 1;           // kv_pos_odd
    setp.gt.u32     %p6, %r155, %r150;         // kv_even > q_pos_r0?
    setp.gt.u32     %p7, %r156, %r150;         // kv_odd > q_pos_r0?
    setp.gt.u32     %p8, %r155, %r151;         // kv_even > q_pos_r1?
    setp.gt.u32     %p9, %r156, %r151;         // kv_odd > q_pos_r1?
    @%p6 mov.b32    %f64, 0xff800000;          // d0 = -inf
    @%p7 mov.b32    %f65, 0xff800000;          // d1 = -inf
    @%p8 mov.b32    %f66, 0xff800000;          // d2 = -inf
    @%p9 mov.b32    %f67, 0xff800000;          // d3 = -inf

    // ng1: kv_pos_base += 8
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p6, %r155, %r150;
    setp.gt.u32     %p7, %r156, %r150;
    setp.gt.u32     %p8, %r155, %r151;
    setp.gt.u32     %p9, %r156, %r151;
    @%p6 mov.b32    %f68, 0xff800000;
    @%p7 mov.b32    %f69, 0xff800000;
    @%p8 mov.b32    %f70, 0xff800000;
    @%p9 mov.b32    %f71, 0xff800000;

    // ng2
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p6, %r155, %r150;
    setp.gt.u32     %p7, %r156, %r150;
    setp.gt.u32     %p8, %r155, %r151;
    setp.gt.u32     %p9, %r156, %r151;
    @%p6 mov.b32    %f72, 0xff800000;
    @%p7 mov.b32    %f73, 0xff800000;
    @%p8 mov.b32    %f74, 0xff800000;
    @%p9 mov.b32    %f75, 0xff800000;

    // ng3
    add.u32         %r155, %r155, 8;
    add.u32         %r156, %r155, 1;
    setp.gt.u32     %p6, %r155, %r150;
    setp.gt.u32     %p7, %r156, %r150;
    setp.gt.u32     %p8, %r155, %r151;
    setp.gt.u32     %p9, %r156, %r151;
    @%p6 mov.b32    %f76, 0xff800000;
    @%p7 mov.b32    %f77, 0xff800000;
    @%p8 mov.b32    %f78, 0xff800000;
    @%p9 mov.b32    %f79, 0xff800000;

