    QK_NG8_OFF(%r50,%r51,%r52,%r53, %r76, 8192, %f200,%f201,%f202,%f203, %f204,%f205,%f206,%f207, %f208,%f209,%f210,%f211, %f212,%f213,%f214,%f215, %f216,%f217,%f218,%f219, %f220,%f221,%f222,%f223, %f224,%f225,%f226,%f227, %f228,%f229,%f230,%f231)

