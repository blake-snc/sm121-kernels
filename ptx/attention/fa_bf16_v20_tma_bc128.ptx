        mov.b32 %r100, {%h0, %h1}; \
        add.u32 %r82, paddr1, %r169; \
        st.shared.b32 [%r82], %r100;

    // ng 0-7 → left half of P
    EXP_STORE_NG_SWZ(%f64,%f65,%f66,%f67, %f197, %f198, %r111, %r112, 0)
    EXP_STORE_NG_SWZ(%f68,%f69,%f70,%f71, %f197, %f198, %r111, %r112, 1)
    EXP_STORE_NG_SWZ(%f72,%f73,%f74,%f75, %f197, %f198, %r111, %r112, 2)
    EXP_STORE_NG_SWZ(%f76,%f77,%f78,%f79, %f197, %f198, %r111, %r112, 3)
    EXP_STORE_NG_SWZ(%f80,%f81,%f82,%f83, %f197, %f198, %r111, %r112, 4)
    EXP_STORE_NG_SWZ(%f84,%f85,%f86,%f87, %f197, %f198, %r111, %r112, 5)
    EXP_STORE_NG_SWZ(%f88,%f89,%f90,%f91, %f197, %f198, %r111, %r112, 6)
    EXP_STORE_NG_SWZ(%f92,%f93,%f94,%f95, %f197, %f198, %r111, %r112, 7)

    // ng 8-15 → right half of P (offset +128 per row from left half base)
    // Right half row0 base = %r111 + 128, row1 base = %r112 + 128
    add.u32         %r113, %r111, 128;
    add.u32         %r114, %r112, 128;

    EXP_STORE_NG_SWZ(%f200,%f201,%f202,%f203, %f197, %f198, %r113, %r114, 0)
    EXP_STORE_NG_SWZ(%f204,%f205,%f206,%f207, %f197, %f198, %r113, %r114, 1)
    EXP_STORE_NG_SWZ(%f208,%f209,%f210,%f211, %f197, %f198, %r113, %r114, 2)
    EXP_STORE_NG_SWZ(%f212,%f213,%f214,%f215, %f197, %f198, %r113, %r114, 3)
    EXP_STORE_NG_SWZ(%f216,%f217,%f218,%f219, %f197, %f198, %r113, %r114, 4)
    EXP_STORE_NG_SWZ(%f220,%f221,%f222,%f223, %f197, %f198, %r113, %r114, 5)
    EXP_STORE_NG_SWZ(%f224,%f225,%f226,%f227, %f197, %f198, %r113, %r114, 6)
    EXP_STORE_NG_SWZ(%f228,%f229,%f230,%f231, %f197, %f198, %r113, %r114, 7)

    // ================================================================
    // Wait for V via mbarrier (single buffer)
    // ================================================================
mma_wait_v:
    mbarrier.try_wait.parity.shared.b64 %p8, [smem + SMEM_MBAR_V], %r153;
    @!%p8 bra mma_wait_v;

    // ================================================================
    // PV GEMM: O += P * V  (16x128) x (128x128) = 16x128
    // ================================================================
    // P (A-operand): ldmatrix.x4 from SMEM_P with swizzle, 128 cols
    // V (B-operand): ldmatrix.x2.trans from swizzled V buffer, 128 rows
    // 8 kp chunks (BC/16=128/16=8)

    // V base (left half) — single buffer
    add.u32         %r110, %r23, SMEM_V;
    add.u32         %r110, %r110, %r131;      // + (lane%16)*128

    // V right half base
    add.u32         %r180, %r110, HALF_SIZE_K;

    // PV_NG16 macro: V B-operand with swizzle
    // Same as V11: ng 0-7 from left half, ng 8-15 from right half
    // kp step = 16 rows = 16*128 = 2048 bytes
    #define PV_NG16_SWZ(p0,p1,p2,p3, vlb, vrb) \
        /* ng=0 (left, ng_in_half=0): (0 XOR lane%8)*16 */ \
        shl.b32 %r82, %r71, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f0,%f1,%f2,%f3, p0,p1,p2,p3, %r104,%r105) \
        /* ng=1: (1 XOR lane%8)*16 */ \
        mov.u32 %r82, 1; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f4,%f5,%f6,%f7, p0,p1,p2,p3, %r104,%r105) \
        /* ng=2: (2 XOR lane%8)*16 */ \
        mov.u32 %r82, 2; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f8,%f9,%f10,%f11, p0,p1,p2,p3, %r104,%r105) \
        /* ng=3 */ \
        mov.u32 %r82, 3; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f12,%f13,%f14,%f15, p0,p1,p2,p3, %r104,%r105) \
        /* ng=4 */ \
        mov.u32 %r82, 4; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f16,%f17,%f18,%f19, p0,p1,p2,p3, %r104,%r105) \
        /* ng=5 */ \
        mov.u32 %r82, 5; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f20,%f21,%f22,%f23, p0,p1,p2,p3, %r104,%r105) \
        /* ng=6 */ \
        mov.u32 %r82, 6; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f24,%f25,%f26,%f27, p0,p1,p2,p3, %r104,%r105) \
        /* ng=7 */ \
        mov.u32 %r82, 7; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vlb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f28,%f29,%f30,%f31, p0,p1,p2,p3, %r104,%r105) \
        /* ng=8 (right half, ng_in_half=0): (0 XOR lane%8)*16 */ \
        shl.b32 %r82, %r71, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f32,%f33,%f34,%f35, p0,p1,p2,p3, %r104,%r105) \
        /* ng=9: (1 XOR lane%8)*16 */ \
        mov.u32 %r82, 1; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f36,%f37,%f38,%f39, p0,p1,p2,p3, %r104,%r105) \
        /* ng=10 */ \
        mov.u32 %r82, 2; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f40,%f41,%f42,%f43, p0,p1,p2,p3, %r104,%r105) \
        /* ng=11 */ \
        mov.u32 %r82, 3; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f44,%f45,%f46,%f47, p0,p1,p2,p3, %r104,%r105) \
        /* ng=12 */ \
        mov.u32 %r82, 4; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f48,%f49,%f50,%f51, p0,p1,p2,p3, %r104,%r105) \
        /* ng=13 */ \
        mov.u32 %r82, 5; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f52,%f53,%f54,%f55, p0,p1,p2,p3, %r104,%r105) \
        /* ng=14 */ \
        mov.u32 %r82, 6; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f56,%f57,%f58,%f59, p0,p1,p2,p3, %r104,%r105) \
        /* ng=15 */ \
        mov.u32 %r82, 7; xor.b32 %r82, %r82, %r71; shl.b32 %r82, %r82, 4; \
        add.u32 %r82, vrb, %r82; \
        ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r82]; \
        MMA_BF16_M16N8K16(%f60,%f61,%f62,%f63, p0,p1,p2,p3, %r104,%r105)

    // P ldmatrix with swizzle: load A-operand from SMEM_P
    // P has 128 cols = 256B per row, split into left half (128B) and right half (128B)
    // kp 0-3: P left half (cols 0-63), kp 4-7: P right half (cols 64-127)
    // P left half base for ldmatrix: %r119 (P_warp_base + row*256)
    // P right half base: %r119 + 128

    // kp=0: kp_in_half=0, left half, byte = 0 + half_pair, swizzled = half_pair XOR ((row&7)*16)
    xor.b32         %r83, %r22, %r161;
    add.u32         %r83, %r119, %r83;        // P_base + row*256 + swizzled(kp=0)
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r110, %r180)

    // kp=1: kp_in_half=1, byte = 32 + half_pair
    mov.u32         %r83, 32;
    add.u32         %r83, %r83, %r22;
    xor.b32         %r83, %r83, %r161;
    add.u32         %r83, %r119, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 2048;        // V left + kp*2048
    add.u32         %r181, %r180, 2048;       // V right + kp*2048
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // kp=2: kp_in_half=2, byte = 64 + half_pair
    mov.u32         %r83, 64;
    add.u32         %r83, %r83, %r22;
    xor.b32         %r83, %r83, %r161;
    add.u32         %r83, %r119, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 4096;
    add.u32         %r181, %r180, 4096;
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // kp=3: kp_in_half=3, byte = 96 + half_pair
    mov.u32         %r83, 96;
    add.u32         %r83, %r83, %r22;
    xor.b32         %r83, %r83, %r161;
    add.u32         %r83, %r119, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 6144;
    add.u32         %r181, %r180, 6144;
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // kp=4: kp_in_half=0, right half of P, byte = 0 + half_pair
    // P right half base = %r119 + 128
    add.u32         %r190, %r119, 128;         // P right half base
    xor.b32         %r83, %r22, %r161;
    add.u32         %r83, %r190, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 8192;        // V left + kp*2048 (kp=4 → 4*2048=8192)
    add.u32         %r181, %r180, 8192;
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // kp=5: kp_in_half=1, right half, byte = 32 + half_pair
    mov.u32         %r83, 32;
    add.u32         %r83, %r83, %r22;
    xor.b32         %r83, %r83, %r161;
    add.u32         %r83, %r190, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 10240;       // V left + 5*2048
    add.u32         %r181, %r180, 10240;
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // kp=6: kp_in_half=2, right half, byte = 64 + half_pair
    mov.u32         %r83, 64;
    add.u32         %r83, %r83, %r22;
    xor.b32         %r83, %r83, %r161;
    add.u32         %r83, %r190, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 12288;       // V left + 6*2048
    add.u32         %r181, %r180, 12288;
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // kp=7: kp_in_half=3, right half, byte = 96 + half_pair
    mov.u32         %r83, 96;
    add.u32         %r83, %r83, %r22;
    xor.b32         %r83, %r83, %r161;
    add.u32         %r83, %r190, %r83;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r83];
    add.u32         %r84, %r110, 14336;       // V left + 7*2048
    add.u32         %r181, %r180, 14336;
    PV_NG16_SWZ(%r106,%r107,%r108,%r109, %r84, %r181)

    // Signal DONE: each MMA warp's lane 0 arrives
    setp.eq.u32     %p13, %r2, 0;
    @%p13 mbarrier.arrive.shared.b64 _, [smem + SMEM_MBAR_DONE];

    // Toggle phases (single-buffer: just toggle each time)
    xor.b32         %r151, %r151, 1;         // toggle k_phase
    xor.b32         %r153, %r153, 1;         // toggle v_phase

    // Advance KV block
    add.u32         %r121, %r121, 1;
    bra             kv_loop;

kv_done:
    // ================================================================
    // Epilogue: O /= row_sum, convert to bf16, store
    // ================================================================
    GROUP4_REDUCE_SUM_F32(%f194, %f98)
    GROUP4_REDUCE_SUM_F32(%f195, %f98)

    // Clamp zero row_sum to 1.0
    setp.eq.f32     %p10, %f194, 0f00000000;
    @%p10 mov.f32   %f194, 0f3f800000;
    setp.eq.f32     %p10, %f195, 0f00000000;
    @%p10 mov.f32   %f195, 0f3f800000;

    rcp.approx.f32  %f101, %f194;
    rcp.approx.f32  %f102, %f195;

    // Normalize O
    mul.f32 %f0, %f0, %f101;    mul.f32 %f1, %f1, %f101;
    mul.f32 %f2, %f2, %f102;    mul.f32 %f3, %f3, %f102;
    mul.f32 %f4, %f4, %f101;    mul.f32 %f5, %f5, %f101;
    mul.f32 %f6, %f6, %f102;    mul.f32 %f7, %f7, %f102;
    mul.f32 %f8, %f8, %f101;    mul.f32 %f9, %f9, %f101;
    mul.f32 %f10, %f10, %f102;  mul.f32 %f11, %f11, %f102;
    mul.f32 %f12, %f12, %f101;  mul.f32 %f13, %f13, %f101;
    mul.f32 %f14, %f14, %f102;  mul.f32 %f15, %f15, %f102;
    mul.f32 %f16, %f16, %f101;  mul.f32 %f17, %f17, %f101;
    mul.f32 %f18, %f18, %f102;  mul.f32 %f19, %f19, %f102;
    mul.f32 %f20, %f20, %f101;  mul.f32 %f21, %f21, %f101;
    mul.f32 %f22, %f22, %f102;  mul.f32 %f23, %f23, %f102;
    mul.f32 %f24, %f24, %f101;  mul.f32 %f25, %f25, %f101;
    mul.f32 %f26, %f26, %f102;  mul.f32 %f27, %f27, %f102;
    mul.f32 %f28, %f28, %f101;  mul.f32 %f29, %f29, %f101;
    mul.f32 %f30, %f30, %f102;  mul.f32 %f31, %f31, %f102;
    mul.f32 %f32, %f32, %f101;  mul.f32 %f33, %f33, %f101;
    mul.f32 %f34, %f34, %f102;  mul.f32 %f35, %f35, %f102;
    mul.f32 %f36, %f36, %f101;  mul.f32 %f37, %f37, %f101;
    mul.f32 %f38, %f38, %f102;  mul.f32 %f39, %f39, %f102;
    mul.f32 %f40, %f40, %f101;  mul.f32 %f41, %f41, %f101;
    mul.f32 %f42, %f42, %f102;  mul.f32 %f43, %f43, %f102;
    mul.f32 %f44, %f44, %f101;  mul.f32 %f45, %f45, %f101;
    mul.f32 %f46, %f46, %f102;  mul.f32 %f47, %f47, %f102;
    mul.f32 %f48, %f48, %f101;  mul.f32 %f49, %f49, %f101;
    mul.f32 %f50, %f50, %f102;  mul.f32 %f51, %f51, %f102;
    mul.f32 %f52, %f52, %f101;  mul.f32 %f53, %f53, %f101;
    mul.f32 %f54, %f54, %f102;  mul.f32 %f55, %f55, %f102;
    mul.f32 %f56, %f56, %f101;  mul.f32 %f57, %f57, %f101;
    mul.f32 %f58, %f58, %f102;  mul.f32 %f59, %f59, %f102;
    mul.f32 %f60, %f60, %f101;  mul.f32 %f61, %f61, %f101;
    mul.f32 %f62, %f62, %f102;  mul.f32 %f63, %f63, %f102;

    // ================================================================
    // Store O to global memory (O is not swizzled)
    // ================================================================
    ld.param.u64    %rd3, [param_O];

    mul.lo.u32      %r141, %r1, 16;
    add.u32         %r124, %r11, %r141;
    add.u32         %r124, %r124, %r13;
    add.u32         %r125, %r124, 8;

    setp.lt.u32     %p11, %r124, %r6;
    setp.lt.u32     %p12, %r125, %r6;

    sub.u32         %r126, %r10, %r11;

    add.u32         %r127, %r126, %r124;
    mul.lo.u32      %r128, %r127, 256;
    cvt.u64.u32     %rd4, %r128;
    add.u64         %rd5, %rd3, %rd4;

    add.u32         %r127, %r126, %r125;
    mul.lo.u32      %r128, %r127, 256;
    cvt.u64.u32     %rd4, %r128;
    add.u64         %rd6, %rd3, %rd4;

    shl.b32         %r129, %r14, 2;
    cvt.u64.u32     %rd7, %r129;

    #define STORE_NG(f0,f1,f2,f3, col_off) \
        add.u64 %rd8, %rd5, %rd7; \
        add.u64 %rd8, %rd8, col_off; \
        cvt.rn.bf16.f32 %h0, f0;  cvt.rn.bf16.f32 %h1, f1; \
        mov.b32 %r100, {%h0, %h1}; \
        @%p11 st.global.b32 [%rd8], %r100; \
        add.u64 %rd8, %rd6, %rd7; \
        add.u64 %rd8, %rd8, col_off; \
        cvt.rn.bf16.f32 %h0, f2;  cvt.rn.bf16.f32 %h1, f3; \
        mov.b32 %r100, {%h0, %h1}; \
        @%p12 st.global.b32 [%rd8], %r100;

    STORE_NG(%f0,%f1,%f2,%f3, 0)
    STORE_NG(%f4,%f5,%f6,%f7, 16)
    STORE_NG(%f8,%f9,%f10,%f11, 32)
    STORE_NG(%f12,%f13,%f14,%f15, 48)
    STORE_NG(%f16,%f17,%f18,%f19, 64)
    STORE_NG(%f20,%f21,%f22,%f23, 80)
    STORE_NG(%f24,%f25,%f26,%f27, 96)
    STORE_NG(%f28,%f29,%f30,%f31, 112)
    STORE_NG(%f32,%f33,%f34,%f35, 128)
    STORE_NG(%f36,%f37,%f38,%f39, 144)
    STORE_NG(%f40,%f41,%f42,%f43, 160)
    STORE_NG(%f44,%f45,%f46,%f47, 176)
    STORE_NG(%f48,%f49,%f50,%f51, 192)
    STORE_NG(%f52,%f53,%f54,%f55, 208)
    STORE_NG(%f56,%f57,%f58,%f59, 224)
    STORE_NG(%f60,%f61,%f62,%f63, 240)

    ret;

    // ================================================================
    // DMA WARP (warp 4): TMA loads Q, K, V — single-buffered K/V
    // Two TMA loads per tile: left half (coord_x=0) and right half (coord_x=64)
    // Protocol: load K → signal K → load V → signal V → wait DONE → repeat
    // ================================================================
dma_path:
    and.b32         %r96, %r0, 31;            // lane within DMA warp
    setp.eq.u32     %p6, %r96, 0;
    mov.u32         %r84, smem;

    // Q load: two halves
    add.u32         %r85, %r84, SMEM_MBAR_Q;
    add.u32         %r86, %r84, SMEM_Q;
    // expect_tx for both halves: 8192 + 8192 = 16384
    @%p6 mbarrier.arrive.expect_tx.shared.b64 _, [%r85], (BR * D * 2);
    mov.u32         %r83, 0;                  // coord_x = 0
    @%p6 cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%r86], [%rd0, {%r83, %r10}], [%r85];
    mov.u32         %r83, 64;                 // coord_x = 64
    add.u32         %r87, %r86, HALF_SIZE_Q;
    @%p6 cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%r87], [%rd0, {%r83, %r10}], [%r85];

    add.u32         %r87, %r7, 127;
    shr.b32         %r87, %r87, 7;            // num_kv_blocks = ceil(seq_kv/128)

    mov.u32         %r88, 0;                  // kv_block = 0
    mov.u32         %r155, 0;                 // done_phase = 0

dma_kv_loop:
    setp.ge.u32     %p9, %r88, %r87;
    @%p9 bra        dma_done;

    // kv_row = kv_base + kv_block * 128
    shl.b32         %r89, %r88, 7;            // kv_block * 128
    add.u32         %r90, %r12, %r89;

    // ---- Load K (single buffer at SMEM_K) ----
    add.u32         %r91, %r84, SMEM_MBAR_K;
    add.u32         %r92, %r84, SMEM_K;
    // expect_tx: BC * D * 2 = 128 * 128 * 2 = 32768
    @%p6 mbarrier.arrive.expect_tx.shared.b64 _, [%r91], (BC * D * 2);
    // K left half: coord_x=0, rows=128, cols=64
    mov.u32         %r83, 0;
    @%p6 cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%r92], [%rd1, {%r83, %r90}], [%r91];
    // K right half: coord_x=64
    mov.u32         %r83, 64;
    add.u32         %r95, %r92, HALF_SIZE_K;
    @%p6 cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%r95], [%rd1, {%r83, %r90}], [%r91];

    // ---- Load V (single buffer at SMEM_V) ----
    add.u32         %r93, %r84, SMEM_MBAR_V;
    add.u32         %r94, %r84, SMEM_V;
    @%p6 mbarrier.arrive.expect_tx.shared.b64 _, [%r93], (BC * D * 2);
    // V left half
    mov.u32         %r83, 0;
    @%p6 cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%r94], [%rd2, {%r83, %r90}], [%r93];
    // V right half
    mov.u32         %r83, 64;
    add.u32         %r95, %r94, HALF_SIZE_K;
    @%p6 cp.async.bulk.tensor.2d.shared::cluster.global.tile.mbarrier::complete_tx::bytes
        [%r95], [%rd2, {%r83, %r90}], [%r93];

    // Wait for MMA warps to signal DONE before loading next block
    add.u32         %r88, %r88, 1;
    setp.ge.u32     %p9, %r88, %r87;
    @%p9 bra        dma_done;                 // no more blocks, don't wait

    // Wait DONE — MMA finished reading this buffer
dma_wait_done:
    mbarrier.try_wait.parity.shared.b64 %p11, [smem + SMEM_MBAR_DONE], %r155;
    @!%p11 bra dma_wait_done;

    // Toggle done_phase
    xor.b32         %r155, %r155, 1;

    bra             dma_kv_loop;

dma_done:
    ret;
}
