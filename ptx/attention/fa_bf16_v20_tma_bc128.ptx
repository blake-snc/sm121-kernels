// fa_bf16_v20_tma_bc128.ptx
//
// Flash Attention V20: BC=128, single-buffered K/V, TMA loads.
// 5 warps (160 threads): warps 0-3 = MMA, warp 4 = DMA.
// Br=64, Bc=128, D=128. Grid: (ceil(seq_q/64), num_heads, batch). Block: (160,1,1).
//
// Based on V11 (double-buffered BC=64 TMA). Key changes:
// - BC doubled from 64 to 128 (halves KV loop iterations)
// - Single-buffered K/V (no ping-pong: K0/K1, V0/V1 → single K, V)
// - 4 mbarriers (Q, K, V, DONE) instead of 7
// - QK GEMM: 16 ng groups (128/8) instead of 8, 64 S accumulators
// - PV GEMM: 8 kp chunks (128/16) instead of 4
// - P tile: 64x128x2B = 16384 bytes (was 64x64x2B = 8192)
// - SMEM total ~96 KB (fits in SM121a's 99 KB limit)
//
// DMA protocol: load K → signal K_ready → load V → signal V_ready → wait DONE → next block
// MMA protocol: wait K_ready → QK → softmax → P store → wait V_ready → PV → signal DONE
//
// Requires dynamic SMEM (~96KB > 48KB default).

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

#define BR 64
#define BC 128
#define D  128
#define NUM_MMA_WARPS 4
#define DMA_WARP_ID   4

// SMEM layout (98368 bytes total, ~96 KB)
// Single-buffered K and V (BC=128 → 32768 bytes each)
// Q: 64*128*2 = 16384, K: 128*128*2 = 32768, V: 128*128*2 = 32768
// P: 64*128*2 = 16384 (row stride = 256 bytes)
// Each buffer split into left (cols 0-63) and right (cols 64-127) halves
// Within each half: rows x 64 cols x 2B, row stride = 128 bytes
// With SWIZZLE_128B applied by TMA hardware
#define SMEM_Q            0                    // 64*128*2 = 16384
#define SMEM_K            16384                // 128*128*2 = 32768
#define SMEM_V            49152                // 128*128*2 = 32768
#define SMEM_P            81920                // 64*128*2 = 16384
#define SMEM_MBAR_Q       98304                // 16 bytes
#define SMEM_MBAR_K       98320                // 16 bytes
#define SMEM_MBAR_V       98336                // 16 bytes
#define SMEM_MBAR_DONE    98352                // 16 bytes
#define SMEM_TOTAL        98368

// Half offsets within each tile buffer
// BC=128: each half = 128 rows * 64 cols * 2B = 16384 bytes
// BC=64 (Q/P): each half = 64 rows * 64 cols * 2B = 8192 bytes
#define HALF_SIZE_K  16384
#define HALF_SIZE_Q  8192
#define HALF_SIZE_P  8192

// Dynamic shared memory (>48KB requires cuFuncSetAttribute)
.extern .shared .align 128 .b8 smem[];

.visible .entry flash_attn_bf16_v20_tma_bc128(
    .param .u64 param_Q_tma_ptr,
    .param .u64 param_K_tma_ptr,
    .param .u64 param_V_tma_ptr,
    .param .u64 param_O,
    .param .u32 param_seq_q,
    .param .u32 param_seq_kv,
    .param .u32 param_num_heads,
    .param .f32 param_scale
)
{
    .reg .b32  %r<200>;
    .reg .b64  %rd<32>;
    .reg .f32  %f<260>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    mov.u32         %r0, %tid.x;
    shr.b32         %r1, %r0, 5;             // warp_id
    and.b32         %r2, %r0, 31;            // lane

    mov.u32         %r3, %ctaid.x;           // q_block
    mov.u32         %r4, %ctaid.y;           // head
    mov.u32         %r5, %ctaid.z;           // batch

    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f196, [param_scale];

    // Thread 0: init 4 mbarriers (Q, K, V, DONE)
    setp.eq.u32     %p0, %r0, 0;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_Q], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_K], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_V], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_DONE], NUM_MMA_WARPS;
    fence.mbarrier_init.release.cluster;
    bar.sync 0;

    // Global row offsets
    mul.lo.u32      %r9, %r5, %r8;
    add.u32         %r9, %r9, %r4;           // batch*H + head
    mul.lo.u32      %r10, %r9, %r6;
    shl.b32         %r11, %r3, 6;            // q_block * 64
    add.u32         %r10, %r10, %r11;        // Q global row
    mul.lo.u32      %r12, %r9, %r7;         // KV global row base

    // TMA descriptors
    ld.param.u64    %rd0, [param_Q_tma_ptr];
    ld.param.u64    %rd1, [param_K_tma_ptr];
    ld.param.u64    %rd2, [param_V_tma_ptr];

    // Branch: warp 4 = DMA, warps 0-3 = MMA
    setp.eq.u32     %p1, %r1, DMA_WARP_ID;
    @%p1 bra        dma_path;

    // ================================================================
    // MMA WARP PATH (warps 0-3)
    // ================================================================

    // Compute MMA thread decomposition
    shr.b32         %r13, %r2, 2;            // groupID = lane / 4
    and.b32         %r14, %r2, 3;            // tidInGroup = lane % 4

    // Wait Q
mma_wait_q:
    mbarrier.try_wait.parity.shared.b64 %p2, [smem + SMEM_MBAR_Q], 0;
    @!%p2 bra mma_wait_q;

    // ================================================================
    // Load Q from swizzled SMEM
    // ================================================================
    // Q layout: two halves at SMEM_Q+0 (cols 0-63) and SMEM_Q+HALF_SIZE_Q (cols 64-127)
    // Each half: 64 rows, 64 cols, row_stride=128B, swizzled with (row&7)<<4

    setp.lt.u32     %p3, %r2, 16;
    @%p3 mov.u32    %r20, %r2;               // row = lane (for lane<16)
    @!%p3 sub.u32   %r20, %r2, 16;           // row = lane-16 (for lane>=16)

    // half_pair: 0 for lane<16, 16 for lane>=16
    @%p3 mov.u32    %r22, 0;
    @!%p3 mov.u32   %r22, 16;

    // Swizzle XOR value for Q: (row & 7) * 16
    and.b32         %r160, %r20, 7;           // row & 7
    shl.b32         %r161, %r160, 4;          // (row & 7) * 16

    // Row offset within half = row * 128
    shl.b32         %r21, %r20, 7;            // row * 128

    // Q left half base per warp
    mov.u32         %r23, smem;
    mul.lo.u32      %r26, %r1, 2048;         // warp_id * 16rows * 128B
    add.u32         %r162, %r23, SMEM_Q;
    add.u32         %r162, %r162, %r26;       // Q_left_base + warp_offset
    add.u32         %r162, %r162, %r21;       // + row * 128

    // Q right half base per warp (+ HALF_SIZE_Q)
    add.u32         %r163, %r162, HALF_SIZE_Q;

    // ================================================================
    // Load Q from swizzled SMEM using ldmatrix.x4
    // ================================================================
    // kc 0-3 from left half, kc 4-7 from right half

    // kc=0 (kc_in_half=0, left): byte = 0 + half_pair
    xor.b32         %r24, %r22, %r161;       // half_pair XOR swizzle
    add.u32         %r24, %r162, %r24;        // left_base + row*128 + swizzled
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r30, %r31, %r32, %r33}, [%r24];

    // kc=1 (kc_in_half=1, left): byte = 32 + half_pair
    mov.u32         %r25, 32;
    add.u32         %r25, %r25, %r22;
    xor.b32         %r25, %r25, %r161;
    add.u32         %r25, %r162, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r34, %r35, %r36, %r37}, [%r25];

    // kc=2 (kc_in_half=2, left): byte = 64 + half_pair
    mov.u32         %r25, 64;
    add.u32         %r25, %r25, %r22;
    xor.b32         %r25, %r25, %r161;
    add.u32         %r25, %r162, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r38, %r39, %r40, %r41}, [%r25];

    // kc=3 (kc_in_half=3, left): byte = 96 + half_pair
    mov.u32         %r25, 96;
    add.u32         %r25, %r25, %r22;
    xor.b32         %r25, %r25, %r161;
    add.u32         %r25, %r162, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r42, %r43, %r44, %r45}, [%r25];

    // kc=4 (kc_in_half=0, right): byte = 0 + half_pair, from right half
    xor.b32         %r25, %r22, %r161;
    add.u32         %r25, %r163, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r46, %r47, %r48, %r49}, [%r25];

    // kc=5 (kc_in_half=1, right): byte = 32 + half_pair
    mov.u32         %r25, 32;
    add.u32         %r25, %r25, %r22;
    xor.b32         %r25, %r25, %r161;
    add.u32         %r25, %r163, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r50, %r51, %r52, %r53}, [%r25];

    // kc=6 (kc_in_half=2, right): byte = 64 + half_pair
    mov.u32         %r25, 64;
    add.u32         %r25, %r25, %r22;
    xor.b32         %r25, %r25, %r161;
    add.u32         %r25, %r163, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r54, %r55, %r56, %r57}, [%r25];

    // kc=7 (kc_in_half=3, right): byte = 96 + half_pair
    mov.u32         %r25, 96;
    add.u32         %r25, %r25, %r22;
    xor.b32         %r25, %r25, %r161;
    add.u32         %r25, %r163, %r25;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r58, %r59, %r60, %r61}, [%r25];

    // Q regs: kc0={30,31,32,33}, kc1={34,35,36,37}, kc2={38,39,40,41}, kc3={42,43,44,45}
    //          kc4={46,47,48,49}, kc5={50,51,52,53}, kc6={54,55,56,57}, kc7={58,59,60,61}

    // ================================================================
    // Initialize O accumulators and softmax state
    // ================================================================
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    mov.b32         %f192, 0xff800000;        // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;        // row_max[1] = -inf
    mov.f32         %f194, 0.0;               // row_sum[0] = 0
    mov.f32         %f195, 0.0;               // row_sum[1] = 0

    // Precompute K ldmatrix offsets (B-operand for QK GEMM)
    // K row = ng*8 + sub_lane (ng = which 8-row group in Bc=128, 16 groups)
    and.b32         %r71, %r2, 7;             // sub_lane = lane % 8
    shr.b32         %r72, %r2, 3;
    and.b32         %r72, %r72, 1;            // half = (lane/8) % 2
    shl.b32         %r74, %r72, 4;            // half * 16

    // K swizzle XOR for this lane: sub_lane * 16
    shl.b32         %r164, %r71, 4;           // %r164 = (lane%8) * 16

    // K row offset within half: sub_lane * 128
    shl.b32         %r73, %r71, 7;            // sub_lane * 128

    // Precompute V ldmatrix lane offset
    // V B-operand uses ldmatrix.x2.trans: row = lane % 16
    // V row offset = (lane%16) * 128
    and.b32         %r130, %r2, 15;           // lane % 16
    shl.b32         %r131, %r130, 7;          // (lane%16) * 128

    // P store addresses (MMA C-operand layout)
    // P has 128 cols = 256 bytes per row. Split into left (cols 0-63, 128B) and right (cols 64-127, 128B).
    // P is stored WITH swizzle for bank-conflict-free ldmatrix reads.
    //
    // P store: row = groupID (0-7) or groupID+8
    // For ng 0-7 (left half): col_byte_in_half = ng*16 + tidInGroup*4
    // For ng 8-15 (right half): col_byte_in_half = (ng-8)*16 + tidInGroup*4
    // swizzled_byte = col_byte_in_half XOR ((row & 7) * 16)
    //
    // P base per warp: SMEM_P + warp_id * 16 * 256 = SMEM_P + warp_id * 4096
    mul.lo.u32      %r140, %r1, 4096;        // warp_id * 4096
    add.u32         %r115, %r23, SMEM_P;
    add.u32         %r115, %r115, %r140;      // P base for this warp

    // P store row0 = groupID, row1 = groupID + 8
    // P row0 offset = groupID * 256, P row1 offset = (groupID+8) * 256
    mul.lo.u32      %r116, %r13, 256;        // groupID * 256
    shl.b32         %r117, %r14, 2;           // tidInGroup * 4

    // P store XOR for row0: (groupID & 7) * 16 = groupID * 16 (since groupID < 8)
    shl.b32         %r165, %r13, 4;           // groupID * 16

    // Pre-compute base + row_offset for the two rows (left half)
    add.u32         %r111, %r115, %r116;      // P_base + groupID*256 (row0 left)
    add.u32         %r112, %r111, 2048;       // P_base + (groupID+8)*256 (row1 left)

    // P ldmatrix addresses (A-operand for PV GEMM)
    // P layout: 16 rows x 128 cols x 2B per warp, row stride = 256B
    // Split into two halves: left (cols 0-63, 128B stride) and right (cols 64-127)
    // row = lane<16 ? lane : lane-16 (reuse %r20 and %p3)
    // half_pair = lane<16 ? 0 : 16 (reuse %r22)

    // P base per lane (row part) — left half
    @%p3 mul.lo.u32 %r118, %r2, 256;         // row * 256 (lane < 16)
    @!%p3 sub.u32   %r118, %r2, 16;
    @!%p3 mul.lo.u32 %r118, %r118, 256;      // (lane-16) * 256
    add.u32         %r119, %r115, %r118;      // P_warp_base + row*256

    // ================================================================
    // KV BLOCK LOOP — single-buffered
    // ================================================================
    add.u32         %r120, %r7, 127;
    shr.b32         %r120, %r120, 7;          // num_kv_blocks = ceil(seq_kv/128)

    mov.u32         %r121, 0;                 // kv_block = 0
    mov.u32         %r151, 0;                 // k_phase = 0
    mov.u32         %r153, 0;                 // v_phase = 0

    // Precompute scale_log2e = scale * LOG2E for fused softmax
    mul.f32         %f199, %f196, LOG2E;       // scale_log2e = scale * LOG2E

kv_loop:
    setp.ge.u32     %p7, %r121, %r120;
    @%p7 bra        kv_done;

    // ---- Compute K ldmatrix base (single buffer at SMEM_K) ----
    // K left half base = smem + SMEM_K
    // K_addr = K_half_base + (ng*8 + sub_lane)*128 + swizzled_byte
    add.u32         %r75, %r23, SMEM_K;

    // K addr for ng=0, kc_in_half=0:
    xor.b32         %r166, %r74, %r164;       // (half*16) XOR (sub_lane*16)
    add.u32         %r75, %r75, %r73;         // + sub_lane*128
    add.u32         %r75, %r75, %r166;        // + swizzled byte

    // Wait K
mma_wait_k:
    mbarrier.try_wait.parity.shared.b64 %p4, [smem + SMEM_MBAR_K], %r151;
    @!%p4 bra mma_wait_k;

    // Zero S accumulators — 64 regs for 16 ng groups x 4 outputs each
    mov.f32 %f64, 0.0;  mov.f32 %f65, 0.0;  mov.f32 %f66, 0.0;  mov.f32 %f67, 0.0;
    mov.f32 %f68, 0.0;  mov.f32 %f69, 0.0;  mov.f32 %f70, 0.0;  mov.f32 %f71, 0.0;
    mov.f32 %f72, 0.0;  mov.f32 %f73, 0.0;  mov.f32 %f74, 0.0;  mov.f32 %f75, 0.0;
    mov.f32 %f76, 0.0;  mov.f32 %f77, 0.0;  mov.f32 %f78, 0.0;  mov.f32 %f79, 0.0;
    mov.f32 %f80, 0.0;  mov.f32 %f81, 0.0;  mov.f32 %f82, 0.0;  mov.f32 %f83, 0.0;
    mov.f32 %f84, 0.0;  mov.f32 %f85, 0.0;  mov.f32 %f86, 0.0;  mov.f32 %f87, 0.0;
    mov.f32 %f88, 0.0;  mov.f32 %f89, 0.0;  mov.f32 %f90, 0.0;  mov.f32 %f91, 0.0;
    mov.f32 %f92, 0.0;  mov.f32 %f93, 0.0;  mov.f32 %f94, 0.0;  mov.f32 %f95, 0.0;
    // ng 8-15 use %f200-%f231
    mov.f32 %f200, 0.0; mov.f32 %f201, 0.0; mov.f32 %f202, 0.0; mov.f32 %f203, 0.0;
    mov.f32 %f204, 0.0; mov.f32 %f205, 0.0; mov.f32 %f206, 0.0; mov.f32 %f207, 0.0;
    mov.f32 %f208, 0.0; mov.f32 %f209, 0.0; mov.f32 %f210, 0.0; mov.f32 %f211, 0.0;
    mov.f32 %f212, 0.0; mov.f32 %f213, 0.0; mov.f32 %f214, 0.0; mov.f32 %f215, 0.0;
    mov.f32 %f216, 0.0; mov.f32 %f217, 0.0; mov.f32 %f218, 0.0; mov.f32 %f219, 0.0;
    mov.f32 %f220, 0.0; mov.f32 %f221, 0.0; mov.f32 %f222, 0.0; mov.f32 %f223, 0.0;
    mov.f32 %f224, 0.0; mov.f32 %f225, 0.0; mov.f32 %f226, 0.0; mov.f32 %f227, 0.0;
    mov.f32 %f228, 0.0; mov.f32 %f229, 0.0; mov.f32 %f230, 0.0; mov.f32 %f231, 0.0;

    // ================================================================
    // QK GEMM with swizzled K — 16 ng groups (BC=128)
    // ================================================================
    // K B-operand: ldmatrix.x2
    // ng groups 0-15, each 8 rows, stepping by 1024 bytes
    // K has 128 rows: left half has rows 0-127 (128 rows x 64 cols x 2B = 16384)
    // ng 0-7 from left half rows 0-63 (row offset 0..7*1024)
    // ng 8-15 from left half rows 64-127 (row offset 8*1024..15*1024)
    // kc 0-3 from left half (cols 0-63), kc 4-7 from right half (cols 64-127)

    // QK_NG8: processes 8 consecutive ng groups, accumulating to provided S regs
    // First 8 ng groups (ng 0-7): S accumulators %f64-%f95
    #define QK_NG8(q0,q1,q2,q3, kb, s0,s1,s2,s3, s4,s5,s6,s7, s8,s9,s10,s11, s12,s13,s14,s15, s16,s17,s18,s19, s20,s21,s22,s23, s24,s25,s26,s27, s28,s29,s30,s31) \
        ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r100, %r101}, [kb]; \
        MMA_BF16_M16N8K16(s0,s1,s2,s3, q0,q1,q2,q3, %r100,%r101) \
        add.u32 %r82, kb, 1024; \
        ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r100, %r101}, [%r82]; \
        MMA_BF16_M16N8K16(s4,s5,s6,s7, q0,q1,q2,q3, %r100,%r101) \
        add.u32 %r82, %r82, 1024; \
        ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r100, %r101}, [%r82]; \
        MMA_BF16_M16N8K16(s8,s9,s10,s11, q0,q1,q2,q3, %r100,%r101) \
        add.u32 %r82, %r82, 1024; \
        ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r100, %r101}, [%r82]; \
        MMA_BF16_M16N8K16(s12,s13,s14,s15, q0,q1,q2,q3, %r100,%r101) \
        add.u32 %r82, %r82, 1024; \
        ldmatrix.sync.aligned.m8n8.x2.shared.b16 {%r100, %r101}, [%r82]; \
        MMA_BF16_M16N8K16(s16,s17,s18,s19, q0,q1,q2,q3, %r100,%r101) \
        add.u32 %r82, %r82, 1024; \
