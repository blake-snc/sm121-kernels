    add.u32 %r90, %r93, 16;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f4, %f5, %f6, %f7, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 32;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f8, %f9, %f10, %f11, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 48;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f12, %f13, %f14, %f15, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 64;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f16, %f17, %f18, %f19, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 80;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f20, %f21, %f22, %f23, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 96;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f24, %f25, %f26, %f27, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 112;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f28, %f29, %f30, %f31, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 128;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f32, %f33, %f34, %f35, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 144;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f36, %f37, %f38, %f39, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 160;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f40, %f41, %f42, %f43, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 176;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f44, %f45, %f46, %f47, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 192;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f48, %f49, %f50, %f51, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 208;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f52, %f53, %f54, %f55, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 224;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f56, %f57, %f58, %f59, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r90, %r93, 240;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r90];
    MMA_BF16_M16N8K16(%f60, %f61, %f62, %f63, %r106, %r107, %r108, %r109, %r104, %r105)

    bar.sync 0;

    // Advance KV block
    add.u32         %r80, %r80, 1;
    bra             kv_loop;

kv_done:
    // ================================================================
    // Split-KV Epilogue: normalize O, write FP32 partial O + LSE
    // ================================================================
    // Split-KV stores NORMALIZED O_partial (O_acc / row_sum) in FP32
    // plus the log-sum-exp per row. The combine kernel uses LSE weights
    // to merge partials across splits: O = sum(w_s * O_s) / sum(w_s).
    //
    // LSE = log(row_sum) + row_max
    // O_partial = O_acc / row_sum (normalized)

    GROUP4_REDUCE_SUM_F32(%f194, %f98)
    GROUP4_REDUCE_SUM_F32(%f195, %f98)

    // Compute LSE = log(row_sum) + row_max for each of the 2 output rows
    // Handle row_sum=0 (empty split): LSE = -inf
    setp.eq.f32     %p10, %f194, 0f00000000;
    setp.eq.f32     %p11, %f195, 0f00000000;

    // log2(row_sum) then convert to ln: ln(x) = log2(x) / log2(e) = log2(x) * ln(2)
    lg2.approx.f32  %f101, %f194;
    mul.f32         %f101, %f101, 0f3F317218;  // * ln(2)
    add.f32         %f101, %f101, %f192;       // + row_max[0]
    lg2.approx.f32  %f102, %f195;
    mul.f32         %f102, %f102, 0f3F317218;
    add.f32         %f102, %f102, %f193;       // + row_max[1]

    // If row_sum was 0, set LSE to -inf and row_sum to 1 (avoid div by 0)
    @%p10 mov.b32   %f101, 0xff800000;
    @%p10 mov.f32   %f194, 0f3f800000;
    @%p11 mov.f32   %f195, 0f3f800000;
    @%p11 mov.b32   %f102, 0xff800000;

    // Normalize O: O_partial = O_acc / row_sum
    rcp.approx.f32  %f103, %f194;    // 1/row_sum[0]
    rcp.approx.f32  %f104, %f195;    // 1/row_sum[1]

    mul.f32 %f0, %f0, %f103;    mul.f32 %f1, %f1, %f103;
    mul.f32 %f2, %f2, %f104;    mul.f32 %f3, %f3, %f104;
    mul.f32 %f4, %f4, %f103;    mul.f32 %f5, %f5, %f103;
    mul.f32 %f6, %f6, %f104;    mul.f32 %f7, %f7, %f104;
    mul.f32 %f8, %f8, %f103;    mul.f32 %f9, %f9, %f103;
    mul.f32 %f10, %f10, %f104;  mul.f32 %f11, %f11, %f104;
    mul.f32 %f12, %f12, %f103;  mul.f32 %f13, %f13, %f103;
    mul.f32 %f14, %f14, %f104;  mul.f32 %f15, %f15, %f104;
    mul.f32 %f16, %f16, %f103;  mul.f32 %f17, %f17, %f103;
    mul.f32 %f18, %f18, %f104;  mul.f32 %f19, %f19, %f104;
    mul.f32 %f20, %f20, %f103;  mul.f32 %f21, %f21, %f103;
    mul.f32 %f22, %f22, %f104;  mul.f32 %f23, %f23, %f104;
    mul.f32 %f24, %f24, %f103;  mul.f32 %f25, %f25, %f103;
    mul.f32 %f26, %f26, %f104;  mul.f32 %f27, %f27, %f104;
    mul.f32 %f28, %f28, %f103;  mul.f32 %f29, %f29, %f103;
    mul.f32 %f30, %f30, %f104;  mul.f32 %f31, %f31, %f104;
    mul.f32 %f32, %f32, %f103;  mul.f32 %f33, %f33, %f103;
    mul.f32 %f34, %f34, %f104;  mul.f32 %f35, %f35, %f104;
    mul.f32 %f36, %f36, %f103;  mul.f32 %f37, %f37, %f103;
    mul.f32 %f38, %f38, %f104;  mul.f32 %f39, %f39, %f104;
    mul.f32 %f40, %f40, %f103;  mul.f32 %f41, %f41, %f103;
    mul.f32 %f42, %f42, %f104;  mul.f32 %f43, %f43, %f104;
    mul.f32 %f44, %f44, %f103;  mul.f32 %f45, %f45, %f103;
    mul.f32 %f46, %f46, %f104;  mul.f32 %f47, %f47, %f104;
    mul.f32 %f48, %f48, %f103;  mul.f32 %f49, %f49, %f103;
    mul.f32 %f50, %f50, %f104;  mul.f32 %f51, %f51, %f104;
    mul.f32 %f52, %f52, %f103;  mul.f32 %f53, %f53, %f103;
    mul.f32 %f54, %f54, %f104;  mul.f32 %f55, %f55, %f104;
    mul.f32 %f56, %f56, %f103;  mul.f32 %f57, %f57, %f103;
    mul.f32 %f58, %f58, %f104;  mul.f32 %f59, %f59, %f104;
    mul.f32 %f60, %f60, %f103;  mul.f32 %f61, %f61, %f103;
    mul.f32 %f62, %f62, %f104;  mul.f32 %f63, %f63, %f104;

    // ================================================================
    // Store O_partial (FP32, normalized) to global memory
    // ================================================================
    // O_partial layout: [num_splits, B, H, Sq, D] f32
    // Split offset: split_idx * B * H * Sq * D
    ld.param.u64    %rd3, [param_O];

    // Compute split offset
    mul.lo.u32      %r142, %r6, D;             // Sq * D
    mul.lo.u32      %r143, %r8, %r142;         // H * Sq * D
    mul.lo.u32      %r144, %r4, %r143;         // B * H * Sq * D  (NOT param_batch -- use %r4 which is loaded batch)
    // Wait -- %r4 is groupID in V3. Let me check what register holds batch.
    // In V3: %r3 = batch_idx. %r4 = groupID. %r8 = num_heads.
    // Need to load batch count from param.
    ld.param.u32    %r145, [param_batch];
    mul.lo.u32      %r144, %r145, %r143;       // B * H * Sq * D (split stride)

    mul.lo.u32      %r146, %r151, %r144;       // split_idx * split_stride (elements)

    // Base offset for (b, h, sq) within one split
    // %r13 = batch_off + head_off (elements) from header
    // row0 = q_block*128 + warp_id*16 + groupID
    shl.b32         %r115, %r9, 4;
    add.u32         %r116, %r15, %r115;
    add.u32         %r117, %r116, %r4;         // row0 (groupID)
    add.u32         %r118, %r117, 8;           // row1

    setp.lt.u32     %p4, %r117, %r6;
    setp.lt.u32     %p5, %r118, %r6;

    // O_partial addr: O_base + (split_offset + batch_head_offset + row * D + col) * 4
    // batch_head_offset = %r13 (from header)
    add.u32         %r147, %r146, %r13;        // split + batch/head offset

    // Row 0 base
    mul.lo.u32      %r148, %r117, D;           // row0 * D
    add.u32         %r149, %r147, %r148;       // + row offset
    // Column: tidInGroup * 2 (2 elements per store, but FP32 = 4 bytes each)
    shl.b32         %r150, %r5, 1;             // tidInGroup * 2 (element offset)

    // Row 1 base
    mul.lo.u32      %r151, %r118, D;
    add.u32         %r152, %r147, %r151;

    // Store FP32 O_partial: 2 elements per thread per ng group, 8 ng groups
    // Each thread stores 2 f32 values (8 bytes) per ng group
    #define STORE_NG_F32(f0, f1, f2, f3, ng_off) \
        add.u32 %r153, %r149, %r150; \
        add.u32 %r153, %r153, ng_off; \
        mul.wide.u32 %rd20, %r153, 4; \
        add.u64 %rd21, %rd3, %rd20; \
        @%p4 st.global.b32 [%rd21], f0; \
        add.u64 %rd21, %rd21, 4; \
        @%p4 st.global.b32 [%rd21], f1; \
        add.u32 %r153, %r152, %r150; \
        add.u32 %r153, %r153, ng_off; \
        mul.wide.u32 %rd20, %r153, 4; \
        add.u64 %rd21, %rd3, %rd20; \
        @%p5 st.global.b32 [%rd21], f2; \
        add.u64 %rd21, %rd21, 4; \
        @%p5 st.global.b32 [%rd21], f3;

    STORE_NG_F32(%f0, %f1, %f2, %f3, 0)
    STORE_NG_F32(%f4, %f5, %f6, %f7, 8)
    STORE_NG_F32(%f8, %f9, %f10, %f11, 16)
    STORE_NG_F32(%f12, %f13, %f14, %f15, 24)
    STORE_NG_F32(%f16, %f17, %f18, %f19, 32)
    STORE_NG_F32(%f20, %f21, %f22, %f23, 40)
    STORE_NG_F32(%f24, %f25, %f26, %f27, 48)
    STORE_NG_F32(%f28, %f29, %f30, %f31, 56)
    STORE_NG_F32(%f32, %f33, %f34, %f35, 64)
    STORE_NG_F32(%f36, %f37, %f38, %f39, 72)
    STORE_NG_F32(%f40, %f41, %f42, %f43, 80)
    STORE_NG_F32(%f44, %f45, %f46, %f47, 88)
    STORE_NG_F32(%f48, %f49, %f50, %f51, 96)
    STORE_NG_F32(%f52, %f53, %f54, %f55, 104)
    STORE_NG_F32(%f56, %f57, %f58, %f59, 112)
    STORE_NG_F32(%f60, %f61, %f62, %f63, 120)

    // ================================================================
    // Store LSE (FP32)
    // ================================================================
    // LSE layout: [num_splits, B, H, Sq] f32
    // Only lane 0 of each warp's group writes LSE (one value per row)
    // But actually, each thread computes LSE for its own row pair.
    // LSE row0 = %f101, LSE row1 = %f102
    // Only groupID == 0 AND tidInGroup == 0 writes (to avoid duplicates).
    // Wait -- LSE is per-row, not per-element. Each group of 4 threads
    // within a warp shares the same row. So groupID identifies the row
    // and ANY tidInGroup can write (they all computed the same LSE via reduce).
    // Let tidInGroup==0 write.

    setp.eq.u32     %p6, %r5, 0;              // tidInGroup == 0

    // LSE split stride = B * H * Sq
    mul.lo.u32      %r155, %r145, %r8;         // B * H
    mul.lo.u32      %r155, %r155, %r6;         // B * H * Sq
    ld.param.u32    %r156, [param_split_idx];
    mul.lo.u32      %r156, %r156, %r155;       // split_idx * split_stride

    // LSE base for (b, h)
    mul.lo.u32      %r157, %r3, %r8;           // batch * H
    add.u32         %r157, %r157, %r2;         // + head
    mul.lo.u32      %r157, %r157, %r6;         // * Sq

    // LSE[split, b, h, row0]
    add.u32         %r158, %r156, %r157;       // split + batch_head offset
    add.u32         %r159, %r158, %r117;       // + row0
    mul.wide.u32    %rd25, %r159, 4;
    add.u64         %rd26, %rd30, %rd25;
    and.pred        %p7, %p4, %p6;
    @%p7 st.global.b32 [%rd26], %f101;

    // LSE[split, b, h, row1]
    add.u32         %r159, %r158, %r118;       // + row1
    mul.wide.u32    %rd25, %r159, 4;
    add.u64         %rd26, %rd30, %rd25;
    and.pred        %p7, %p5, %p6;
    @%p7 st.global.b32 [%rd26], %f102;

    ret;
}
