    add.u32 %r91, %r72, 1024; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f68, %f69, %f70, %f71, %r30, %r31, %r32, %r33, %r104, %r105)
    add.u32 %r91, %r72, 2048; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f72, %f73, %f74, %f75, %r30, %r31, %r32, %r33, %r104, %r105)
    add.u32 %r91, %r72, 3072; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f76, %f77, %f78, %f79, %r30, %r31, %r32, %r33, %r104, %r105)
    add.u32 %r91, %r72, 4096; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f80, %f81, %f82, %f83, %r30, %r31, %r32, %r33, %r104, %r105)
    add.u32 %r91, %r72, 5120; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f84, %f85, %f86, %f87, %r30, %r31, %r32, %r33, %r104, %r105)
