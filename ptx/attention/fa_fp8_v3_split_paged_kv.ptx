    max.f32         %f96, %f96, %f68;   max.f32 %f96, %f96, %f69;
    max.f32         %f96, %f96, %f72;   max.f32 %f96, %f96, %f73;
    max.f32         %f96, %f96, %f76;   max.f32 %f96, %f96, %f77;
    max.f32         %f96, %f96, %f80;   max.f32 %f96, %f96, %f81;
    max.f32         %f96, %f96, %f84;   max.f32 %f96, %f96, %f85;
    max.f32         %f96, %f96, %f88;   max.f32 %f96, %f96, %f89;
    max.f32         %f96, %f96, %f92;   max.f32 %f96, %f96, %f93;
