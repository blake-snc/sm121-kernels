    ld.shared.b32 %r104, [%r92]; ld.shared.b32 %r105, [%r92+16];
    MMA_FP8_M16N8K32(%f64, %f65, %f66, %f67, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 1024; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f68, %f69, %f70, %f71, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 2048; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f72, %f73, %f74, %f75, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 3072; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f76, %f77, %f78, %f79, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 4096; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f80, %f81, %f82, %f83, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 5120; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f84, %f85, %f86, %f87, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 6144; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f88, %f89, %f90, %f91, %r38, %r39, %r40, %r41, %r104, %r105)
    add.u32 %r91, %r92, 7168; ld.shared.b32 %r104, [%r91]; ld.shared.b32 %r105, [%r91+16];
    MMA_FP8_M16N8K32(%f92, %f93, %f94, %f95, %r38, %r39, %r40, %r41, %r104, %r105)

