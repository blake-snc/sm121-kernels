    // ================================================================
    // Cooperative V load: 256 threads -> V[64,128] FP8 to SMEM [8192..16383]
    // ================================================================
    // Same paged loading pattern as K, targeting SMEM_V

    // Paged V address
    add.u32         %r153, %r152, %r110;       // global_row = kv_block*64 + kv_load_row
    div.u32         %r140, %r153, %r131;       // page_idx
    rem.u32         %r141, %r153, %r131;       // page_offset
    mul.wide.u32    %rd14, %r140, 4;
