    STORE_P_FP8(%f76, %f77, %f78, %f79, 24)
    STORE_P_FP8(%f80, %f81, %f82, %f83, 32)
    STORE_P_FP8(%f84, %f85, %f86, %f87, 40)
    STORE_P_FP8(%f88, %f89, %f90, %f91, 48)
    STORE_P_FP8(%f92, %f93, %f94, %f95, 56)

