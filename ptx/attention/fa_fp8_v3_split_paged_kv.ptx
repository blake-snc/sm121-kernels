// fa_fp8_v3_paged_kv.ptx
//
// Flash Attention (non-causal) for FP8 e4m3 with d=128, split-KV + paged KV cache.
// Writes normalized FP32 partial O + FP32 LSE for FlashDecoding combine.
// FlashAttention-2 online softmax algorithm.
//
// 8 warps (256 threads), Br=128, Bc=64, d=128.
// Grid: (ceil(seq_q/128), num_heads, batch_size)
//
// Q:  [B, H, Sq, 128] FP8 e4m3 (1 byte each)
// K,V: [num_pages, page_size, num_kv_heads, 128] FP8 e4m3 (paged layout)
// O:  [B, H, Sq, 128] BF16 (output)
//
// MMA: mma.sync.aligned.m16n8k32.row.col.f32.e4m3.e4m3.f32
//
// SMEM layout (16384 bytes = 16 KB):
//   [0 ..  8191]   K tile / P tile: 64 rows x 128 cols x 1B = 8192 bytes
//   [8192..16383]  V tile: 64 rows x 128 cols x 1B = 8192 bytes
//
// During Q loading, all 16KB is used for Q[128,128] (128 x 128 x 1B = 16384).
//
// Each warp independently computes 16 rows of output.
//
// Register budget per thread:
//   Q fragments:      4 k-chunks x 4 regs = 16 regs (.b32)
//   S accumulators:   8 n-groups x 4 regs = 32 regs (.f32)
//   O accumulators:  16 n-groups x 4 regs = 64 regs (.f32)
//   Softmax state:   row_max(2) + row_sum(2) = 4 regs (.f32)
//   Temps + addrs:   ~40 regs
//   Total:           ~156 regs (within 256 limit)

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

// Tile dimensions
#define BR 128
#define BC 64
#define D  128

// SMEM layout: K/P tile then V tile (FP8: 1 byte per element)
#define SMEM_KP   0
#define SMEM_V    (BC * D)

// Row strides in SMEM (bytes)
#define KV_ROW_STRIDE (D)
#define P_ROW_STRIDE  (BC)

// Macro to load FP8 B fragment with custom stride (for V in PV multiplication).
#define LOAD_FP8_B_FRAG_STRIDE(dst, addr, S, t0, t1, t2, t3) \
    ld.shared.u8 t0, [addr]; \
    ld.shared.u8 t1, [addr + S]; \
    ld.shared.u8 t2, [addr + 2*S]; \
    ld.shared.u8 t3, [addr + 3*S]; \
    bfi.b32 dst, t1, t0, 8, 8; \
    bfi.b32 dst, t2, dst, 16, 8; \
    bfi.b32 dst, t3, dst, 24, 8;

.visible .entry flash_attn_fp8_v3_split_paged_kv(
    .param .u64 param_Q,            // [B, H, Sq, 128] e4m3
    .param .u64 param_K,            // [num_pages, page_size, num_kv_heads, 128] e4m3
    .param .u64 param_V,            // [num_pages, page_size, num_kv_heads, 128] e4m3
    .param .u64 param_O,            // [num_splits, B, H, Sq, 128] f32 (partial output)
    .param .u64 param_page_table,   // [B, max_pages] u32
    .param .u32 param_seq_q,
    .param .u32 param_seq_kv,
    .param .u32 param_num_heads,
    .param .u32 param_num_kv_heads,
    .param .u32 param_page_size,
    .param .u32 param_max_pages,
    .param .f32 param_scale,
    .param .u64 param_LSE,          // [num_splits, B, H, Sq] f32
    .param .u32 param_num_splits,
    .param .u32 param_split_idx,
    .param .u32 param_batch
)
{
    // ================================================================
    // Register declarations
    // ================================================================
    .reg .b32  %r<200>;
    .reg .b64  %rd<48>;
    .reg .f32  %f<200>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    // Shared memory: K/P tile (8192) + V tile (8192) = 16384 bytes
    .shared .align 128 .b8 smem[16384];

    // ================================================================
    // Thread/block identification
    // ================================================================
    mov.u32         %r0, %tid.x;               // tid [0..255]
    mov.u32         %r1, %ctaid.x;             // q_block_idx
    mov.u32         %r2, %ctaid.y;             // head_idx
    mov.u32         %r3, %ctaid.z;             // batch_idx

    // Warp and lane decomposition
    and.b32         %r10, %r0, 31;             // lane = tid % 32
    shr.b32         %r9, %r0, 5;              // warp_id = tid / 32

    // MMA thread decomposition
    shr.b32         %r4, %r10, 2;             // groupID = lane / 4 [0..7]
    and.b32         %r5, %r10, 3;             // tidInGroup = lane % 4 [0..3]

    // ================================================================
    // Load parameters
    // ================================================================
    ld.param.u64    %rd0, [param_Q];
    ld.param.u64    %rd1, [param_K];
    ld.param.u64    %rd2, [param_V];
    ld.param.u64    %rd3, [param_O];
    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f196, [param_scale];
    ld.param.u64    %rd30, [param_LSE];
    ld.param.u32    %r180, [param_num_splits];
    ld.param.u32    %r181, [param_split_idx];
    ld.param.u32    %r182, [param_batch];

    // Paged KV params
    ld.param.u64    %rd40, [param_page_table];
    ld.param.u32    %r130, [param_num_kv_heads];
    ld.param.u32    %r131, [param_page_size];
    ld.param.u32    %r132, [param_max_pages];

    // KV strides for paged layout: [num_pages, page_size, num_kv_heads, D]
    // FP8: element offset = byte offset (1B per element)
    mul.lo.u32      %r133, %r130, D;          // row_stride = num_kv_heads * D
    mul.lo.u32      %r134, %r131, %r133;      // page_stride = page_size * row_stride
    // GQA: kv_head = head / (num_heads / num_kv_heads)
    div.u32         %r135, %r8, %r130;        // heads_per_kv_head
    div.u32         %r136, %r2, %r135;        // kv_head
    mul.lo.u32      %r137, %r136, D;          // kv_head_offset = kv_head * D
    // Page table base for this batch
    mul.lo.u32      %r138, %r3, %r132;        // batch * max_pages
    mul.wide.u32    %rd41, %r138, 4;          // byte offset
    add.u64         %rd42, %rd40, %rd41;      // page_table[batch] base

    // ================================================================
    // Compute base pointers for this (batch, head, q_block)
    // ================================================================
    // Q base: FP8 = 1 byte per element
    mul.lo.u32      %r11, %r6, D;             // seq_q * 128
    mul.lo.u32      %r12, %r8, %r11;          // num_heads * seq_q * 128 (batch stride)
    mul.lo.u32      %r13, %r3, %r12;          // batch * batch_stride
    mul.lo.u32      %r14, %r2, %r11;          // head * head_stride
    add.u32         %r13, %r13, %r14;         // batch_off + head_off (Q)

    shl.b32         %r15, %r1, 7;             // q_block * 128
    mul.lo.u32      %r16, %r15, D;            // q_block * BR * 128
    add.u32         %r17, %r13, %r16;         // total Q element offset

    // FP8: byte offset = element offset
    cvt.u64.u32     %rd4, %r17;
    add.u64         %rd5, %rd0, %rd4;         // Q base ptr

    // O base: bf16 (2 bytes per element)
    mul.wide.u32    %rd43, %r13, 2;           // batch+head byte offset for bf16
    add.u64         %rd6, %rd3, %rd43;        // O base ptr

    // smem base
    mov.u32         %r21, smem;

    // ================================================================
    // Cooperative Q load: 256 threads load Q[128,128] to all 16KB SMEM
    // ================================================================
    // Q tile: 128 rows x 128 cols x 1B = 16384 bytes
    // 256 threads: each thread loads half a row (64 bytes = 4 x cp.async 16B)
    //   row = tid / 2  [0..127]
    //   half = tid % 2  [0 or 1]
    //   FP8 row stride = 128 bytes

    shr.b32         %r24, %r0, 1;             // q_load_row = tid / 2
    and.b32         %r25, %r0, 1;             // q_load_half = tid % 2

    // Global address
    mul.lo.u32      %r26, %r24, D;            // row * 128 bytes (FP8)
    cvt.u64.u32     %rd10, %r26;
    add.u64         %rd11, %rd5, %rd10;       // &Q[row][0]
    shl.b32         %r27, %r25, 6;            // half * 64 bytes
    cvt.u64.u32     %rd12, %r27;
    add.u64         %rd13, %rd11, %rd12;      // &Q[row][half*64]

    // SMEM store address
    add.u32         %r28, %r26, %r27;         // row*128 + half*64
    add.u32         %r29, %r21, %r28;         // smem + row*128 + half*64

    // Bounds check: q_block*128 + row < seq_q
    add.u32         %r30, %r15, %r24;         // q_block*128 + row
    setp.lt.u32     %p1, %r30, %r6;

    // Load 64 bytes via cp.async: 4 x 16B
    selp.b32        %r100, 16, 0, %p1;
    cp.async.cg.shared.global [%r29],       [%rd13],       16, %r100;
    cp.async.cg.shared.global [%r29 + 16],  [%rd13 + 16],  16, %r100;
    cp.async.cg.shared.global [%r29 + 32],  [%rd13 + 32],  16, %r100;
    cp.async.cg.shared.global [%r29 + 48],  [%rd13 + 48],  16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;
    bar.sync 0;

    // ================================================================
    // Per-warp Q fragment load from SMEM to registers
    // ================================================================
    // Q is 128x128 FP8 in SMEM, row stride = 128 bytes.
    // Each warp handles 16 rows. Warp w starts at smem + w*16*128 = smem + w*2048.
    // For m16n8k32 A-operand (4 k-chunks, 4 regs each = 16 regs):
    //   a0 = Q[gid, kc*32 + tip*4 .. +3]         (4 bytes from row gid)
    //   a1 = Q[gid+8, kc*32 + tip*4 .. +3]       (4 bytes from row gid+8)
    //   a2 = Q[gid, kc*32 + 16 + tip*4 .. +3]    (4 bytes, second K half)
    //   a3 = Q[gid+8, kc*32 + 16 + tip*4 .. +3]  (4 bytes, second K half)

    mul.lo.u32      %r62, %r9, 2048;          // warp_id * 2048 (warp Q offset)
    mul.lo.u32      %r63, %r4, KV_ROW_STRIDE; // gid * 128 (row0 offset)
    add.u32         %r64, %r63, 1024;         // (gid+8) * 128 (row1 offset)
    shl.b32         %r65, %r5, 2;             // tip * 4 (col offset)
    add.u32         %r66, %r65, 16;           // tip * 4 + 16 (second K half)

    // Compose SMEM addresses
    add.u32         %r67, %r21, %r62;         // smem + warp_offset
    // row0_base = smem + warp_offset + gid*128
    add.u32         %r68, %r67, %r63;
    // row1_base = smem + warp_offset + (gid+8)*128
    add.u32         %r69, %r67, %r64;

    // k-chunk 0 (k=0..31): regs %r30..%r33
    add.u32         %r90, %r68, %r65;         // row0 + tip*4
    ld.shared.b32   %r30, [%r90];             // a0: row gid, K=tip*4..+3
    add.u32         %r90, %r69, %r65;         // row1 + tip*4
    ld.shared.b32   %r31, [%r90];             // a1: row gid+8
    add.u32         %r90, %r68, %r66;         // row0 + tip*4+16
    ld.shared.b32   %r32, [%r90];             // a2: row gid, K=16+tip*4..+3
    add.u32         %r90, %r69, %r66;         // row1 + tip*4+16
    ld.shared.b32   %r33, [%r90];             // a3: row gid+8, second half

    // k-chunk 1 (k=32..63): regs %r34..%r37
    add.u32         %r90, %r68, %r65;
    ld.shared.b32   %r34, [%r90 + 32];
    add.u32         %r90, %r69, %r65;
    ld.shared.b32   %r35, [%r90 + 32];
    add.u32         %r90, %r68, %r66;
    ld.shared.b32   %r36, [%r90 + 32];
    add.u32         %r90, %r69, %r66;
    ld.shared.b32   %r37, [%r90 + 32];

    // k-chunk 2 (k=64..95): regs %r38..%r41
    add.u32         %r90, %r68, %r65;
    ld.shared.b32   %r38, [%r90 + 64];
    add.u32         %r90, %r69, %r65;
    ld.shared.b32   %r39, [%r90 + 64];
    add.u32         %r90, %r68, %r66;
    ld.shared.b32   %r40, [%r90 + 64];
    add.u32         %r90, %r69, %r66;
    ld.shared.b32   %r41, [%r90 + 64];

    // k-chunk 3 (k=96..127): regs %r42..%r45
    add.u32         %r90, %r68, %r65;
    ld.shared.b32   %r42, [%r90 + 96];
    add.u32         %r90, %r69, %r65;
    ld.shared.b32   %r43, [%r90 + 96];
    add.u32         %r90, %r68, %r66;
    ld.shared.b32   %r44, [%r90 + 96];
    add.u32         %r90, %r69, %r66;
    ld.shared.b32   %r45, [%r90 + 96];

    // Q now in registers: kc0=%r30..33, kc1=%r34..37, kc2=%r38..41, kc3=%r42..45

    // Sync so SMEM can be reused for K/V/P
    bar.sync 0;

    // ================================================================
    // Initialize O accumulators and softmax state
    // ================================================================
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    // Softmax state
    mov.b32         %f192, 0xff800000;         // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;         // row_max[1] = -inf
    mov.f32         %f194, 0.0;                // row_sum[0] = 0
    mov.f32         %f195, 0.0;                // row_sum[1] = 0

    // ================================================================
    // Precompute K/V/P SMEM address helpers
    // ================================================================

    // K B-fragment base address (QK^T)
    // K[64,128] in SMEM_KP, row stride = 128 bytes (FP8).
    // b0 = ld.shared.b32 at K[(ng*8 + gid), kc*32 + tip*4]
    // b1 = ld.shared.b32 at K[(ng*8 + gid), kc*32 + 16 + tip*4]
    // Base: smem + gid*128 + tip*4
    mul.lo.u32      %r70, %r4, KV_ROW_STRIDE; // gid * 128
    shl.b32         %r71, %r5, 2;             // tip * 4
    add.u32         %r72, %r21, %r70;         // smem + gid*128
    add.u32         %r72, %r72, %r71;         // + tip*4
    // %r72 = K B-frag base (add ng*1024 + kc*32 per iter)
    // ng stride = 8 * 128 = 1024

    // P store addresses (warp-specific)
    // P tile: 128 x 64 FP8 at SMEM_KP, row stride = 64 bytes
    // Each warp: 16 rows at warp_id * 1024
    mul.lo.u32      %r73, %r9, 1024;          // warp_id * 1024
    add.u32         %r74, %r21, %r73;         // P_smem_base
    // P store row0: groupID * 64, row1: (groupID+8) * 64
    mul.lo.u32      %r75, %r4, P_ROW_STRIDE;  // groupID * 64
    add.u32         %r76, %r75, 512;          // (groupID+8) * 64
    shl.b32         %r77, %r5, 1;             // tidInGroup * 2 (col byte offset for e4m3x2)
    // P store addr row0:
    add.u32         %r78, %r74, %r75;
    add.u32         %r78, %r78, %r77;
    // P store addr row1:
    add.u32         %r79, %r74, %r76;
    add.u32         %r79, %r79, %r77;

    // P A-fragment load addresses (PV MMA)
    // P[16,64] FP8 at warp's P_smem_base, row stride = 64 bytes.
    // a0 = P[gid, kp*32 + tip*4 .. +3]
    // a1 = P[gid+8, kp*32 + tip*4 .. +3]
    // a2 = P[gid, kp*32 + 16 + tip*4 .. +3]
    // a3 = P[gid+8, kp*32 + 16 + tip*4 .. +3]
    // Base: P_smem_base + gid*64 + tip*4
    mul.lo.u32      %r80, %r4, P_ROW_STRIDE;  // gid * 64
    add.u32         %r81, %r74, %r80;         // P_smem_base + gid*64
    add.u32         %r81, %r81, %r71;         // + tip*4
    // %r81 = P A-frag base for row0 (add kp*32 per chunk)
    // row1 offset = 8*64 = 512
    add.u32         %r82, %r81, 512;          // P A-frag base for row1

    // V B-fragment load addresses (PV MMA)
    // V[64,128] at SMEM_V, row stride = 128.
    // b0: 4 bytes from V[kp*32 + tip*4 + j, ng*8 + gid] for j=0..3
    //   = stride-128 load at SMEM_V + (kp*32 + tip*4)*128 + ng*8 + gid
    // b1: same + 16*128 = +2048
    mul.lo.u32      %r83, %r5, 512;           // tidInGroup * 4 * 128 = tidInGroup * 512
    add.u32         %r83, %r83, %r4;          // + gid
    add.u32         %r84, %r21, SMEM_V;       // smem + SMEM_V
    add.u32         %r83, %r84, %r83;         // V B-frag base
    // %r83 = V B-frag base for ng=0, kp=0
    // ng stride = 8, kp stride = 32*128 = 4096, b1 offset = 16*128 = 2048

    // ================================================================
    // Precompute cooperative K/V load helpers
    // ================================================================
    // 256 threads load K/V [64, 128] FP8 = 8192 bytes cooperatively
    //   kv_load_row = tid / 4  [0..63]
    //   kv_load_col_quarter = tid % 4  [0..3]
    //   Each quarter = 32 bytes (32 elements x 1B) = 2 x cp.async(16B)
    //   SMEM: row * 128 + quarter * 32

    shr.b32         %r110, %r0, 2;            // kv_load_row = tid / 4
    and.b32         %r111, %r0, 3;            // kv_load_col_quarter = tid % 4
    mul.lo.u32      %r112, %r110, KV_ROW_STRIDE; // row * 128
    shl.b32         %r113, %r111, 5;          // quarter * 32
    add.u32         %r114, %r112, %r113;      // row*128 + quarter*32

    // ================================================================
    // KV BLOCK LOOP
    // ================================================================
    // Split-KV block range
    add.u32         %r151, %r7, 63;
    shr.b32         %r151, %r151, 6;           // num_kv_blocks = ceil(seq_kv / 64)
    add.u32         %r183, %r151, %r180;
    sub.u32         %r183, %r183, 1;
    div.u32         %r183, %r183, %r180;       // blocks_per_split
    mul.lo.u32      %r150, %r181, %r183;       // split_start
    add.u32         %r184, %r150, %r183;
    min.u32         %r151, %r184, %r151;       // split_end

kv_loop:
    setp.ge.u32     %p2, %r150, %r151;
    @%p2 bra        kv_done;

    // ================================================================
    // Cooperative K load: 256 threads -> K[64,128] FP8 to SMEM [0..8191]
    // ================================================================
    shl.b32         %r152, %r150, 6;           // kv_block * 64

    // Paged K address: page table lookup + paged element offset
    add.u32         %r153, %r152, %r110;       // global_row = kv_block*64 + kv_load_row
    // Page table lookup
    div.u32         %r140, %r153, %r131;       // page_idx = global_row / page_size
    rem.u32         %r141, %r153, %r131;       // page_offset
    mul.wide.u32    %rd14, %r140, 4;
    add.u64         %rd15, %rd42, %rd14;       // page_table addr
    ld.global.b32   %r142, [%rd15];           // physical_page
    // Paged element offset (FP8: element = byte)
    mul.lo.u32      %r143, %r142, %r134;       // physical_page * page_stride
    mul.lo.u32      %r144, %r141, %r133;       // page_offset * row_stride
    add.u32         %r143, %r143, %r144;
    add.u32         %r143, %r143, %r137;       // + kv_head_offset
    shl.b32         %r144, %r111, 5;           // quarter * 32 (element = byte offset)
    add.u32         %r143, %r143, %r144;       // total byte offset
    cvt.u64.u32     %rd16, %r143;
    add.u64         %rd17, %rd1, %rd16;        // K global addr

    // Bounds check
    setp.lt.u32     %p3, %r153, %r7;          // global_row < seq_kv

    // K SMEM dest
    add.u32         %r155, %r21, %r114;        // smem + row*128 + quarter*32

