    ld.global.b32   %r142, [%rd15];           // physical_page
    mul.lo.u32      %r143, %r142, %r134;       // physical_page * page_stride
    mul.lo.u32      %r144, %r141, %r133;       // page_offset * row_stride
    add.u32         %r143, %r143, %r144;
    add.u32         %r143, %r143, %r137;       // + kv_head_offset
    shl.b32         %r144, %r111, 5;           // quarter * 32
    add.u32         %r143, %r143, %r144;
    cvt.u64.u32     %rd16, %r143;
    add.u64         %rd17, %rd2, %rd16;        // V global addr

    setp.lt.u32     %p3, %r153, %r7;

    // V SMEM dest (offset by SMEM_V = 8192)
    add.u32         %r155, %r21, SMEM_V;
    add.u32         %r155, %r155, %r114;       // + row*128 + quarter*32

    selp.b32        %r100, 16, 0, %p3;
    cp.async.cg.shared.global [%r155],      [%rd17],      16, %r100;
    cp.async.cg.shared.global [%r155 + 16], [%rd17 + 16], 16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;
    bar.sync 0;

    // ================================================================
    // PV GEMM: O += P * V  (16x64) x (64x128) = 16x128
    // ================================================================
    // 2 kp-chunks x 16 n-groups = 32 MMAs per warp
    // P A-frag base: %r81 (row0), %r82 (row1)
    // V B-frag base: %r83
    // kp stride in P = 32, kp stride in V = 4096, ng stride in V = 8
    // b1 offset in V = 2048

    // kp=0: load P A-frags
    ld.shared.b32   %r160, [%r81];            // P a0: row0, kp0, first half
    ld.shared.b32   %r161, [%r82];            // P a1: row1, kp0, first half
    add.u32         %r91, %r81, 16;
    ld.shared.b32   %r162, [%r91];            // P a2: row0, kp0, second half
    add.u32         %r91, %r82, 16;
    ld.shared.b32   %r163, [%r91];            // P a3: row1, kp0, second half

    // ng0..ng15 for kp=0
    #define PV_MMA_NG(ng, f0, f1, f2, f3, pa0, pa1, pa2, pa3, vbase, ng_off) \
        add.u32 %r91, vbase, ng_off; \
        LOAD_FP8_B_FRAG_STRIDE(%r104, %r91, KV_ROW_STRIDE, %r156, %r157, %r158, %r159) \
        add.u32 %r91, %r91, 2048; \
        LOAD_FP8_B_FRAG_STRIDE(%r105, %r91, KV_ROW_STRIDE, %r156, %r157, %r158, %r159) \
        MMA_FP8_M16N8K32(f0, f1, f2, f3, pa0, pa1, pa2, pa3, %r104, %r105)

    PV_MMA_NG(0,  %f0,  %f1,  %f2,  %f3,  %r160, %r161, %r162, %r163, %r83, 0)
    PV_MMA_NG(1,  %f4,  %f5,  %f6,  %f7,  %r160, %r161, %r162, %r163, %r83, 8)
    PV_MMA_NG(2,  %f8,  %f9,  %f10, %f11, %r160, %r161, %r162, %r163, %r83, 16)
    PV_MMA_NG(3,  %f12, %f13, %f14, %f15, %r160, %r161, %r162, %r163, %r83, 24)
    PV_MMA_NG(4,  %f16, %f17, %f18, %f19, %r160, %r161, %r162, %r163, %r83, 32)
    PV_MMA_NG(5,  %f20, %f21, %f22, %f23, %r160, %r161, %r162, %r163, %r83, 40)
    PV_MMA_NG(6,  %f24, %f25, %f26, %f27, %r160, %r161, %r162, %r163, %r83, 48)
    PV_MMA_NG(7,  %f28, %f29, %f30, %f31, %r160, %r161, %r162, %r163, %r83, 56)
    PV_MMA_NG(8,  %f32, %f33, %f34, %f35, %r160, %r161, %r162, %r163, %r83, 64)
    PV_MMA_NG(9,  %f36, %f37, %f38, %f39, %r160, %r161, %r162, %r163, %r83, 72)
    PV_MMA_NG(10, %f40, %f41, %f42, %f43, %r160, %r161, %r162, %r163, %r83, 80)
    PV_MMA_NG(11, %f44, %f45, %f46, %f47, %r160, %r161, %r162, %r163, %r83, 88)
    PV_MMA_NG(12, %f48, %f49, %f50, %f51, %r160, %r161, %r162, %r163, %r83, 96)
    PV_MMA_NG(13, %f52, %f53, %f54, %f55, %r160, %r161, %r162, %r163, %r83, 104)
    PV_MMA_NG(14, %f56, %f57, %f58, %f59, %r160, %r161, %r162, %r163, %r83, 112)
    PV_MMA_NG(15, %f60, %f61, %f62, %f63, %r160, %r161, %r162, %r163, %r83, 120)

    // kp=1: load P A-frags (kp offset = 32 in P, 4096 in V)
    ld.shared.b32   %r160, [%r81 + 32];
    ld.shared.b32   %r161, [%r82 + 32];
    add.u32         %r91, %r81, 48;            // 32 + 16
    ld.shared.b32   %r162, [%r91];
    add.u32         %r91, %r82, 48;
    ld.shared.b32   %r163, [%r91];

    // V base for kp=1: %r83 + 4096
    add.u32         %r93, %r83, 4096;

    PV_MMA_NG(0,  %f0,  %f1,  %f2,  %f3,  %r160, %r161, %r162, %r163, %r93, 0)
    PV_MMA_NG(1,  %f4,  %f5,  %f6,  %f7,  %r160, %r161, %r162, %r163, %r93, 8)
    PV_MMA_NG(2,  %f8,  %f9,  %f10, %f11, %r160, %r161, %r162, %r163, %r93, 16)
    PV_MMA_NG(3,  %f12, %f13, %f14, %f15, %r160, %r161, %r162, %r163, %r93, 24)
    PV_MMA_NG(4,  %f16, %f17, %f18, %f19, %r160, %r161, %r162, %r163, %r93, 32)
    PV_MMA_NG(5,  %f20, %f21, %f22, %f23, %r160, %r161, %r162, %r163, %r93, 40)
    PV_MMA_NG(6,  %f24, %f25, %f26, %f27, %r160, %r161, %r162, %r163, %r93, 48)
    PV_MMA_NG(7,  %f28, %f29, %f30, %f31, %r160, %r161, %r162, %r163, %r93, 56)
    PV_MMA_NG(8,  %f32, %f33, %f34, %f35, %r160, %r161, %r162, %r163, %r93, 64)
    PV_MMA_NG(9,  %f36, %f37, %f38, %f39, %r160, %r161, %r162, %r163, %r93, 72)
    PV_MMA_NG(10, %f40, %f41, %f42, %f43, %r160, %r161, %r162, %r163, %r93, 80)
    PV_MMA_NG(11, %f44, %f45, %f46, %f47, %r160, %r161, %r162, %r163, %r93, 88)
    PV_MMA_NG(12, %f48, %f49, %f50, %f51, %r160, %r161, %r162, %r163, %r93, 96)
    PV_MMA_NG(13, %f52, %f53, %f54, %f55, %r160, %r161, %r162, %r163, %r93, 104)
    PV_MMA_NG(14, %f56, %f57, %f58, %f59, %r160, %r161, %r162, %r163, %r93, 112)
    PV_MMA_NG(15, %f60, %f61, %f62, %f63, %r160, %r161, %r162, %r163, %r93, 120)

    // ================================================================
    // Loop tail
    // ================================================================
    add.u32         %r150, %r150, 1;
    bra             kv_loop;

kv_done:

    // ================================================================
    // Split-KV Epilogue: normalize O, write FP32 partial O + LSE
    // ================================================================
    GROUP4_REDUCE_SUM_F32(%f194, %f98)
    GROUP4_REDUCE_SUM_F32(%f195, %f98)

    // LSE = log(row_sum) + row_max
    setp.eq.f32     %p10, %f194, 0f00000000;
    setp.eq.f32     %p11, %f195, 0f00000000;
    lg2.approx.f32  %f101, %f194;
    mul.f32         %f101, %f101, 0f3F317218;  // * ln(2)
    add.f32         %f101, %f101, %f192;       // + row_max[0]
    lg2.approx.f32  %f102, %f195;
    mul.f32         %f102, %f102, 0f3F317218;
    add.f32         %f102, %f102, %f193;       // + row_max[1]

    // Empty split: LSE = -inf, row_sum = 1
    @%p10 mov.b32   %f101, 0xff800000;
    @%p10 mov.f32   %f194, 0f3f800000;
    @%p11 mov.f32   %f195, 0f3f800000;
    @%p11 mov.b32   %f102, 0xff800000;

    // Normalize O
    rcp.approx.f32  %f103, %f194;
    rcp.approx.f32  %f104, %f195;

    mul.f32 %f0, %f0, %f103;    mul.f32 %f1, %f1, %f103;
    mul.f32 %f2, %f2, %f104;    mul.f32 %f3, %f3, %f104;
    mul.f32 %f4, %f4, %f103;    mul.f32 %f5, %f5, %f103;
    mul.f32 %f6, %f6, %f104;    mul.f32 %f7, %f7, %f104;
    mul.f32 %f8, %f8, %f103;    mul.f32 %f9, %f9, %f103;
    mul.f32 %f10, %f10, %f104;  mul.f32 %f11, %f11, %f104;
    mul.f32 %f12, %f12, %f103;  mul.f32 %f13, %f13, %f103;
    mul.f32 %f14, %f14, %f104;  mul.f32 %f15, %f15, %f104;
    mul.f32 %f16, %f16, %f103;  mul.f32 %f17, %f17, %f103;
    mul.f32 %f18, %f18, %f104;  mul.f32 %f19, %f19, %f104;
    mul.f32 %f20, %f20, %f103;  mul.f32 %f21, %f21, %f103;
    mul.f32 %f22, %f22, %f104;  mul.f32 %f23, %f23, %f104;
    mul.f32 %f24, %f24, %f103;  mul.f32 %f25, %f25, %f103;
    mul.f32 %f26, %f26, %f104;  mul.f32 %f27, %f27, %f104;
    mul.f32 %f28, %f28, %f103;  mul.f32 %f29, %f29, %f103;
    mul.f32 %f30, %f30, %f104;  mul.f32 %f31, %f31, %f104;
    mul.f32 %f32, %f32, %f103;  mul.f32 %f33, %f33, %f103;
    mul.f32 %f34, %f34, %f104;  mul.f32 %f35, %f35, %f104;
    mul.f32 %f36, %f36, %f103;  mul.f32 %f37, %f37, %f103;
    mul.f32 %f38, %f38, %f104;  mul.f32 %f39, %f39, %f104;
    mul.f32 %f40, %f40, %f103;  mul.f32 %f41, %f41, %f103;
    mul.f32 %f42, %f42, %f104;  mul.f32 %f43, %f43, %f104;
    mul.f32 %f44, %f44, %f103;  mul.f32 %f45, %f45, %f103;
    mul.f32 %f46, %f46, %f104;  mul.f32 %f47, %f47, %f104;
    mul.f32 %f48, %f48, %f103;  mul.f32 %f49, %f49, %f103;
    mul.f32 %f50, %f50, %f104;  mul.f32 %f51, %f51, %f104;
    mul.f32 %f52, %f52, %f103;  mul.f32 %f53, %f53, %f103;
    mul.f32 %f54, %f54, %f104;  mul.f32 %f55, %f55, %f104;
    mul.f32 %f56, %f56, %f103;  mul.f32 %f57, %f57, %f103;
    mul.f32 %f58, %f58, %f104;  mul.f32 %f59, %f59, %f104;
    mul.f32 %f60, %f60, %f103;  mul.f32 %f61, %f61, %f103;
    mul.f32 %f62, %f62, %f104;  mul.f32 %f63, %f63, %f104;

    // ================================================================
    // Store O_partial (FP32) to global memory
    // ================================================================
    // O_partial layout: [num_splits, B, H, Sq, D] f32
    ld.param.u64    %rd3, [param_O];

    // Compute split offset: split_idx * B * H * Sq * D
    mul.lo.u32      %r142, %r6, D;             // Sq * D
    mul.lo.u32      %r143, %r8, %r142;         // H * Sq * D
    mul.lo.u32      %r144, %r182, %r143;       // B * H * Sq * D (split stride)
    mul.lo.u32      %r146, %r181, %r144;       // split_idx * split_stride

    // Row computation
    shl.b32         %r115, %r9, 4;
    add.u32         %r116, %r15, %r115;
    add.u32         %r117, %r116, %r4;         // row0
    add.u32         %r118, %r117, 8;           // row1

    setp.lt.u32     %p4, %r117, %r6;
    setp.lt.u32     %p5, %r118, %r6;

    // batch_head offset = %r13 (from header)
    add.u32         %r147, %r146, %r13;        // split + batch/head offset
    mul.lo.u32      %r148, %r117, D;
    add.u32         %r149, %r147, %r148;       // + row0 offset
    shl.b32         %r150, %r5, 1;             // tidInGroup * 2

    mul.lo.u32      %r151, %r118, D;
    add.u32         %r152, %r147, %r151;       // + row1 offset

    #define STORE_NG_F32(f0, f1, f2, f3, ng_off) \
        add.u32 %r153, %r149, %r150; \
        add.u32 %r153, %r153, ng_off; \
        mul.wide.u32 %rd20, %r153, 4; \
        add.u64 %rd21, %rd3, %rd20; \
        @%p4 st.global.b32 [%rd21], f0; \
        add.u64 %rd21, %rd21, 4; \
        @%p4 st.global.b32 [%rd21], f1; \
        add.u32 %r153, %r152, %r150; \
        add.u32 %r153, %r153, ng_off; \
        mul.wide.u32 %rd20, %r153, 4; \
        add.u64 %rd21, %rd3, %rd20; \
        @%p5 st.global.b32 [%rd21], f2; \
        add.u64 %rd21, %rd21, 4; \
        @%p5 st.global.b32 [%rd21], f3;

    STORE_NG_F32(%f0, %f1, %f2, %f3, 0)
    STORE_NG_F32(%f4, %f5, %f6, %f7, 8)
    STORE_NG_F32(%f8, %f9, %f10, %f11, 16)
    STORE_NG_F32(%f12, %f13, %f14, %f15, 24)
    STORE_NG_F32(%f16, %f17, %f18, %f19, 32)
    STORE_NG_F32(%f20, %f21, %f22, %f23, 40)
    STORE_NG_F32(%f24, %f25, %f26, %f27, 48)
    STORE_NG_F32(%f28, %f29, %f30, %f31, 56)
    STORE_NG_F32(%f32, %f33, %f34, %f35, 64)
    STORE_NG_F32(%f36, %f37, %f38, %f39, 72)
    STORE_NG_F32(%f40, %f41, %f42, %f43, 80)
    STORE_NG_F32(%f44, %f45, %f46, %f47, 88)
    STORE_NG_F32(%f48, %f49, %f50, %f51, 96)
    STORE_NG_F32(%f52, %f53, %f54, %f55, 104)
    STORE_NG_F32(%f56, %f57, %f58, %f59, 112)
    STORE_NG_F32(%f60, %f61, %f62, %f63, 120)

    // ================================================================
    // Store LSE (FP32)
    // ================================================================
    setp.eq.u32     %p6, %r5, 0;              // tidInGroup == 0

    // LSE split stride = B * H * Sq
    mul.lo.u32      %r155, %r182, %r8;         // B * H
    mul.lo.u32      %r155, %r155, %r6;         // B * H * Sq
    ld.param.u32    %r156, [param_split_idx];
    mul.lo.u32      %r156, %r156, %r155;       // split_idx * split_stride

    mul.lo.u32      %r157, %r3, %r8;           // batch * H
    add.u32         %r157, %r157, %r2;         // + head
    mul.lo.u32      %r157, %r157, %r6;         // * Sq

    add.u32         %r158, %r156, %r157;
    add.u32         %r159, %r158, %r117;       // + row0
    mul.wide.u32    %rd25, %r159, 4;
    add.u64         %rd26, %rd30, %rd25;
    and.pred        %p7, %p4, %p6;
    @%p7 st.global.b32 [%rd26], %f101;

    add.u32         %r159, %r158, %r118;       // + row1
    mul.wide.u32    %rd25, %r159, 4;
    add.u64         %rd26, %rd30, %rd25;
    and.pred        %p7, %p5, %p6;
    @%p7 st.global.b32 [%rd26], %f102;

    ret;
}
