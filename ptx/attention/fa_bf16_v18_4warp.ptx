    sub.f32 %f77, %f77, %f204;  mul.f32 %f77, %f77, LOG2E;  ex2.approx.f32 %f77, %f77;
    sub.f32 %f78, %f78, %f205;  mul.f32 %f78, %f78, LOG2E;  ex2.approx.f32 %f78, %f78;
    sub.f32 %f79, %f79, %f205;  mul.f32 %f79, %f79, LOG2E;  ex2.approx.f32 %f79, %f79;
