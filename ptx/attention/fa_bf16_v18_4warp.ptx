    mul.f32 %f96, %f96, %f200;   mul.f32 %f97, %f97, %f200;
    mul.f32 %f98, %f98, %f200;   mul.f32 %f99, %f99, %f200;
    mul.f32 %f100, %f100, %f200; mul.f32 %f101, %f101, %f200;
    mul.f32 %f102, %f102, %f200; mul.f32 %f103, %f103, %f200;
    mul.f32 %f104, %f104, %f200; mul.f32 %f105, %f105, %f200;
    mul.f32 %f106, %f106, %f200; mul.f32 %f107, %f107, %f200;
    mul.f32 %f108, %f108, %f200; mul.f32 %f109, %f109, %f200;
    mul.f32 %f110, %f110, %f200; mul.f32 %f111, %f111, %f200;
    mul.f32 %f112, %f112, %f200; mul.f32 %f113, %f113, %f200;
    mul.f32 %f114, %f114, %f200; mul.f32 %f115, %f115, %f200;
    mul.f32 %f116, %f116, %f200; mul.f32 %f117, %f117, %f200;
    mul.f32 %f118, %f118, %f200; mul.f32 %f119, %f119, %f200;
    mul.f32 %f120, %f120, %f200; mul.f32 %f121, %f121, %f200;
    mul.f32 %f122, %f122, %f200; mul.f32 %f123, %f123, %f200;
    mul.f32 %f124, %f124, %f200; mul.f32 %f125, %f125, %f200;
    mul.f32 %f126, %f126, %f200; mul.f32 %f127, %f127, %f200;

    // ================================================================
    // rg0 Online softmax + P store to SMEM_P
    // ================================================================
    // Uses %f201..%f210 as temps. Softmax state: %f192..%f195.
    // P store targets: %r75 (row0), %r76 (row1)
    // --- rg0 softmax: find row max, rescale O_rg0, compute P = exp(S - max) ---
    // row0 max: d0,d1 values (even regs from each ng)
    mov.f32         %f201, %f64;
    max.f32 %f201, %f201, %f65;  max.f32 %f201, %f201, %f68;  max.f32 %f201, %f201, %f69;
    max.f32 %f201, %f201, %f72;  max.f32 %f201, %f201, %f73;  max.f32 %f201, %f201, %f76;
    max.f32 %f201, %f201, %f77;  max.f32 %f201, %f201, %f80;  max.f32 %f201, %f201, %f81;
    max.f32 %f201, %f201, %f84;  max.f32 %f201, %f201, %f85;  max.f32 %f201, %f201, %f88;
    max.f32 %f201, %f201, %f89;  max.f32 %f201, %f201, %f92;  max.f32 %f201, %f201, %f93;
    max.f32 %f201, %f201, %f96;  max.f32 %f201, %f201, %f97;  max.f32 %f201, %f201, %f100;
    max.f32 %f201, %f201, %f101; max.f32 %f201, %f201, %f104; max.f32 %f201, %f201, %f105;
    max.f32 %f201, %f201, %f108; max.f32 %f201, %f201, %f109; max.f32 %f201, %f201, %f112;
    max.f32 %f201, %f201, %f113; max.f32 %f201, %f201, %f116; max.f32 %f201, %f201, %f117;
    max.f32 %f201, %f201, %f120; max.f32 %f201, %f201, %f121; max.f32 %f201, %f201, %f124;
    max.f32 %f201, %f201, %f125;

    // row1 max: d2,d3 values
    mov.f32         %f202, %f66;
    max.f32 %f202, %f202, %f67;  max.f32 %f202, %f202, %f70;  max.f32 %f202, %f202, %f71;
    max.f32 %f202, %f202, %f74;  max.f32 %f202, %f202, %f75;  max.f32 %f202, %f202, %f78;
    max.f32 %f202, %f202, %f79;  max.f32 %f202, %f202, %f82;  max.f32 %f202, %f202, %f83;
    max.f32 %f202, %f202, %f86;  max.f32 %f202, %f202, %f87;  max.f32 %f202, %f202, %f90;
    max.f32 %f202, %f202, %f91;  max.f32 %f202, %f202, %f94;  max.f32 %f202, %f202, %f95;
    max.f32 %f202, %f202, %f98;  max.f32 %f202, %f202, %f99;  max.f32 %f202, %f202, %f102;
    max.f32 %f202, %f202, %f103; max.f32 %f202, %f202, %f106; max.f32 %f202, %f202, %f107;
    max.f32 %f202, %f202, %f110; max.f32 %f202, %f202, %f111; max.f32 %f202, %f202, %f114;
    max.f32 %f202, %f202, %f115; max.f32 %f202, %f202, %f118; max.f32 %f202, %f202, %f119;
    max.f32 %f202, %f202, %f122; max.f32 %f202, %f202, %f123; max.f32 %f202, %f202, %f126;
    max.f32 %f202, %f202, %f127;

    GROUP4_REDUCE_MAX_F32(%f201, %f203)
    GROUP4_REDUCE_MAX_F32(%f202, %f203)


    // Combine with running max (both scaled)
    max.f32         %f204, %f192, %f201;
    max.f32         %f205, %f193, %f202;

    // NaN guard
    mov.b32 %f203, 0xff800000; setp.eq.f32 %p10, %f204, %f203;
    @%p10 mov.f32   %f204, 0f00000000;
    mov.b32 %f203, 0xff800000; setp.eq.f32 %p10, %f205, %f203;
    @%p10 mov.f32   %f205, 0f00000000;

    // Correction factors
    sub.f32 %f206, %f192, %f204; mul.f32 %f206, %f206, LOG2E; ex2.approx.f32 %f206, %f206;
    sub.f32 %f207, %f193, %f205; mul.f32 %f207, %f207, LOG2E; ex2.approx.f32 %f207, %f207;

    // Rescale O_rg0 by correction
    mul.f32 %f0, %f0, %f206;    mul.f32 %f1, %f1, %f206;
    mul.f32 %f2, %f2, %f207;    mul.f32 %f3, %f3, %f207;
    mul.f32 %f4, %f4, %f206;    mul.f32 %f5, %f5, %f206;
    mul.f32 %f6, %f6, %f207;    mul.f32 %f7, %f7, %f207;
    mul.f32 %f8, %f8, %f206;    mul.f32 %f9, %f9, %f206;
    mul.f32 %f10, %f10, %f207;  mul.f32 %f11, %f11, %f207;
    mul.f32 %f12, %f12, %f206;  mul.f32 %f13, %f13, %f206;
