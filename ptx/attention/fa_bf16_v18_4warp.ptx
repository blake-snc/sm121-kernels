// fa_bf16_v18_4warp.ptx
//
// Flash Attention (non-causal) for BF16 with d=128.
// FlashAttention-2 online softmax algorithm.
//
// 4 warps (128 threads), Br=128, Bc=128, d=128.
// Each warp handles 32 Q rows via 2 sequential row groups (rg0: rows 0-15, rg1: rows 16-31).
// Grid: (ceil(seq_q/128), num_heads, batch_size)
//
// Q,K,V: [batch, num_heads, seq, 128] row-major bf16
// O:     [batch, num_heads, seq, 128] row-major bf16
//
// MMA: mma.sync.aligned.m16n8k16.row.col.f32.bf16.bf16.f32
//
// SMEM layout (98304 bytes = 96 KB):
//   [0     .. 32767]  Q tile: 128 rows x 128 cols x 2B = 32768 bytes (persistent)
//   [32768 .. 65535]  K tile then V tile: 128 rows x 128 cols x 2B = 32768 bytes
//   [65536 .. 98303]  P tile: 128 rows x 128 cols x 2B = 32768 bytes
//
// Q is loaded ONCE and persists in SMEM. Q fragments are reloaded per-kc (4 regs).
// K and V share the same 32KB buffer (K during QK, V during PV).
// P is stored to a dedicated 32KB buffer that doesn't conflict with K or V.
//
// Register budget per thread:
//   O_rg0 accumulators: 16 ng x 4 regs = 64 regs (.f32) %f0..%f63
//   S accumulators:     16 ng x 4 regs = 64 regs (.f32) %f64..%f127 (shared rg0/rg1)
//   O_rg1 accumulators: 16 ng x 4 regs = 64 regs (.f32) %f128..%f191
//   Softmax rg0:        row_max(2) + row_sum(2) = 4 regs %f192..%f195
//   Softmax rg1:        row_max(2) + row_sum(2) = 4 regs %f196..%f199
//   Scale:              1 reg %f200
//   Temps:              ~20 regs
//   Total:              ~221 regs (within 256 limit)
//
// KV loop body:
//   1. K load to SMEM_KV (128 threads load 32KB cooperatively)
//   2. bar.sync
//   3. rg0 QK: reload Q per-kc from SMEM_Q, K from SMEM_KV -> S in %f64..%f127
//   4. rg1 QK: reload Q per-kc from SMEM_Q, K from SMEM_KV -> S in %f64..%f127
//   5. rg0 softmax -> P store to SMEM_P
//   6. rg1 softmax -> P store to SMEM_P
//   7. V load to SMEM_KV (overwrites K, which is no longer needed)
//   8. bar.sync
//   9. rg0 PV: P from SMEM_P, V from SMEM_KV -> accumulate into O_rg0
//  10. rg1 PV: P from SMEM_P, V from SMEM_KV -> accumulate into O_rg1

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

// Tile dimensions
#define BR 128
#define BC 128
#define D  128

// SMEM layout (96 KB):
//   [0, 32768)       Q tile (persistent)
//   [32768, 65536)   K tile then V tile (shared buffer)
//   [65536, 98304)   P tile
#define SMEM_Q    0
#define SMEM_KV   32768
#define SMEM_P    65536

// Row strides (bytes per row in SMEM)
#define KV_ROW_STRIDE (D * 2)
#define P_ROW_STRIDE  (BC * 2)

.visible .entry flash_attn_bf16_v18_4warp(
    .param .u64 param_Q,        // [B, H, Sq, 128] bf16
    .param .u64 param_K,        // [B, H, Skv, 128] bf16
    .param .u64 param_V,        // [B, H, Skv, 128] bf16
    .param .u64 param_O,        // [B, H, Sq, 128] bf16 (output)
    .param .u32 param_seq_q,    // sequence length Q
    .param .u32 param_seq_kv,   // sequence length KV
    .param .u32 param_num_heads,
    .param .f32 param_scale     // 1/sqrt(d)
)
{
    // ================================================================
    // Register declarations
    // ================================================================
    .reg .b32  %r<200>;
    .reg .b64  %rd<48>;
    .reg .f32  %f<260>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    // Shared memory: Q(32KB) + K/V(32KB) + P(32KB) = 98304 bytes
    .shared .align 128 .b8 smem[98304];

    // ================================================================
    // Thread/block identification
    // ================================================================
    mov.u32         %r0, %tid.x;               // tid [0..127]
    mov.u32         %r1, %ctaid.x;             // q_block_idx
    mov.u32         %r2, %ctaid.y;             // head_idx
    mov.u32         %r3, %ctaid.z;             // batch_idx

    // Warp and lane decomposition
    and.b32         %r10, %r0, 31;             // lane = tid % 32 [0..31]
    shr.b32         %r9, %r0, 5;              // warp_id = tid / 32 [0..3]

    // MMA thread decomposition (based on LANE, not tid)
    shr.b32         %r4, %r10, 2;             // groupID = lane / 4  [0..7]
    and.b32         %r5, %r10, 3;             // tidInGroup = lane % 4  [0..3]

    // ================================================================
    // Load parameters
    // ================================================================
    ld.param.u64    %rd0, [param_Q];
    ld.param.u64    %rd1, [param_K];
    ld.param.u64    %rd2, [param_V];
    ld.param.u64    %rd3, [param_O];
    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f200, [param_scale];

    // ================================================================
    // Compute base pointers for this (batch, head, q_block)
    // ================================================================
    mul.lo.u32      %r11, %r6, D;             // seq_q * 128
    mul.lo.u32      %r12, %r8, %r11;          // num_heads * seq_q * 128 (batch stride)
    mul.lo.u32      %r13, %r3, %r12;          // batch * batch_stride
    mul.lo.u32      %r14, %r2, %r11;          // head * head_stride
    add.u32         %r13, %r13, %r14;         // batch_off + head_off (Q/O)

    shl.b32         %r15, %r1, 7;             // q_block * BR = q_block * 128
    mul.lo.u32      %r16, %r15, D;            // q_block * BR * 128
    add.u32         %r17, %r13, %r16;         // total Q element offset

    mul.wide.u32    %rd4, %r17, 2;            // byte offset
    add.u64         %rd5, %rd0, %rd4;         // Q base ptr for this block

    // O base: batch+head offset only (store uses global row)
    mul.wide.u32    %rd40, %r13, 2;           // batch+head byte offset
    add.u64         %rd6, %rd3, %rd40;        // O base ptr (no q_block)

    // K/V base: param_K + (batch * num_heads * seq_kv * 128 + head * seq_kv * 128) * 2
    mul.lo.u32      %r18, %r7, D;             // seq_kv * 128
    mul.lo.u32      %r19, %r8, %r18;          // num_heads * seq_kv * 128 (batch stride)
    mul.lo.u32      %r20, %r3, %r19;          // batch * batch_stride
    mul.lo.u32      %r23, %r2, %r18;          // head * head_stride
    add.u32         %r20, %r20, %r23;         // batch_off + head_off (K/V)
    mul.wide.u32    %rd7, %r20, 2;            // byte offset
    add.u64         %rd8, %rd1, %rd7;         // K base ptr
    add.u64         %rd9, %rd2, %rd7;         // V base ptr

    // smem base
    mov.u32         %r21, smem;

    // ================================================================
    // Precompute Q ldmatrix addresses for rg0 and rg1
    // ================================================================
    // Q is at SMEM_Q (offset 0), persistent. 128 rows x 128 cols, row stride 256.
    // Each warp handles 32 rows: rg0 = rows [warp*32 .. warp*32+15], rg1 = rows [warp*32+16 .. warp*32+31]
    // ldmatrix.x4 for 16x16 subtile at column kc*16:
    //   lane < 16: base + lane * 256 + kc * 32
    //   lane >= 16: base + (lane-16) * 256 + kc * 32 + 16

    setp.lt.u32     %p0, %r10, 16;

    // rg0 Q base: smem + SMEM_Q + warp*32*256 = smem + warp*8192
    mul.lo.u32      %r62, %r9, 8192;          // warp_id * 8192 (32 rows * 256 bytes)
    @%p0 mul.lo.u32 %r63, %r10, 256;          // lane < 16: lane * 256
    @!%p0 sub.u32   %r63, %r10, 16;
    @!%p0 mul.lo.u32 %r63, %r63, 256;         // (lane-16) * 256
    @!%p0 add.u32   %r63, %r63, 16;           // + 16 bytes
    add.u32         %r63, %r63, %r62;         // + warp offset (rg0)
    add.u32         %r29, %r21, %r63;         // smem + rg0 Q ldmatrix base
    // %r29 = rg0 Q ldmatrix base. Add kc*32 per k-chunk.

    // rg1 Q base: rg0 base + 4096 (16 rows * 256 bytes)
    add.u32         %r30, %r29, 4096;         // rg1 Q ldmatrix base

    // ================================================================
    // Cooperative Q load: 128 threads load Q[128,128] to SMEM_Q
    // ================================================================
    // 128 threads load 128 rows x 128 cols x 2B = 32768 bytes
    // Each thread loads one full row: 256 bytes = 16 x cp.async(16B)
    //   row = tid [0..127]
    //   global_addr = Q_base + row * 256
    //   smem_addr = smem + SMEM_Q + row * 256

    // Global address
    mul.lo.u32      %r26, %r0, 256;           // row * 256 bytes (tid = row)
    cvt.u64.u32     %rd10, %r26;
    add.u64         %rd13, %rd5, %rd10;       // &Q[row][0]

    // SMEM store address
    add.u32         %r28, %r21, %r26;         // smem + SMEM_Q(0) + row*256

    // Bounds check: q_block*128 + row < seq_q
    add.u32         %r31, %r15, %r0;          // q_block*128 + row (tid = row for 128 threads)
    setp.lt.u32     %p1, %r31, %r6;

    // Load 256 bytes via cp.async: 16 x 16B
    selp.b32        %r100, 16, 0, %p1;
    cp.async.cg.shared.global [%r28],       [%rd13],       16, %r100;
    cp.async.cg.shared.global [%r28 + 16],  [%rd13 + 16],  16, %r100;
    cp.async.cg.shared.global [%r28 + 32],  [%rd13 + 32],  16, %r100;
    cp.async.cg.shared.global [%r28 + 48],  [%rd13 + 48],  16, %r100;
    cp.async.cg.shared.global [%r28 + 64],  [%rd13 + 64],  16, %r100;
    cp.async.cg.shared.global [%r28 + 80],  [%rd13 + 80],  16, %r100;
    cp.async.cg.shared.global [%r28 + 96],  [%rd13 + 96],  16, %r100;
    cp.async.cg.shared.global [%r28 + 112], [%rd13 + 112], 16, %r100;
    cp.async.cg.shared.global [%r28 + 128], [%rd13 + 128], 16, %r100;
    cp.async.cg.shared.global [%r28 + 144], [%rd13 + 144], 16, %r100;
    cp.async.cg.shared.global [%r28 + 160], [%rd13 + 160], 16, %r100;
    cp.async.cg.shared.global [%r28 + 176], [%rd13 + 176], 16, %r100;
    cp.async.cg.shared.global [%r28 + 192], [%rd13 + 192], 16, %r100;
    cp.async.cg.shared.global [%r28 + 208], [%rd13 + 208], 16, %r100;
    cp.async.cg.shared.global [%r28 + 224], [%rd13 + 224], 16, %r100;
    cp.async.cg.shared.global [%r28 + 240], [%rd13 + 240], 16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;
    bar.sync 0;

    // ================================================================
    // Initialize O accumulators and softmax state
    // ================================================================
    // O_rg0: %f0..%f63
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    // O_rg1: %f128..%f191
    mov.f32 %f128, 0.0; mov.f32 %f129, 0.0; mov.f32 %f130, 0.0; mov.f32 %f131, 0.0;
    mov.f32 %f132, 0.0; mov.f32 %f133, 0.0; mov.f32 %f134, 0.0; mov.f32 %f135, 0.0;
    mov.f32 %f136, 0.0; mov.f32 %f137, 0.0; mov.f32 %f138, 0.0; mov.f32 %f139, 0.0;
    mov.f32 %f140, 0.0; mov.f32 %f141, 0.0; mov.f32 %f142, 0.0; mov.f32 %f143, 0.0;
    mov.f32 %f144, 0.0; mov.f32 %f145, 0.0; mov.f32 %f146, 0.0; mov.f32 %f147, 0.0;
    mov.f32 %f148, 0.0; mov.f32 %f149, 0.0; mov.f32 %f150, 0.0; mov.f32 %f151, 0.0;
    mov.f32 %f152, 0.0; mov.f32 %f153, 0.0; mov.f32 %f154, 0.0; mov.f32 %f155, 0.0;
    mov.f32 %f156, 0.0; mov.f32 %f157, 0.0; mov.f32 %f158, 0.0; mov.f32 %f159, 0.0;
    mov.f32 %f160, 0.0; mov.f32 %f161, 0.0; mov.f32 %f162, 0.0; mov.f32 %f163, 0.0;
    mov.f32 %f164, 0.0; mov.f32 %f165, 0.0; mov.f32 %f166, 0.0; mov.f32 %f167, 0.0;
    mov.f32 %f168, 0.0; mov.f32 %f169, 0.0; mov.f32 %f170, 0.0; mov.f32 %f171, 0.0;
    mov.f32 %f172, 0.0; mov.f32 %f173, 0.0; mov.f32 %f174, 0.0; mov.f32 %f175, 0.0;
    mov.f32 %f176, 0.0; mov.f32 %f177, 0.0; mov.f32 %f178, 0.0; mov.f32 %f179, 0.0;
    mov.f32 %f180, 0.0; mov.f32 %f181, 0.0; mov.f32 %f182, 0.0; mov.f32 %f183, 0.0;
    mov.f32 %f184, 0.0; mov.f32 %f185, 0.0; mov.f32 %f186, 0.0; mov.f32 %f187, 0.0;
    mov.f32 %f188, 0.0; mov.f32 %f189, 0.0; mov.f32 %f190, 0.0; mov.f32 %f191, 0.0;

    // Softmax state rg0: %f192..%f195
    mov.b32         %f192, 0xff800000;         // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;         // row_max[1] = -inf
    mov.f32         %f194, 0.0;                // row_sum[0] = 0
    mov.f32         %f195, 0.0;                // row_sum[1] = 0

    // Softmax state rg1: %f196..%f199
    mov.b32         %f196, 0xff800000;         // row_max[0] = -inf
    mov.b32         %f197, 0xff800000;         // row_max[1] = -inf
    mov.f32         %f198, 0.0;                // row_sum[0] = 0
    mov.f32         %f199, 0.0;                // row_sum[1] = 0

    // ================================================================
    // Precompute K/V/P SMEM address helpers
    // ================================================================

    // K ldmatrix addresses (B-operand for QK^T, at SMEM_KV = 32768)
    // ldmatrix.x2: addr = smem + SMEM_KV + (ng*8 + sub_lane)*256 + kc*32 + half*16
    and.b32         %r68, %r10, 7;             // sub_lane = lane % 8
    mul.lo.u32      %r69, %r68, KV_ROW_STRIDE; // sub_lane * 256
    shr.b32         %r94, %r10, 3;
    and.b32         %r94, %r94, 1;            // half = (lane/8) % 2
    shl.b32         %r94, %r94, 4;            // half * 16
    add.u32         %r69, %r69, %r94;         // sub_lane*256 + half*16

    // V ldmatrix addresses (B-operand for PV, at SMEM_KV = 32768)
    // ldmatrix.x2.trans: addr = SMEM_KV + (kp*16 + lane%16)*256 + ng*16
    and.b32         %r95, %r10, 15;            // lane % 16
    mul.lo.u32      %r96, %r95, KV_ROW_STRIDE; // (lane%16) * 256

    // P store addresses (at SMEM_P = 65536)
    // rg0: P_base = smem + SMEM_P + warp*8192
    // rg1: P_base = smem + SMEM_P + warp*8192 + 4096
    mul.lo.u32      %r70, %r9, 8192;          // warp_id * 8192 (32 rows per warp)

    // P store row0/row1 within 16-row rg tile:
    //   row0 = groupID, row1 = groupID+8
    mul.lo.u32      %r72, %r4, P_ROW_STRIDE;  // groupID * 256
    add.u32         %r73, %r72, 2048;          // (groupID+8) * 256
    shl.b32         %r74, %r5, 2;              // tidInGroup * 2 * 2 = col byte offset

    // rg0 P store bases
    add.u32         %r75, %r21, %r70;
    add.u32         %r75, %r75, SMEM_P;        // smem + SMEM_P + warp*8192
    add.u32         %r76, %r75, %r73;          // row1 base
    add.u32         %r76, %r76, %r74;
    add.u32         %r75, %r75, %r72;          // row0 base
    add.u32         %r75, %r75, %r74;

    // rg1 P store bases: +4096 from rg0
    add.u32         %r160, %r75, 4096;         // rg1 row0
    add.u32         %r161, %r76, 4096;         // rg1 row1

    // P ldmatrix addresses (A-operand for PV, at SMEM_P = 65536)
    // rg0: P_ldm_base = smem + SMEM_P + warp*8192 + per_lane_offset
    //   lane < 16: warp_base + lane * 256 + kp * 32
    //   lane >= 16: warp_base + (lane-16) * 256 + kp * 32 + 16
    @%p0 mul.lo.u32 %r77, %r10, P_ROW_STRIDE;            // lane * 256
    @!%p0 sub.u32   %r77, %r10, 16;
    @!%p0 mul.lo.u32 %r77, %r77, P_ROW_STRIDE;            // (lane-16)*256
    @!%p0 add.u32   %r77, %r77, 16;

    // rg0 P ldmatrix base
    add.u32         %r78, %r21, %r70;
    add.u32         %r78, %r78, SMEM_P;
    add.u32         %r78, %r78, %r77;          // P ldmatrix base rg0

    // rg1 P ldmatrix base: +4096
    add.u32         %r162, %r78, 4096;         // P ldmatrix base rg1

    // ================================================================
    // Precompute cooperative K/V load helpers
    // ================================================================
    // 128 threads load K/V [128, 128] bf16 = 32768 bytes cooperatively
    // Each thread loads one full row (256 bytes = 16 x cp.async(16B))
    //   kv_load_row = tid [0..127]
    //   smem_addr = smem + SMEM_KV + row * 256

    mul.lo.u32      %r112, %r0, KV_ROW_STRIDE; // row * 256 (tid = row for 128 threads)

    // ================================================================
    // KV BLOCK LOOP
    // ================================================================
    mov.u32         %r80, 0;                   // kv_block = 0
    add.u32         %r81, %r7, 127;
    shr.b32         %r81, %r81, 7;             // num_kv_blocks = ceil(seq_kv / 128)

kv_loop:
    setp.ge.u32     %p2, %r80, %r81;
    @%p2 bra        kv_done;

    // ================================================================
    // Cooperative K load: 128 threads -> K[128,128] to SMEM_KV
    // ================================================================
    shl.b32         %r82, %r80, 7;             // kv_block * 128

    // Global address: K_base + (kv_block*128 + tid) * D * 2
    add.u32         %r83, %r82, %r0;           // global_row = kv_block*128 + tid
    mul.lo.u32      %r84, %r83, D;            // global_row * 128 (elements)
    add.u32         %r84, %r84, %r20;         // + batch/head offset (elements)
    mul.wide.u32    %rd14, %r84, 2;           // byte offset
    add.u64         %rd15, %rd1, %rd14;       // K global addr

    // Bounds check
    setp.lt.u32     %p3, %r83, %r7;           // global_row < seq_kv

    // SMEM addr = smem + SMEM_KV + row*256
    add.u32         %r86, %r21, %r112;
    add.u32         %r86, %r86, SMEM_KV;      // smem + SMEM_KV + row*256

    // Load 256 bytes via cp.async: 16 x 16B
    selp.b32        %r100, 16, 0, %p3;
    cp.async.cg.shared.global [%r86],      [%rd15],      16, %r100;
    cp.async.cg.shared.global [%r86 + 16], [%rd15 + 16], 16, %r100;
    cp.async.cg.shared.global [%r86 + 32], [%rd15 + 32], 16, %r100;
    cp.async.cg.shared.global [%r86 + 48], [%rd15 + 48], 16, %r100;
    cp.async.cg.shared.global [%r86 + 64], [%rd15 + 64], 16, %r100;
    cp.async.cg.shared.global [%r86 + 80], [%rd15 + 80], 16, %r100;
    cp.async.cg.shared.global [%r86 + 96], [%rd15 + 96], 16, %r100;
    cp.async.cg.shared.global [%r86 + 112],[%rd15 + 112],16, %r100;
    cp.async.cg.shared.global [%r86 + 128],[%rd15 + 128],16, %r100;
    cp.async.cg.shared.global [%r86 + 144],[%rd15 + 144],16, %r100;
    cp.async.cg.shared.global [%r86 + 160],[%rd15 + 160],16, %r100;
    cp.async.cg.shared.global [%r86 + 176],[%rd15 + 176],16, %r100;
