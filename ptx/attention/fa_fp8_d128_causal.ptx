    LOAD_FP8_B_FRAG_STRIDE(%r105, %r90, KV_ROW_STRIDE, %r140, %r141, %r142, %r143)
    MMA_FP8_M16N8K32(%f48, %f49, %f50, %f51, %r106, %r107, %r108, %r109, %r104, %r105)

