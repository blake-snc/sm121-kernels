    mul.f32 %f62, %f62, %f102;  mul.f32 %f63, %f63, %f102;

    // ================================================================
    // Store O to global memory (BF16)
    // ================================================================
    // O layout: [B, H, Sq, 128] row-major bf16
    // row0 = q_block*16 + groupID, row1 = q_block*16 + groupID + 8
    add.u32         %r110, %r14, %r4;          // row0 = q_block*16 + groupID
    add.u32         %r111, %r110, 8;            // row1 = row0 + 8

    // bounds check
    setp.lt.u32     %p3, %r110, %r6;
    setp.lt.u32     %p4, %r111, %r6;

    // O byte address: O_base (bf16) + row * 128 * 2 = row * 256
    mul.lo.u32      %r112, %r110, 256;
    cvt.u64.u32     %rd20, %r112;
    add.u64         %rd21, %rd6, %rd20;        // &O[row0][0]

    mul.lo.u32      %r113, %r111, 256;
    cvt.u64.u32     %rd22, %r113;
