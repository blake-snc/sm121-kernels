// fa_bf16_varlen_d128.ptx
//
// Variable-length Flash Attention (non-causal) for BF16 with d=128.
// FlashAttention-2 online softmax algorithm.
//
// Handles batched sequences of different lengths using cumulative
// sequence length arrays (cu_seqlens). Matches FlashAttention-2 varlen API.
//
// 1 warp (32 threads), Br=16, Bc=64, d=128.
// Grid: (ceil(max_seqlen_q/Br), num_heads, batch_size)
// Block: (32, 1, 1)
//
// Q,K,V: [total_tokens, num_heads, 128] row-major bf16
// O:     [total_q_tokens, num_heads, 128] row-major bf16
// cu_seqlens_q: [batch+1] u32 (cumulative Q sequence lengths)
// cu_seqlens_k: [batch+1] u32 (cumulative K/V sequence lengths)
//
// Token stride = num_heads * 128 * 2 = num_heads * 256 bytes
// Head stride  = 128 * 2 = 256 bytes
//
// MMA: mma.sync.aligned.m16n8k16.row.col.f32.bf16.bf16.f32
//
// SMEM layout (18432 bytes):
//   [0 ..  16383]  K/V tile: 64 rows x 128 cols x 2B = 16384 bytes
//   [16384..18431]  P tile:  16 rows x 64 cols x 2B  = 2048 bytes

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

// Tile dimensions
#define BR 16
#define BC 64
#define D  128

// SMEM offsets
#define SMEM_KV   0
#define SMEM_P    16384

// SMEM sizes: K/V tile row stride = 128 cols * 2B = 256 bytes
#define KV_ROW_STRIDE 256

// P tile row stride = 64 cols * 2B = 128 bytes
#define P_ROW_STRIDE 128

.visible .entry flash_attn_bf16_varlen_d128(
    .param .u64 param_Q,            // [total_q, num_heads, 128] bf16
    .param .u64 param_K,            // [total_kv, num_heads, 128] bf16
    .param .u64 param_V,            // [total_kv, num_heads, 128] bf16
    .param .u64 param_O,            // [total_q, num_heads, 128] bf16 (output)
    .param .u64 param_cu_seqlens_q, // [batch+1] u32
    .param .u64 param_cu_seqlens_k, // [batch+1] u32
    .param .u32 param_num_heads,
    .param .u32 param_max_seqlen_q, // max Q sequence length (for grid sizing)
    .param .f32 param_scale         // 1/sqrt(d)
)
{
    // ================================================================
    // Register declarations
    // ================================================================
    .reg .b32  %r<170>;
    .reg .b64  %rd<48>;
    .reg .f32  %f<200>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    // Shared memory: K/V tile (16384) + P tile (2048) = 18432 bytes
    .shared .align 128 .b8 smem[18432];

    // ================================================================
    // Thread/block identification
    // ================================================================
    mov.u32         %r0, %tid.x;               // lane [0..31]
    mov.u32         %r1, %ctaid.x;             // q_block_idx
    mov.u32         %r2, %ctaid.y;             // head_idx
    mov.u32         %r3, %ctaid.z;             // batch_idx

    // MMA thread decomposition
    shr.b32         %r4, %r0, 2;              // groupID = lane / 4  [0..7]
    and.b32         %r5, %r0, 3;              // tidInGroup = lane % 4  [0..3]

    // ================================================================
    // Load parameters
    // ================================================================
    ld.param.u64    %rd0, [param_Q];
    ld.param.u64    %rd1, [param_K];
    ld.param.u64    %rd2, [param_V];
    ld.param.u64    %rd3, [param_O];
    ld.param.u64    %rd30, [param_cu_seqlens_q];
    ld.param.u64    %rd31, [param_cu_seqlens_k];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.u32    %r9, [param_max_seqlen_q];
    ld.param.f32    %f196, [param_scale];

    // ================================================================
    // Load cu_seqlens for this batch element
    // ================================================================
    // cu_seqlens_q[batch_idx] and cu_seqlens_q[batch_idx + 1]
    cvt.u64.u32     %rd32, %r3;                // batch_idx as u64
    shl.b64         %rd32, %rd32, 2;           // * 4 bytes (u32 elements)
    add.u64         %rd33, %rd30, %rd32;       // &cu_seqlens_q[batch_idx]
    ld.global.u32   %r130, [%rd33];            // cu_q_start
    ld.global.u32   %r131, [%rd33 + 4];        // cu_q_end

    add.u64         %rd34, %rd31, %rd32;       // &cu_seqlens_k[batch_idx]
    ld.global.u32   %r132, [%rd34];            // cu_k_start
    ld.global.u32   %r133, [%rd34 + 4];        // cu_k_end

    // Compute per-batch sequence lengths
    sub.u32         %r6, %r131, %r130;         // seq_q = cu_q_end - cu_q_start
    sub.u32         %r7, %r133, %r132;         // seq_kv = cu_k_end - cu_k_start

    // ================================================================
    // Early exit: if this q_block is beyond this batch's seq_q
    // ================================================================
    shl.b32         %r14, %r1, 4;             // q_block_start = q_block_idx * 16
    setp.ge.u32     %p15, %r14, %r6;          // q_block_start >= seq_q?
    @%p15 bra       early_exit;

    // ================================================================
    // Compute base pointers for this (batch, head)
    // ================================================================
    // Layout: [total_tokens, num_heads, 128] row-major
    // Token stride = num_heads * 128 elements = num_heads * 256 bytes
    // Head stride = 128 elements = 256 bytes
    //
    // Q_base = param_Q + cu_q_start * num_heads * 256 + head_idx * 256  (byte addr)
    // Then token t within this sequence: Q_base + t * num_heads * 256

    // Compute token_stride_bytes = num_heads * 256
    shl.b32         %r134, %r8, 8;            // num_heads * 256 (token stride in bytes)

    // Q/O base: param_Q + (cu_q_start * num_heads + head_idx) * 256
    mul.lo.u32      %r135, %r130, %r8;        // cu_q_start * num_heads
    add.u32         %r136, %r135, %r2;        // cu_q_start * num_heads + head_idx
    mul.wide.u32    %rd35, %r136, 256;        // byte offset
    add.u64         %rd5, %rd0, %rd35;        // Q base ptr for this (batch, head)
    add.u64         %rd6, %rd3, %rd35;        // O base ptr for this (batch, head)

    // K/V base: param_K + (cu_k_start * num_heads + head_idx) * 256
    mul.lo.u32      %r137, %r132, %r8;        // cu_k_start * num_heads
    add.u32         %r138, %r137, %r2;        // cu_k_start * num_heads + head_idx
    mul.wide.u32    %rd36, %r138, 256;        // byte offset
    add.u64         %rd8, %rd1, %rd36;        // K base ptr for this (batch, head)
    add.u64         %rd9, %rd2, %rd36;        // V base ptr for this (batch, head)

    // smem base
    mov.u32         %r21, smem;

    // ================================================================
    // Precompute ldmatrix addresses for Q (constant across KV loop)
    // ================================================================
    setp.lt.u32     %p0, %r0, 16;
    @%p0 mul.lo.u32 %r22, %r0, 32;
    @!%p0 sub.u32   %r22, %r0, 16;
    @!%p0 mad.lo.u32 %r22, %r22, 32, 16;

    // ================================================================
    // Load Q tile to registers via SMEM
    // ================================================================
    // Q tile: 16 rows x 128 cols loaded in 8 k-chunks of 16x16.
    // Each k-chunk: load Q[row, kc*16..+16] to SMEM, ldmatrix to regs.
    //
    // Thread mapping for loading 16x16 bf16 tile (512 bytes):
    //   32 threads, each loads 16B. row = lane % 16, half = lane / 16.
    //   smem_addr = row * 32 + half * 16
    //   global_addr = Q_base + row * token_stride + (kc*16 + half*8) * 2

    and.b32         %r23, %r0, 15;            // q_load_row = lane % 16
    shr.b32         %r24, %r0, 4;             // q_load_half = lane / 16 (0 or 1)

    // Q global row address: Q_base + q_load_row * token_stride_bytes
    // token_stride_bytes = num_heads * 256 = %r134
    mul.lo.u32      %r25, %r23, %r134;        // q_load_row * token_stride_bytes
    cvt.u64.u32     %rd10, %r25;
    // Also add q_block_start * token_stride_bytes to skip to correct rows
    mul.lo.u32      %r139, %r14, %r134;       // q_block_start * token_stride_bytes
    cvt.u64.u32     %rd37, %r139;
    add.u64         %rd11, %rd5, %rd37;       // Q base + q_block offset
    add.u64         %rd11, %rd11, %rd10;      // + row offset = &Q[q_block_start + row][head][0]

    // SMEM store address for Q load: row * 32 + half * 16
    mul.lo.u32      %r26, %r23, 32;           // row * 32
    shl.b32         %r27, %r24, 4;            // half * 16
    add.u32         %r26, %r26, %r27;
    add.u32         %r28, %r21, %r26;         // smem + row*32 + half*16

    // ldmatrix base address
    add.u32         %r29, %r21, %r22;         // smem + ldmatrix_offset

    // Load Q k-chunk 0 (k=0..15)
    // Global: Q row base + half * 16 bytes
    shl.b32         %r27, %r24, 4;            // half * 16 bytes
    cvt.u64.u32     %rd12, %r27;
    add.u64         %rd13, %rd11, %rd12;      // &Q[row][half*8]
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r30, %r31, %r32, %r33}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 1 (k=16..31)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 32;         // +32 bytes = +16 bf16 cols
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r34, %r35, %r36, %r37}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 2 (k=32..47)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 64;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r38, %r39, %r40, %r41}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 3 (k=48..63)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 96;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r42, %r43, %r44, %r45}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 4 (k=64..79)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 128;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r46, %r47, %r48, %r49}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 5 (k=80..95)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 160;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r50, %r51, %r52, %r53}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 6 (k=96..111)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 192;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r54, %r55, %r56, %r57}, [%r29];
    bar.sync 0;

    // Load Q k-chunk 7 (k=112..127)
    add.u64         %rd13, %rd11, %rd12;
    add.u64         %rd13, %rd13, 224;
    ld.global.v4.b32 {%r100, %r101, %r102, %r103}, [%rd13];
    st.shared.v4.b32 [%r28], {%r100, %r101, %r102, %r103};
    bar.sync 0;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r58, %r59, %r60, %r61}, [%r29];
    bar.sync 0;

    // Q is now in registers:
    //   k-chunk 0: %r30..%r33, k-chunk 1: %r34..%r37
    //   k-chunk 2: %r38..%r41, k-chunk 3: %r42..%r45
    //   k-chunk 4: %r46..%r49, k-chunk 5: %r50..%r53
    //   k-chunk 6: %r54..%r57, k-chunk 7: %r58..%r61

    // ================================================================
    // Initialize O accumulators and softmax state
    // ================================================================
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    // Softmax state
    mov.b32         %f192, 0xff800000;         // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;         // row_max[1] = -inf
    mov.f32         %f194, 0.0;                // row_sum[0] = 0
    mov.f32         %f195, 0.0;                // row_sum[1] = 0

    // ================================================================
    // Precompute K/V SMEM load helpers
    // ================================================================
    // K/V tile: 64 rows x 128 cols x 2B = 16384 bytes at SMEM_KV
    // 4 sub-passes of 16 rows each.
    // Sub-pass: 32 threads load 16 rows. Thread t: row = lane/2, half = lane%2
    // Each loads half a row = 64 bf16 = 128 bytes = 8 x v4.b32 (16B each)
    // smem_addr = SMEM_KV + row * 256 + half * 128
    shr.b32         %r62, %r0, 1;             // lane / 2 = row within sub-pass [0..15]
    and.b32         %r63, %r0, 1;             // lane % 2 = half [0 or 1]
    mul.lo.u32      %r64, %r62, KV_ROW_STRIDE;  // row * 256
    shl.b32         %r65, %r63, 7;            // half * 128
    add.u32         %r66, %r64, %r65;         // row_smem_off = row*256 + half*128
    add.u32         %r67, %r21, %r66;         // smem + row_smem_off (sub-pass 0 base)

    // ================================================================
    // Precompute ldmatrix addresses for K
    // ================================================================
    and.b32         %r68, %r0, 7;             // sub_lane = lane % 8
    mul.lo.u32      %r69, %r68, KV_ROW_STRIDE; // sub_lane * 256
    shr.b32         %r94, %r0, 3;
    and.b32         %r94, %r94, 1;            // half = (lane/8) % 2
    shl.b32         %r94, %r94, 4;            // half * 16 bytes
    add.u32         %r69, %r69, %r94;         // sub_lane*256 + half*16

    // Precompute V ldmatrix base
    and.b32         %r95, %r0, 15;            // lane % 16
    mul.lo.u32      %r96, %r95, KV_ROW_STRIDE; // (lane%16) * 256

    // ================================================================
    // Precompute P SMEM store/load addresses
    // ================================================================
    mul.lo.u32      %r70, %r4, P_ROW_STRIDE;  // groupID * 128 (row0 byte offset)
    add.u32         %r71, %r70, 1024;          // (groupID+8) * 128 = row1 byte offset
    shl.b32         %r72, %r5, 2;              // tidInGroup * 2 * 2 = col byte offset

    add.u32         %r73, %r21, SMEM_P;        // smem + SMEM_P
    add.u32         %r74, %r73, %r70;
    add.u32         %r74, %r74, %r72;          // P store base for row0
    add.u32         %r75, %r73, %r71;
    add.u32         %r75, %r75, %r72;          // P store base for row1

    // P ldmatrix addresses
    @%p0 mul.lo.u32 %r76, %r0, P_ROW_STRIDE;
    @!%p0 sub.u32   %r76, %r0, 16;
    @!%p0 mul.lo.u32 %r76, %r76, P_ROW_STRIDE;
    @!%p0 add.u32   %r76, %r76, 16;
    add.u32         %r77, %r73, %r76;          // P ldmatrix base

    // ================================================================
    // Precompute K/V global address helpers for varlen layout
    // ================================================================
    // For varlen [total, H, D], K/V row address for global kv token t:
    //   addr = K_base + t * token_stride_bytes
    //   token_stride_bytes = num_heads * 256 = %r134
    // Within each sub-pass, thread loads:
    //   global_kv_row = kv_block*64 + subpass*16 + lane/2
    //   addr = K_base + global_kv_row * token_stride + half * 128
    //
    // We precompute: thread's row-within-subpass * token_stride
    mul.lo.u32      %r140, %r62, %r134;       // (lane/2) * token_stride_bytes
    // half * 128 bytes for the second half of each row
    shl.b32         %r141, %r63, 7;           // half * 128 bytes
    // Combined per-thread offset within a sub-pass (row + half offset)
    add.u32         %r142, %r140, %r141;      // row_offset + half_offset in bytes
    cvt.u64.u32     %rd38, %r142;

    // Precompute sub-pass stride = 16 * token_stride_bytes
    shl.b32         %r143, %r134, 4;          // 16 * token_stride_bytes
    cvt.u64.u32     %rd39, %r143;

    // Precompute kv_block stride = 64 * token_stride_bytes
    shl.b32         %r144, %r134, 6;          // 64 * token_stride_bytes
    cvt.u64.u32     %rd40, %r144;

    // ================================================================
    // KV BLOCK LOOP
    // ================================================================
    mov.u32         %r80, 0;                   // kv_block = 0
    // num_kv_blocks = ceil(seq_kv / BC) = (seq_kv + 63) / 64
    add.u32         %r81, %r7, 63;
    shr.b32         %r81, %r81, 6;             // num_kv_blocks

kv_loop:
    setp.ge.u32     %p1, %r80, %r81;
    @%p1 bra        kv_done;

    // ================================================================
    // Load K tile [BC=64, D=128] to SMEM
    // ================================================================
    // kv_block_byte_offset = kv_block * 64 * token_stride_bytes
    mul.wide.u32    %rd41, %r80, 1;           // just to get u64 of kv_block
    // Actually compute: kv_block * kv_block_stride
    cvt.u64.u32     %rd41, %r80;
    mul.lo.u64      %rd41, %rd41, %rd40;      // kv_block * (64 * token_stride_bytes)

    // K tile global base for this kv_block:
    // K_base + kv_block * 64 * token_stride + per_thread_offset
    add.u64         %rd42, %rd8, %rd41;       // K_base + block offset

    // kv_row_base for bounds check = kv_block * 64
    shl.b32         %r82, %r80, 6;             // kv_block * 64

    // Sub-pass 0: rows 0..15
    add.u64         %rd15, %rd42, %rd38;       // + per_thread (row + half) offset
    add.u32         %r83, %r82, %r62;          // global_row = kv_base + lane/2
    setp.lt.u32     %p2, %r83, %r7;           // bounds check: global_row < seq_kv
    mov.u32         %r86, %r67;                // sub-pass 0 smem addr

    // Load via cp.async: 8 x 16B (register-bypass, global->SMEM direct)
    selp.b32        %r100, 16, 0, %p2;
    cp.async.cg.shared.global [%r86], [%rd15], 16, %r100;
    cp.async.cg.shared.global [%r86 + 16], [%rd15 + 16], 16, %r100;
    cp.async.cg.shared.global [%r86 + 32], [%rd15 + 32], 16, %r100;
    cp.async.cg.shared.global [%r86 + 48], [%rd15 + 48], 16, %r100;
    cp.async.cg.shared.global [%r86 + 64], [%rd15 + 64], 16, %r100;
    cp.async.cg.shared.global [%r86 + 80], [%rd15 + 80], 16, %r100;
    cp.async.cg.shared.global [%r86 + 96], [%rd15 + 96], 16, %r100;
    cp.async.cg.shared.global [%r86 + 112], [%rd15 + 112], 16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;

    // Sub-pass 1: rows 16..31
    add.u64         %rd15, %rd42, %rd38;
