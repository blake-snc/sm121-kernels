// fa_bf16_v3_d256_gqa.ptx
//
// Flash Attention (non-causal) for BF16 with d=256.
// Port of fa_bf16_v3_d128.ptx for GDN-hybrid's gated full-attention layers.
// FlashAttention-2 online softmax algorithm.
//
// 8 warps (256 threads), Br=128, Bc=64, d=256.
// Grid: (ceil(seq_q/128), num_heads, batch_size)
//
// Q,K,V: [batch, num_heads, seq, 256] row-major bf16
// O:     [batch, num_heads, seq, 256] row-major bf16
//
// MMA: mma.sync.aligned.m16n8k16.row.col.f32.bf16.bf16.f32
//
// SMEM layout (65536 bytes = 64 KB, fits in 99 KB SM121a limit):
//   [0,     32768)    K/P tile (BC*D*2 = 64*256*2 = 32768 bytes), reused for P matrix
//   [32768, 65536) V tile (BC*D*2 = 32768 bytes)
//
// During Q loading, Q occupies the K+V slot (Q held in regs after, slot reused).
// Q tile size: 128*256*2 = 65536 bytes = peak SMEM.
//
// Each warp independently computes 16 rows of output.
// Warp w computes rows [q_block*128 + w*16 .. q_block*128 + w*16 + 15].
//
// Register budget per thread:
//   Q fragments:    16 k-chunks × 4 = 64 (.b32)
//   S accumulators: 8 n-groups × 4 = 32 (.f32) [reused per KV block]
//   O accumulators: 32 n-groups × 4 = 128 (.f32)
//   Softmax state:  4 (.f32)
//   Temps + addrs:  ~30
//   Total:          ~258 (TIGHT, may force minor spills, acceptable)

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

// Tile dimensions
#define BR 128
#define BC 64
#define D  256

// SMEM layout (must fit in 99KB = 101376 bytes for SM121a)
#define SMEM_KP   0
#define SMEM_V    32768

// Row strides (bytes per row in SMEM)
#define KV_ROW_STRIDE 512
#define P_ROW_STRIDE  128


.visible .entry flash_attn_bf16_v3_d256_gqa(
    .param .u64 param_Q,        // [B, H_q, Sq, 256] bf16
    .param .u64 param_K,        // [B, H_kv, Skv, 256] bf16
    .param .u64 param_V,        // [B, H_kv, Skv, 256] bf16
    .param .u64 param_O,        // [B, H_q, Sq, 256] bf16 (output)
    .param .u32 param_seq_q,    // sequence length Q
    .param .u32 param_seq_kv,   // sequence length KV
    .param .u32 param_num_heads,// Q head count
    .param .u32 param_num_heads_kv, // K/V head count (GQA)
    .param .f32 param_scale     // 1/sqrt(d)
)
{
    .reg .b32  %r<256>;
    .reg .b64  %rd<48>;
    .reg .f32  %f<256>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    // SMEM: K/P (32KB) + V (32KB) = 64KB, Q overlays during load
    .shared .align 128 .b8 smem[65536];

    // Thread/block IDs
    mov.u32         %r0, %tid.x;               // tid [0..255]
    mov.u32         %r1, %ctaid.x;             // q_block_idx
    mov.u32         %r2, %ctaid.y;             // head_idx
    mov.u32         %r3, %ctaid.z;             // batch_idx

    and.b32         %r10, %r0, 31;             // lane = tid % 32
    shr.b32         %r9, %r0, 5;               // warp_id = tid / 32

    shr.b32         %r4, %r10, 2;              // groupID = lane / 4
    and.b32         %r5, %r10, 3;              // tidInGroup = lane % 4

    // Load params
    ld.param.u64    %rd0, [param_Q];
    ld.param.u64    %rd1, [param_K];
    ld.param.u64    %rd2, [param_V];
    ld.param.u64    %rd3, [param_O];
    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f196, [param_scale];

    // Compute base pointers for this (batch, head, q_block)
    // Q base: param_Q + (batch * num_heads * seq_q * D + head * seq_q * D + q_block * BR * D) * 2
    mul.lo.u32      %r11, %r6, D;              // seq_q * D
    mul.lo.u32      %r12, %r8, %r11;           // num_heads * seq_q * D (batch stride)
    mul.lo.u32      %r13, %r3, %r12;           // batch * batch_stride
    mul.lo.u32      %r14, %r2, %r11;           // head * head_stride
    add.u32         %r13, %r13, %r14;          // batch_off + head_off (Q/O)

    mul.lo.u32      %r15, %r1, BR;             // q_block * BR (in elements when * D)
    mul.lo.u32      %r16, %r15, D;             // q_block * BR * D
    add.u32         %r17, %r13, %r16;          // total Q element offset

    mul.wide.u32    %rd4, %r17, 2;             // byte offset
    add.u64         %rd5, %rd0, %rd4;          // Q base ptr for this block

    // O base: batch+head offset only
    mul.wide.u32    %rd40, %r13, 2;
    add.u64         %rd6, %rd3, %rd40;

    // K/V base: param_K + (batch * H_kv * seq_kv * D + head_kv * seq_kv * D) * 2
    // GQA: head_kv = (head_q * H_kv) / H_q. Non-GQA: head_kv = head_q.
    mul.lo.u32      %r18, %r7, D;              // seq_kv * D
    ld.param.u32    %r230, [param_num_heads_kv];
    mul.lo.u32      %r229, %r2, %r230;         // head_q * H_kv
    div.u32         %r229, %r229, %r8;         // / H_q = head_kv
    mul.lo.u32      %r19, %r230, %r18;          // H_kv * seq_kv * D
    mul.lo.u32      %r20, %r3, %r19;           // batch * batch_stride
    mul.lo.u32      %r23, %r229, %r18;          // head_kv * seq_kv * D
    add.u32         %r20, %r20, %r23;
    mul.wide.u32    %rd7, %r20, 2;
    add.u64         %rd8, %rd1, %rd7;          // K base
    add.u64         %rd9, %rd2, %rd7;          // V base

    mov.u32         %r21, smem;


    // Cooperative Q load: 256 threads load Q[128,256] to SMEM
    // Q tile: 128 rows x 256 cols x 2B = 65536 bytes
    // 256 threads: each thread loads half a row (256 bytes = 16 x v4.b32 cp.async)
    //   row = tid / 2 [0..127]
    //   half = tid % 2 (each half = 128 cols = 256 bytes)

    shr.b32         %r24, %r0, 1;              // q_load_row = tid / 2
    and.b32         %r25, %r0, 1;              // q_load_half = tid % 2

    // Global addr: row * D * 2 = row * 512
    mul.lo.u32      %r26, %r24, 512;         // row * 512 bytes
    cvt.u64.u32     %rd10, %r26;
    add.u64         %rd11, %rd5, %rd10;
    mul.lo.u32      %r27, %r25, 256;           // half * 128 elements = 256 bytes
    cvt.u64.u32     %rd12, %r27;
    add.u64         %rd13, %rd11, %rd12;

    // SMEM store addr
    add.u32         %r28, %r26, %r27;
    add.u32         %r29, %r21, %r28;

    // Bounds check
    add.u32         %r30, %r15, %r24;          // q_block*BR + row
    setp.lt.u32     %p1, %r30, %r6;

    // Load 256 bytes via cp.async: 16 × 16B
    selp.b32        %r100, 16, 0, %p1;
    cp.async.cg.shared.global [%r29 + 0], [%rd13 + 0], 16, %r100;
    cp.async.cg.shared.global [%r29 + 16], [%rd13 + 16], 16, %r100;
    cp.async.cg.shared.global [%r29 + 32], [%rd13 + 32], 16, %r100;
    cp.async.cg.shared.global [%r29 + 48], [%rd13 + 48], 16, %r100;
    cp.async.cg.shared.global [%r29 + 64], [%rd13 + 64], 16, %r100;
    cp.async.cg.shared.global [%r29 + 80], [%rd13 + 80], 16, %r100;
    cp.async.cg.shared.global [%r29 + 96], [%rd13 + 96], 16, %r100;
    cp.async.cg.shared.global [%r29 + 112], [%rd13 + 112], 16, %r100;
    cp.async.cg.shared.global [%r29 + 128], [%rd13 + 128], 16, %r100;
    cp.async.cg.shared.global [%r29 + 144], [%rd13 + 144], 16, %r100;
    cp.async.cg.shared.global [%r29 + 160], [%rd13 + 160], 16, %r100;
    cp.async.cg.shared.global [%r29 + 176], [%rd13 + 176], 16, %r100;
    cp.async.cg.shared.global [%r29 + 192], [%rd13 + 192], 16, %r100;
    cp.async.cg.shared.global [%r29 + 208], [%rd13 + 208], 16, %r100;
    cp.async.cg.shared.global [%r29 + 224], [%rd13 + 224], 16, %r100;
    cp.async.cg.shared.global [%r29 + 240], [%rd13 + 240], 16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;
    bar.sync 0;

    // Per-warp ldmatrix: 16 k-chunks × ldmatrix.x4 → 64 Q fragment regs
    // Each warp's Q tile: 16 rows × 256 cols, row stride 512 bytes
    // Warp w base: smem + w * 16 * 512 = smem + w * 8192

    setp.lt.u32     %p0, %r10, 16;
    mul.lo.u32      %r204, %r9, 8192;  // warp_id * 8192
    @%p0 mul.lo.u32 %r205, %r10, 512;    // lane < 16: lane * row_stride
    @!%p0 sub.u32   %r205, %r10, 16;
    @!%p0 mul.lo.u32 %r205, %r205, 512;  // (lane-16) * row_stride
    @!%p0 add.u32   %r205, %r205, 16;      // + 16 bytes for second half
    add.u32         %r205, %r205, %r204;
    add.u32         %r206, %r21, %r205;    // Q ldmatrix base for this lane

    // kc=0
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r140, %r141, %r142, %r143}, [%r206];
    // kc=1: offset +32
    add.u32         %r207, %r206, 32;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r144, %r145, %r146, %r147}, [%r207];
    // kc=2: offset +64
    add.u32         %r207, %r206, 64;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r148, %r149, %r150, %r151}, [%r207];
    // kc=3: offset +96
    add.u32         %r207, %r206, 96;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r152, %r153, %r154, %r155}, [%r207];
    // kc=4: offset +128
    add.u32         %r207, %r206, 128;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r156, %r157, %r158, %r159}, [%r207];
    // kc=5: offset +160
    add.u32         %r207, %r206, 160;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r160, %r161, %r162, %r163}, [%r207];
    // kc=6: offset +192
    add.u32         %r207, %r206, 192;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r164, %r165, %r166, %r167}, [%r207];
    // kc=7: offset +224
    add.u32         %r207, %r206, 224;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r168, %r169, %r170, %r171}, [%r207];
    // kc=8: offset +256
    add.u32         %r207, %r206, 256;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r172, %r173, %r174, %r175}, [%r207];
    // kc=9: offset +288
    add.u32         %r207, %r206, 288;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r176, %r177, %r178, %r179}, [%r207];
    // kc=10: offset +320
    add.u32         %r207, %r206, 320;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r180, %r181, %r182, %r183}, [%r207];
    // kc=11: offset +352
    add.u32         %r207, %r206, 352;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r184, %r185, %r186, %r187}, [%r207];
    // kc=12: offset +384
    add.u32         %r207, %r206, 384;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r188, %r189, %r190, %r191}, [%r207];
    // kc=13: offset +416
    add.u32         %r207, %r206, 416;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r192, %r193, %r194, %r195}, [%r207];
    // kc=14: offset +448
    add.u32         %r207, %r206, 448;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r196, %r197, %r198, %r199}, [%r207];
    // kc=15: offset +480
    add.u32         %r207, %r206, 480;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r200, %r201, %r202, %r203}, [%r207];

    bar.sync 0;  // Q now in regs, SMEM available for K/V/P
    // Initialize O accumulators (32 ng × 4 = 128 regs) to 0
    mov.f32 %f0, 0.0;  mov.f32 %f1, 0.0;  mov.f32 %f2, 0.0;  mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;  mov.f32 %f5, 0.0;  mov.f32 %f6, 0.0;  mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;  mov.f32 %f9, 0.0;  mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;
    mov.f32 %f64, 0.0;  mov.f32 %f65, 0.0;  mov.f32 %f66, 0.0;  mov.f32 %f67, 0.0;
    mov.f32 %f68, 0.0;  mov.f32 %f69, 0.0;  mov.f32 %f70, 0.0;  mov.f32 %f71, 0.0;
    mov.f32 %f72, 0.0;  mov.f32 %f73, 0.0;  mov.f32 %f74, 0.0;  mov.f32 %f75, 0.0;
    mov.f32 %f76, 0.0;  mov.f32 %f77, 0.0;  mov.f32 %f78, 0.0;  mov.f32 %f79, 0.0;
    mov.f32 %f80, 0.0;  mov.f32 %f81, 0.0;  mov.f32 %f82, 0.0;  mov.f32 %f83, 0.0;
    mov.f32 %f84, 0.0;  mov.f32 %f85, 0.0;  mov.f32 %f86, 0.0;  mov.f32 %f87, 0.0;
    mov.f32 %f88, 0.0;  mov.f32 %f89, 0.0;  mov.f32 %f90, 0.0;  mov.f32 %f91, 0.0;
    mov.f32 %f92, 0.0;  mov.f32 %f93, 0.0;  mov.f32 %f94, 0.0;  mov.f32 %f95, 0.0;
    mov.f32 %f96, 0.0;  mov.f32 %f97, 0.0;  mov.f32 %f98, 0.0;  mov.f32 %f99, 0.0;
    mov.f32 %f100, 0.0;  mov.f32 %f101, 0.0;  mov.f32 %f102, 0.0;  mov.f32 %f103, 0.0;
    mov.f32 %f104, 0.0;  mov.f32 %f105, 0.0;  mov.f32 %f106, 0.0;  mov.f32 %f107, 0.0;
    mov.f32 %f108, 0.0;  mov.f32 %f109, 0.0;  mov.f32 %f110, 0.0;  mov.f32 %f111, 0.0;
    mov.f32 %f112, 0.0;  mov.f32 %f113, 0.0;  mov.f32 %f114, 0.0;  mov.f32 %f115, 0.0;
    mov.f32 %f116, 0.0;  mov.f32 %f117, 0.0;  mov.f32 %f118, 0.0;  mov.f32 %f119, 0.0;
    mov.f32 %f120, 0.0;  mov.f32 %f121, 0.0;  mov.f32 %f122, 0.0;  mov.f32 %f123, 0.0;
    mov.f32 %f124, 0.0;  mov.f32 %f125, 0.0;  mov.f32 %f126, 0.0;  mov.f32 %f127, 0.0;

    // Softmax state
    mov.b32         %f192, 0xff800000;     // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;     // row_max[1] = -inf
    mov.f32         %f194, 0.0;            // row_sum[0] = 0
    mov.f32         %f195, 0.0;            // row_sum[1] = 0

    // ================================================================
    // Precompute K/V/P SMEM address helpers
    // ================================================================

    // K ldmatrix addresses (B-operand for QK^T, at SMEM offset 0)
    // ldmatrix.x2: addr = smem + (sub_lane*KV_ROW_STRIDE) + (half*16)
    //   sub_lane = lane % 8, half = (lane/8) % 2
    and.b32         %r68, %r10, 7;             // sub_lane = lane % 8
    mul.lo.u32      %r69, %r68, KV_ROW_STRIDE;
    shr.b32         %r94, %r10, 3;
    and.b32         %r94, %r94, 1;             // half = (lane/8) % 2
    shl.b32         %r94, %r94, 4;             // half * 16
    add.u32         %r69, %r69, %r94;

    // V ldmatrix addresses (B-operand for PV, at SMEM offset SMEM_V)
    // ldmatrix.x2.trans: addr = SMEM_V + (lane%16)*KV_ROW_STRIDE
    and.b32         %r95, %r10, 15;            // lane % 16
    mul.lo.u32      %r96, %r95, KV_ROW_STRIDE;

    // P store addresses (warp-specific offset in K/P buffer)
    // P layout per warp: 16 rows × 64 cols × 2B = 2048 bytes, row stride P_ROW_STRIDE=128
    mul.lo.u32      %r70, %r9, 2048;           // warp_id * 2048
    add.u32         %r71, %r21, %r70;          // P_smem_base

    mul.lo.u32      %r72, %r4, P_ROW_STRIDE;   // groupID * 128
    add.u32         %r73, %r72, 1024;          // (groupID+8) * 128
    shl.b32         %r74, %r5, 2;              // tidInGroup * 4 bytes (2 BF16)

    add.u32         %r75, %r71, %r72;
    add.u32         %r75, %r75, %r74;          // P store row0
    add.u32         %r76, %r71, %r73;
    add.u32         %r76, %r76, %r74;          // P store row1

    // P ldmatrix addresses (A-operand for P*V MMA):
    @%p0 mul.lo.u32 %r77, %r10, P_ROW_STRIDE;
    @!%p0 sub.u32   %r77, %r10, 16;
    @!%p0 mul.lo.u32 %r77, %r77, P_ROW_STRIDE;
    @!%p0 add.u32   %r77, %r77, 16;
    add.u32         %r78, %r71, %r77;

    // K/V cooperative load helpers
    // 256 threads load K/V [64, 256] = 32768 bytes
    //   kv_load_row = tid / 4 [0..63]
    //   kv_load_col_eighth = tid % 4 [0..3], each load chunk = 64 bytes? No: split into 4 quarters of 128 bytes each
    //   Actually: each thread loads 128 = 128 bytes = 4 × 16B per thread
    //   row * KV_ROW_STRIDE + quarter * 128
    shr.b32         %r110, %r0, 2;             // kv_load_row = tid / 4 [0..63]
    and.b32         %r111, %r0, 3;             // quarter = tid % 4
    mul.lo.u32      %r112, %r110, KV_ROW_STRIDE;
    mul.lo.u32      %r113, %r111, 128;      // quarter * 128 bytes
    add.u32         %r114, %r112, %r113;       // smem offset within tile


    // ================================================================
    // KV BLOCK LOOP
    // ================================================================
    mov.u32         %r80, 0;                   // kv_block = 0
    add.u32         %r81, %r7, 63;
    shr.b32         %r81, %r81, 6;           // num_kv_blocks = ceil(seq_kv/64)

kv_loop:
    setp.ge.u32     %p2, %r80, %r81;
    @%p2 bra        kv_done;

    // Cooperative K load: 256 threads → K[64,256] to SMEM[0..32767]
    mul.lo.u32      %r82, %r80, 64;          // kv_block * BC

    add.u32         %r83, %r82, %r110;         // global_row = kv_block*BC + kv_load_row
    mul.lo.u32      %r84, %r83, D;             // global_row * D
    add.u32         %r84, %r84, %r20;          // + batch/head offset
    mul.lo.u32      %r85, %r111, 64;       // quarter * 64 elements (128 bytes)
    add.u32         %r84, %r84, %r85;
    mul.wide.u32    %rd14, %r84, 2;
    add.u64         %rd15, %rd1, %rd14;        // K global addr

    setp.lt.u32     %p3, %r83, %r7;            // bounds check
    add.u32         %r86, %r21, %r114;         // SMEM addr (within K buffer)

    selp.b32        %r100, 16, 0, %p3;
    cp.async.cg.shared.global [%r86 + 0], [%rd15 + 0], 16, %r100;
    cp.async.cg.shared.global [%r86 + 16], [%rd15 + 16], 16, %r100;
    cp.async.cg.shared.global [%r86 + 32], [%rd15 + 32], 16, %r100;
