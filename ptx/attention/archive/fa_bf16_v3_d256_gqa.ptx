    cvt.rn.bf16.f32 %h0, %f138;  cvt.rn.bf16.f32 %h1, %f139;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 32], %r100;

    // ng3
    sub.f32 %f140, %f140, %f190;  mul.f32 %f140, %f140, LOG2E;  ex2.approx.f32 %f140, %f140;
    sub.f32 %f141, %f141, %f190;  mul.f32 %f141, %f141, LOG2E;  ex2.approx.f32 %f141, %f141;
    sub.f32 %f142, %f142, %f191;  mul.f32 %f142, %f142, LOG2E;  ex2.approx.f32 %f142, %f142;
    sub.f32 %f143, %f143, %f191;  mul.f32 %f143, %f143, LOG2E;  ex2.approx.f32 %f143, %f143;
    add.f32 %f194, %f194, %f140;  add.f32 %f194, %f194, %f141;
    add.f32 %f195, %f195, %f142;  add.f32 %f195, %f195, %f143;
    cvt.rn.bf16.f32 %h0, %f140;  cvt.rn.bf16.f32 %h1, %f141;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 48], %r100;
    cvt.rn.bf16.f32 %h0, %f142;  cvt.rn.bf16.f32 %h1, %f143;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 48], %r100;

    // ng4
    sub.f32 %f144, %f144, %f190;  mul.f32 %f144, %f144, LOG2E;  ex2.approx.f32 %f144, %f144;
    sub.f32 %f145, %f145, %f190;  mul.f32 %f145, %f145, LOG2E;  ex2.approx.f32 %f145, %f145;
    sub.f32 %f146, %f146, %f191;  mul.f32 %f146, %f146, LOG2E;  ex2.approx.f32 %f146, %f146;
    sub.f32 %f147, %f147, %f191;  mul.f32 %f147, %f147, LOG2E;  ex2.approx.f32 %f147, %f147;
    add.f32 %f194, %f194, %f144;  add.f32 %f194, %f194, %f145;
    add.f32 %f195, %f195, %f146;  add.f32 %f195, %f195, %f147;
