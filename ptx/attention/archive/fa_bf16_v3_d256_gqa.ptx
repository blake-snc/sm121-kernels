    st.shared.b32 [%r75 + 80], %r100;
    cvt.rn.bf16.f32 %h0, %f150;  cvt.rn.bf16.f32 %h1, %f151;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 80], %r100;

    // ng6
    sub.f32 %f152, %f152, %f190;  mul.f32 %f152, %f152, LOG2E;  ex2.approx.f32 %f152, %f152;
    sub.f32 %f153, %f153, %f190;  mul.f32 %f153, %f153, LOG2E;  ex2.approx.f32 %f153, %f153;
    sub.f32 %f154, %f154, %f191;  mul.f32 %f154, %f154, LOG2E;  ex2.approx.f32 %f154, %f154;
    sub.f32 %f155, %f155, %f191;  mul.f32 %f155, %f155, LOG2E;  ex2.approx.f32 %f155, %f155;
    add.f32 %f194, %f194, %f152;  add.f32 %f194, %f194, %f153;
    add.f32 %f195, %f195, %f154;  add.f32 %f195, %f195, %f155;
    cvt.rn.bf16.f32 %h0, %f152;  cvt.rn.bf16.f32 %h1, %f153;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 96], %r100;
    cvt.rn.bf16.f32 %h0, %f154;  cvt.rn.bf16.f32 %h1, %f155;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 96], %r100;

    // ng7
    sub.f32 %f156, %f156, %f190;  mul.f32 %f156, %f156, LOG2E;  ex2.approx.f32 %f156, %f156;
    sub.f32 %f157, %f157, %f190;  mul.f32 %f157, %f157, LOG2E;  ex2.approx.f32 %f157, %f157;
    sub.f32 %f158, %f158, %f191;  mul.f32 %f158, %f158, LOG2E;  ex2.approx.f32 %f158, %f158;
    sub.f32 %f159, %f159, %f191;  mul.f32 %f159, %f159, LOG2E;  ex2.approx.f32 %f159, %f159;
    add.f32 %f194, %f194, %f156;  add.f32 %f194, %f194, %f157;
    add.f32 %f195, %f195, %f158;  add.f32 %f195, %f195, %f159;
    cvt.rn.bf16.f32 %h0, %f156;  cvt.rn.bf16.f32 %h1, %f157;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 112], %r100;
    cvt.rn.bf16.f32 %h0, %f158;  cvt.rn.bf16.f32 %h1, %f159;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 112], %r100;

    bar.sync 0;  // Sync before V load overwrites K/P slot? No — P is in K slot.
    // Actually V is at SMEM_V, K/P at 0. They DON'T overlap. But all warps must finish
    // writing P to SMEM before any warp reads from V (which we'll do after V load).
    // We need bar.sync before V load? Actually no — V load is to SMEM_V (separate).
    // The bar.sync is ONLY needed before reading P (in PV GEMM). Already there before PV.

    // ================================================================
    // Cooperative V load: 256 threads → V[64,256] to SMEM[SMEM_V..]
    // ================================================================
    add.u32         %r83, %r82, %r110;
    mul.lo.u32      %r84, %r83, D;
    add.u32         %r84, %r84, %r20;
    mul.lo.u32      %r85, %r111, 64;
    add.u32         %r84, %r84, %r85;
    mul.wide.u32    %rd14, %r84, 2;
    add.u64         %rd15, %rd2, %rd14;        // V global addr

    setp.lt.u32     %p3, %r83, %r7;
    add.u32         %r86, %r21, %r114;
    add.u32         %r86, %r86, SMEM_V;

    selp.b32        %r100, 16, 0, %p3;
    cp.async.cg.shared.global [%r86 + 0], [%rd15 + 0], 16, %r100;
    cp.async.cg.shared.global [%r86 + 16], [%rd15 + 16], 16, %r100;
    cp.async.cg.shared.global [%r86 + 32], [%rd15 + 32], 16, %r100;
    cp.async.cg.shared.global [%r86 + 48], [%rd15 + 48], 16, %r100;
    cp.async.cg.shared.global [%r86 + 64], [%rd15 + 64], 16, %r100;
    cp.async.cg.shared.global [%r86 + 80], [%rd15 + 80], 16, %r100;
    cp.async.cg.shared.global [%r86 + 96], [%rd15 + 96], 16, %r100;
    cp.async.cg.shared.global [%r86 + 112], [%rd15 + 112], 16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;
    bar.sync 0;

    // ================================================================
    // Compute O += P × V  (16×64) × (64×256) = 16×256
    // 4 kp-chunks × 32 n-groups = 128 MMAs per warp
    // ================================================================
    add.u32         %r216, %r21, %r96;
    add.u32         %r216, %r216, SMEM_V;

    // kp=0: P ldmatrix from %r78
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r106, %r107, %r108, %r109}, [%r78];
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r216];
    MMA_BF16_M16N8K16(%f0, %f1, %f2, %f3, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r219, %r216, 16;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r219];
    MMA_BF16_M16N8K16(%f4, %f5, %f6, %f7, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r219, %r216, 32;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r219];
    MMA_BF16_M16N8K16(%f8, %f9, %f10, %f11, %r106, %r107, %r108, %r109, %r104, %r105)
    add.u32 %r219, %r216, 48;
    ldmatrix.sync.aligned.m8n8.x2.trans.shared.b16 {%r104, %r105}, [%r219];
    MMA_BF16_M16N8K16(%f12, %f13, %f14, %f15, %r106, %r107, %r108, %r109, %r104, %r105)
