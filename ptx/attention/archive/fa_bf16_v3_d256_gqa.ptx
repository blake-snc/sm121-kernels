    mul.f32 %f2, %f2, %f198;  mul.f32 %f3, %f3, %f198;
    mul.f32 %f4, %f4, %f197;  mul.f32 %f5, %f5, %f197;
    mul.f32 %f6, %f6, %f198;  mul.f32 %f7, %f7, %f198;
    mul.f32 %f8, %f8, %f197;  mul.f32 %f9, %f9, %f197;
    mul.f32 %f10, %f10, %f198;  mul.f32 %f11, %f11, %f198;
    mul.f32 %f12, %f12, %f197;  mul.f32 %f13, %f13, %f197;
    mul.f32 %f14, %f14, %f198;  mul.f32 %f15, %f15, %f198;
    mul.f32 %f16, %f16, %f197;  mul.f32 %f17, %f17, %f197;
    mul.f32 %f18, %f18, %f198;  mul.f32 %f19, %f19, %f198;
    mul.f32 %f20, %f20, %f197;  mul.f32 %f21, %f21, %f197;
    mul.f32 %f22, %f22, %f198;  mul.f32 %f23, %f23, %f198;
    mul.f32 %f24, %f24, %f197;  mul.f32 %f25, %f25, %f197;
    mul.f32 %f26, %f26, %f198;  mul.f32 %f27, %f27, %f198;
    mul.f32 %f28, %f28, %f197;  mul.f32 %f29, %f29, %f197;
    mul.f32 %f30, %f30, %f198;  mul.f32 %f31, %f31, %f198;
    mul.f32 %f32, %f32, %f197;  mul.f32 %f33, %f33, %f197;
