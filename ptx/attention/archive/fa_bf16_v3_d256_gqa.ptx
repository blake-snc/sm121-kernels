    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 64], %r100;

    // ng5
    sub.f32 %f148, %f148, %f190;  mul.f32 %f148, %f148, LOG2E;  ex2.approx.f32 %f148, %f148;
    sub.f32 %f149, %f149, %f190;  mul.f32 %f149, %f149, LOG2E;  ex2.approx.f32 %f149, %f149;
    sub.f32 %f150, %f150, %f191;  mul.f32 %f150, %f150, LOG2E;  ex2.approx.f32 %f150, %f150;
    sub.f32 %f151, %f151, %f191;  mul.f32 %f151, %f151, LOG2E;  ex2.approx.f32 %f151, %f151;
    add.f32 %f194, %f194, %f148;  add.f32 %f194, %f194, %f149;
    add.f32 %f195, %f195, %f150;  add.f32 %f195, %f195, %f151;
    cvt.rn.bf16.f32 %h0, %f148;  cvt.rn.bf16.f32 %h1, %f149;
