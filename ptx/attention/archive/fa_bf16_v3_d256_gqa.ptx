    max.f32         %f200, %f200, %f152;
    max.f32         %f200, %f200, %f153;
    max.f32         %f200, %f200, %f156;
    max.f32         %f200, %f200, %f157;
    mov.f32         %f201, %f130;
    max.f32         %f201, %f201, %f131;
    max.f32         %f201, %f201, %f134;
    max.f32         %f201, %f201, %f135;
    max.f32         %f201, %f201, %f138;
    max.f32         %f201, %f201, %f139;
    max.f32         %f201, %f201, %f142;
    max.f32         %f201, %f201, %f143;
    max.f32         %f201, %f201, %f146;
    max.f32         %f201, %f201, %f147;
    max.f32         %f201, %f201, %f150;
    max.f32         %f201, %f201, %f151;
    max.f32         %f201, %f201, %f154;
    max.f32         %f201, %f201, %f155;
    max.f32         %f201, %f201, %f158;
    max.f32         %f201, %f201, %f159;

    // Reduce across 4 threads per row (GROUP4)
    GROUP4_REDUCE_MAX_F32(%f200, %f202)
