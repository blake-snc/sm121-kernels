    mul.f32 %f76, %f76, %f197;  mul.f32 %f77, %f77, %f197;
    mul.f32 %f78, %f78, %f198;  mul.f32 %f79, %f79, %f198;
    mul.f32 %f80, %f80, %f197;  mul.f32 %f81, %f81, %f197;
    mul.f32 %f82, %f82, %f198;  mul.f32 %f83, %f83, %f198;
    mul.f32 %f84, %f84, %f197;  mul.f32 %f85, %f85, %f197;
    mul.f32 %f86, %f86, %f198;  mul.f32 %f87, %f87, %f198;
    mul.f32 %f88, %f88, %f197;  mul.f32 %f89, %f89, %f197;
    mul.f32 %f90, %f90, %f198;  mul.f32 %f91, %f91, %f198;
    mul.f32 %f92, %f92, %f197;  mul.f32 %f93, %f93, %f197;
    mul.f32 %f94, %f94, %f198;  mul.f32 %f95, %f95, %f198;
    mul.f32 %f96, %f96, %f197;  mul.f32 %f97, %f97, %f197;
    mul.f32 %f98, %f98, %f198;  mul.f32 %f99, %f99, %f198;
    mul.f32 %f100, %f100, %f197;  mul.f32 %f101, %f101, %f197;
    mul.f32 %f102, %f102, %f198;  mul.f32 %f103, %f103, %f198;
    mul.f32 %f104, %f104, %f197;  mul.f32 %f105, %f105, %f197;
    mul.f32 %f106, %f106, %f198;  mul.f32 %f107, %f107, %f198;
    mul.f32 %f108, %f108, %f197;  mul.f32 %f109, %f109, %f197;
    mul.f32 %f110, %f110, %f198;  mul.f32 %f111, %f111, %f198;
    mul.f32 %f112, %f112, %f197;  mul.f32 %f113, %f113, %f197;
    mul.f32 %f114, %f114, %f198;  mul.f32 %f115, %f115, %f198;
    mul.f32 %f116, %f116, %f197;  mul.f32 %f117, %f117, %f197;
    mul.f32 %f118, %f118, %f198;  mul.f32 %f119, %f119, %f198;
    mul.f32 %f120, %f120, %f197;  mul.f32 %f121, %f121, %f197;
    mul.f32 %f122, %f122, %f198;  mul.f32 %f123, %f123, %f198;
    mul.f32 %f124, %f124, %f197;  mul.f32 %f125, %f125, %f197;
    mul.f32 %f126, %f126, %f198;  mul.f32 %f127, %f127, %f198;

    // Rescale row_sum
    mul.f32         %f194, %f194, %f197;
    mul.f32         %f195, %f195, %f198;

    // Update running max
    mov.f32         %f192, %f190;
    mov.f32         %f193, %f191;

    // Compute P and store to SMEM. P store: %r75 (row0), %r76 (row1)
    // ng0
    sub.f32 %f128, %f128, %f190;  mul.f32 %f128, %f128, LOG2E;  ex2.approx.f32 %f128, %f128;
    sub.f32 %f129, %f129, %f190;  mul.f32 %f129, %f129, LOG2E;  ex2.approx.f32 %f129, %f129;
    sub.f32 %f130, %f130, %f191;  mul.f32 %f130, %f130, LOG2E;  ex2.approx.f32 %f130, %f130;
    sub.f32 %f131, %f131, %f191;  mul.f32 %f131, %f131, LOG2E;  ex2.approx.f32 %f131, %f131;
    add.f32 %f194, %f194, %f128;  add.f32 %f194, %f194, %f129;
    add.f32 %f195, %f195, %f130;  add.f32 %f195, %f195, %f131;
    cvt.rn.bf16.f32 %h0, %f128;  cvt.rn.bf16.f32 %h1, %f129;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75], %r100;
    cvt.rn.bf16.f32 %h0, %f130;  cvt.rn.bf16.f32 %h1, %f131;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76], %r100;

    // ng1
    sub.f32 %f132, %f132, %f190;  mul.f32 %f132, %f132, LOG2E;  ex2.approx.f32 %f132, %f132;
    sub.f32 %f133, %f133, %f190;  mul.f32 %f133, %f133, LOG2E;  ex2.approx.f32 %f133, %f133;
    sub.f32 %f134, %f134, %f191;  mul.f32 %f134, %f134, LOG2E;  ex2.approx.f32 %f134, %f134;
    sub.f32 %f135, %f135, %f191;  mul.f32 %f135, %f135, LOG2E;  ex2.approx.f32 %f135, %f135;
    add.f32 %f194, %f194, %f132;  add.f32 %f194, %f194, %f133;
    add.f32 %f195, %f195, %f134;  add.f32 %f195, %f195, %f135;
    cvt.rn.bf16.f32 %h0, %f132;  cvt.rn.bf16.f32 %h1, %f133;
