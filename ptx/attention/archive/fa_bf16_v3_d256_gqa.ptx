    sub.f32 %f136, %f136, %f190;  mul.f32 %f136, %f136, LOG2E;  ex2.approx.f32 %f136, %f136;
    sub.f32 %f137, %f137, %f190;  mul.f32 %f137, %f137, LOG2E;  ex2.approx.f32 %f137, %f137;
    sub.f32 %f138, %f138, %f191;  mul.f32 %f138, %f138, LOG2E;  ex2.approx.f32 %f138, %f138;
    sub.f32 %f139, %f139, %f191;  mul.f32 %f139, %f139, LOG2E;  ex2.approx.f32 %f139, %f139;
    add.f32 %f194, %f194, %f136;  add.f32 %f194, %f194, %f137;
    add.f32 %f195, %f195, %f138;  add.f32 %f195, %f195, %f139;
