    mul.f32         %f197, %f197, LOG2E;
    ex2.approx.f32  %f197, %f197;
    sub.f32         %f198, %f193, %f191;
    mul.f32         %f198, %f198, LOG2E;
    ex2.approx.f32  %f198, %f198;

