mma_wait_v:
    mbarrier.try_wait.parity.shared.b64 %p8, [%r158], %r156;
    @!%p8 bra mma_wait_v;

    // ================================================================
    // PV GEMM: O += P @ V  (FP8 m16n8k32, 2 kp * 16 ng = 32 MMAs)
    // V_T SMEM base for this stage + this thread's offset
