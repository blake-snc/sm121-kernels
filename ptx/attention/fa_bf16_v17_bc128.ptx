    mul.f32 %f120, %f120, %f196; mul.f32 %f121, %f121, %f196;
    mul.f32 %f122, %f122, %f196; mul.f32 %f123, %f123, %f196;
    mul.f32 %f124, %f124, %f196; mul.f32 %f125, %f125, %f196;
    mul.f32 %f126, %f126, %f196; mul.f32 %f127, %f127, %f196;

    // ================================================================
    // Online softmax: find row max, rescale O, compute P = exp(S - max)
    // ================================================================
    // Softmax temps use %f128+ (S accumulators occupy %f64..%f127)
    // row0: max across all d0,d1 values (even regs from each ng)
    mov.f32         %f128, %f64;
    max.f32         %f128, %f128, %f65;
    max.f32         %f128, %f128, %f68;
    max.f32         %f128, %f128, %f69;
    max.f32         %f128, %f128, %f72;
    max.f32         %f128, %f128, %f73;
    max.f32         %f128, %f128, %f76;
    max.f32         %f128, %f128, %f77;
    max.f32         %f128, %f128, %f80;
    max.f32         %f128, %f128, %f81;
    max.f32         %f128, %f128, %f84;
    max.f32         %f128, %f128, %f85;
    max.f32         %f128, %f128, %f88;
    max.f32         %f128, %f128, %f89;
    max.f32         %f128, %f128, %f92;
    max.f32         %f128, %f128, %f93;
    max.f32         %f128, %f128, %f96;
    max.f32         %f128, %f128, %f97;
    max.f32         %f128, %f128, %f100;
    max.f32         %f128, %f128, %f101;
    max.f32         %f128, %f128, %f104;
    max.f32         %f128, %f128, %f105;
    max.f32         %f128, %f128, %f108;
    max.f32         %f128, %f128, %f109;
    max.f32         %f128, %f128, %f112;
    max.f32         %f128, %f128, %f113;
    max.f32         %f128, %f128, %f116;
    max.f32         %f128, %f128, %f117;
    max.f32         %f128, %f128, %f120;
    max.f32         %f128, %f128, %f121;
    max.f32         %f128, %f128, %f124;
    max.f32         %f128, %f128, %f125;

    // row1: max across all d2,d3 values
    mov.f32         %f129, %f66;
    max.f32         %f129, %f129, %f67;
    max.f32         %f129, %f129, %f70;
    max.f32         %f129, %f129, %f71;
    max.f32         %f129, %f129, %f74;
    max.f32         %f129, %f129, %f75;
    max.f32         %f129, %f129, %f78;
    max.f32         %f129, %f129, %f79;
    max.f32         %f129, %f129, %f82;
    max.f32         %f129, %f129, %f83;
    max.f32         %f129, %f129, %f86;
    max.f32         %f129, %f129, %f87;
    max.f32         %f129, %f129, %f90;
    max.f32         %f129, %f129, %f91;
    max.f32         %f129, %f129, %f94;
    max.f32         %f129, %f129, %f95;
    max.f32         %f129, %f129, %f98;
    max.f32         %f129, %f129, %f99;
    max.f32         %f129, %f129, %f102;
    max.f32         %f129, %f129, %f103;
    max.f32         %f129, %f129, %f106;
    max.f32         %f129, %f129, %f107;
    max.f32         %f129, %f129, %f110;
    max.f32         %f129, %f129, %f111;
    max.f32         %f129, %f129, %f114;
    max.f32         %f129, %f129, %f115;
    max.f32         %f129, %f129, %f118;
    max.f32         %f129, %f129, %f119;
    max.f32         %f129, %f129, %f122;
    max.f32         %f129, %f129, %f123;
    max.f32         %f129, %f129, %f126;
    max.f32         %f129, %f129, %f127;

    // Reduce across 4 threads per row (GROUP4)
    GROUP4_REDUCE_MAX_F32(%f128, %f130)
    GROUP4_REDUCE_MAX_F32(%f129, %f130)

    // Combine with running max
    max.f32         %f131, %f192, %f128;
    max.f32         %f132, %f193, %f129;

    // NaN guard: if new_max is -inf (all tokens masked in this + prior tiles),
    // clamp to 0.0. This prevents -inf - (-inf) = NaN in the exp computation
    // below. With max=0.0, exp(S - 0.0) = exp(-inf) = 0.0 for masked values,
    // and row_sum remains 0.0 (handled by rcp clamp in epilogue).
    mov.b32 %f130, 0xff800000; setp.eq.f32 %p10, %f131, %f130;
    @%p10 mov.f32   %f131, 0f00000000;
    mov.b32 %f130, 0xff800000; setp.eq.f32 %p10, %f132, %f130;
    @%p10 mov.f32   %f132, 0f00000000;

    // Correction factors: exp(old_max - new_max)
    sub.f32         %f133, %f192, %f131;
    mul.f32         %f133, %f133, LOG2E;
    ex2.approx.f32  %f133, %f133;
    sub.f32         %f134, %f193, %f132;
    mul.f32         %f134, %f134, LOG2E;
    ex2.approx.f32  %f134, %f134;

    // Rescale O accumulators by correction
    mul.f32 %f0, %f0, %f133;    mul.f32 %f1, %f1, %f133;
    mul.f32 %f2, %f2, %f134;    mul.f32 %f3, %f3, %f134;
    mul.f32 %f4, %f4, %f133;    mul.f32 %f5, %f5, %f133;
    mul.f32 %f6, %f6, %f134;    mul.f32 %f7, %f7, %f134;
    mul.f32 %f8, %f8, %f133;    mul.f32 %f9, %f9, %f133;
    mul.f32 %f10, %f10, %f134;  mul.f32 %f11, %f11, %f134;
    mul.f32 %f12, %f12, %f133;  mul.f32 %f13, %f13, %f133;
    mul.f32 %f14, %f14, %f134;  mul.f32 %f15, %f15, %f134;
    mul.f32 %f16, %f16, %f133;  mul.f32 %f17, %f17, %f133;
    mul.f32 %f18, %f18, %f134;  mul.f32 %f19, %f19, %f134;
    mul.f32 %f20, %f20, %f133;  mul.f32 %f21, %f21, %f133;
    mul.f32 %f22, %f22, %f134;  mul.f32 %f23, %f23, %f134;
    mul.f32 %f24, %f24, %f133;  mul.f32 %f25, %f25, %f133;
    mul.f32 %f26, %f26, %f134;  mul.f32 %f27, %f27, %f134;
    mul.f32 %f28, %f28, %f133;  mul.f32 %f29, %f29, %f133;
    mul.f32 %f30, %f30, %f134;  mul.f32 %f31, %f31, %f134;
    mul.f32 %f32, %f32, %f133;  mul.f32 %f33, %f33, %f133;
    mul.f32 %f34, %f34, %f134;  mul.f32 %f35, %f35, %f134;
    mul.f32 %f36, %f36, %f133;  mul.f32 %f37, %f37, %f133;
    mul.f32 %f38, %f38, %f134;  mul.f32 %f39, %f39, %f134;
    mul.f32 %f40, %f40, %f133;  mul.f32 %f41, %f41, %f133;
    mul.f32 %f42, %f42, %f134;  mul.f32 %f43, %f43, %f134;
    mul.f32 %f44, %f44, %f133;  mul.f32 %f45, %f45, %f133;
    mul.f32 %f46, %f46, %f134;  mul.f32 %f47, %f47, %f134;
    mul.f32 %f48, %f48, %f133;  mul.f32 %f49, %f49, %f133;
    mul.f32 %f50, %f50, %f134;  mul.f32 %f51, %f51, %f134;
    mul.f32 %f52, %f52, %f133;  mul.f32 %f53, %f53, %f133;
    mul.f32 %f54, %f54, %f134;  mul.f32 %f55, %f55, %f134;
    mul.f32 %f56, %f56, %f133;  mul.f32 %f57, %f57, %f133;
    mul.f32 %f58, %f58, %f134;  mul.f32 %f59, %f59, %f134;
    mul.f32 %f60, %f60, %f133;  mul.f32 %f61, %f61, %f133;
    mul.f32 %f62, %f62, %f134;  mul.f32 %f63, %f63, %f134;

    // Rescale row_sum
    mul.f32         %f194, %f194, %f133;
    mul.f32         %f195, %f195, %f134;

    // Update running max
    mov.f32         %f192, %f131;
    mov.f32         %f193, %f132;

    // ================================================================
    // Compute P = exp(S - new_max), store to SMEM at warp-specific offset
    // ================================================================
    // P store: %r75 (row0), %r76 (row1), ng offset = ng*16

    // ng0
    sub.f32 %f64, %f64, %f131;  mul.f32 %f64, %f64, LOG2E;  ex2.approx.f32 %f64, %f64;
    sub.f32 %f65, %f65, %f131;  mul.f32 %f65, %f65, LOG2E;  ex2.approx.f32 %f65, %f65;
    sub.f32 %f66, %f66, %f132; mul.f32 %f66, %f66, LOG2E;  ex2.approx.f32 %f66, %f66;
    sub.f32 %f67, %f67, %f132; mul.f32 %f67, %f67, LOG2E;  ex2.approx.f32 %f67, %f67;
    add.f32 %f194, %f194, %f64;  add.f32 %f194, %f194, %f65;
    add.f32 %f195, %f195, %f66;  add.f32 %f195, %f195, %f67;
    cvt.rn.bf16.f32 %h0, %f64;  cvt.rn.bf16.f32 %h1, %f65;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75], %r100;
    cvt.rn.bf16.f32 %h0, %f66;  cvt.rn.bf16.f32 %h1, %f67;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76], %r100;

    // ng1
    sub.f32 %f68, %f68, %f131;  mul.f32 %f68, %f68, LOG2E;  ex2.approx.f32 %f68, %f68;
    sub.f32 %f69, %f69, %f131;  mul.f32 %f69, %f69, LOG2E;  ex2.approx.f32 %f69, %f69;
    sub.f32 %f70, %f70, %f132; mul.f32 %f70, %f70, LOG2E;  ex2.approx.f32 %f70, %f70;
    sub.f32 %f71, %f71, %f132; mul.f32 %f71, %f71, LOG2E;  ex2.approx.f32 %f71, %f71;
    add.f32 %f194, %f194, %f68;  add.f32 %f194, %f194, %f69;
    add.f32 %f195, %f195, %f70;  add.f32 %f195, %f195, %f71;
    cvt.rn.bf16.f32 %h0, %f68;  cvt.rn.bf16.f32 %h1, %f69;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 16], %r100;
    cvt.rn.bf16.f32 %h0, %f70;  cvt.rn.bf16.f32 %h1, %f71;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 16], %r100;

    // ng2
    sub.f32 %f72, %f72, %f131;  mul.f32 %f72, %f72, LOG2E;  ex2.approx.f32 %f72, %f72;
    sub.f32 %f73, %f73, %f131;  mul.f32 %f73, %f73, LOG2E;  ex2.approx.f32 %f73, %f73;
    sub.f32 %f74, %f74, %f132; mul.f32 %f74, %f74, LOG2E;  ex2.approx.f32 %f74, %f74;
    sub.f32 %f75, %f75, %f132; mul.f32 %f75, %f75, LOG2E;  ex2.approx.f32 %f75, %f75;
    add.f32 %f194, %f194, %f72;  add.f32 %f194, %f194, %f73;
    add.f32 %f195, %f195, %f74;  add.f32 %f195, %f195, %f75;
    cvt.rn.bf16.f32 %h0, %f72;  cvt.rn.bf16.f32 %h1, %f73;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 32], %r100;
    cvt.rn.bf16.f32 %h0, %f74;  cvt.rn.bf16.f32 %h1, %f75;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 32], %r100;

    // ng3
    sub.f32 %f76, %f76, %f131;  mul.f32 %f76, %f76, LOG2E;  ex2.approx.f32 %f76, %f76;
    sub.f32 %f77, %f77, %f131;  mul.f32 %f77, %f77, LOG2E;  ex2.approx.f32 %f77, %f77;
    sub.f32 %f78, %f78, %f132; mul.f32 %f78, %f78, LOG2E;  ex2.approx.f32 %f78, %f78;
    sub.f32 %f79, %f79, %f132; mul.f32 %f79, %f79, LOG2E;  ex2.approx.f32 %f79, %f79;
    add.f32 %f194, %f194, %f76;  add.f32 %f194, %f194, %f77;
    add.f32 %f195, %f195, %f78;  add.f32 %f195, %f195, %f79;
    cvt.rn.bf16.f32 %h0, %f76;  cvt.rn.bf16.f32 %h1, %f77;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 48], %r100;
    cvt.rn.bf16.f32 %h0, %f78;  cvt.rn.bf16.f32 %h1, %f79;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 48], %r100;

    // ng4
    sub.f32 %f80, %f80, %f131;  mul.f32 %f80, %f80, LOG2E;  ex2.approx.f32 %f80, %f80;
    sub.f32 %f81, %f81, %f131;  mul.f32 %f81, %f81, LOG2E;  ex2.approx.f32 %f81, %f81;
    sub.f32 %f82, %f82, %f132; mul.f32 %f82, %f82, LOG2E;  ex2.approx.f32 %f82, %f82;
    sub.f32 %f83, %f83, %f132; mul.f32 %f83, %f83, LOG2E;  ex2.approx.f32 %f83, %f83;
    add.f32 %f194, %f194, %f80;  add.f32 %f194, %f194, %f81;
    add.f32 %f195, %f195, %f82;  add.f32 %f195, %f195, %f83;
    cvt.rn.bf16.f32 %h0, %f80;  cvt.rn.bf16.f32 %h1, %f81;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 64], %r100;
    cvt.rn.bf16.f32 %h0, %f82;  cvt.rn.bf16.f32 %h1, %f83;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 64], %r100;

    // ng5
    sub.f32 %f84, %f84, %f131;  mul.f32 %f84, %f84, LOG2E;  ex2.approx.f32 %f84, %f84;
    sub.f32 %f85, %f85, %f131;  mul.f32 %f85, %f85, LOG2E;  ex2.approx.f32 %f85, %f85;
    sub.f32 %f86, %f86, %f132; mul.f32 %f86, %f86, LOG2E;  ex2.approx.f32 %f86, %f86;
    sub.f32 %f87, %f87, %f132; mul.f32 %f87, %f87, LOG2E;  ex2.approx.f32 %f87, %f87;
    add.f32 %f194, %f194, %f84;  add.f32 %f194, %f194, %f85;
    add.f32 %f195, %f195, %f86;  add.f32 %f195, %f195, %f87;
    cvt.rn.bf16.f32 %h0, %f84;  cvt.rn.bf16.f32 %h1, %f85;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 80], %r100;
    cvt.rn.bf16.f32 %h0, %f86;  cvt.rn.bf16.f32 %h1, %f87;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 80], %r100;

    // ng6
    sub.f32 %f88, %f88, %f131;  mul.f32 %f88, %f88, LOG2E;  ex2.approx.f32 %f88, %f88;
    sub.f32 %f89, %f89, %f131;  mul.f32 %f89, %f89, LOG2E;  ex2.approx.f32 %f89, %f89;
    sub.f32 %f90, %f90, %f132; mul.f32 %f90, %f90, LOG2E;  ex2.approx.f32 %f90, %f90;
    sub.f32 %f91, %f91, %f132; mul.f32 %f91, %f91, LOG2E;  ex2.approx.f32 %f91, %f91;
    add.f32 %f194, %f194, %f88;  add.f32 %f194, %f194, %f89;
    add.f32 %f195, %f195, %f90;  add.f32 %f195, %f195, %f91;
    cvt.rn.bf16.f32 %h0, %f88;  cvt.rn.bf16.f32 %h1, %f89;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 96], %r100;
    cvt.rn.bf16.f32 %h0, %f90;  cvt.rn.bf16.f32 %h1, %f91;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 96], %r100;

    // ng7
    sub.f32 %f92, %f92, %f131;  mul.f32 %f92, %f92, LOG2E;  ex2.approx.f32 %f92, %f92;
    sub.f32 %f93, %f93, %f131;  mul.f32 %f93, %f93, LOG2E;  ex2.approx.f32 %f93, %f93;
    sub.f32 %f94, %f94, %f132; mul.f32 %f94, %f94, LOG2E;  ex2.approx.f32 %f94, %f94;
    sub.f32 %f95, %f95, %f132; mul.f32 %f95, %f95, LOG2E;  ex2.approx.f32 %f95, %f95;
    add.f32 %f194, %f194, %f92;  add.f32 %f194, %f194, %f93;
    add.f32 %f195, %f195, %f94;  add.f32 %f195, %f195, %f95;
    cvt.rn.bf16.f32 %h0, %f92;  cvt.rn.bf16.f32 %h1, %f93;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 112], %r100;
    cvt.rn.bf16.f32 %h0, %f94;  cvt.rn.bf16.f32 %h1, %f95;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 112], %r100;

    // ng8
    sub.f32 %f96, %f96, %f131;  mul.f32 %f96, %f96, LOG2E;  ex2.approx.f32 %f96, %f96;
    sub.f32 %f97, %f97, %f131;  mul.f32 %f97, %f97, LOG2E;  ex2.approx.f32 %f97, %f97;
    sub.f32 %f98, %f98, %f132; mul.f32 %f98, %f98, LOG2E;  ex2.approx.f32 %f98, %f98;
    sub.f32 %f99, %f99, %f132; mul.f32 %f99, %f99, LOG2E;  ex2.approx.f32 %f99, %f99;
    add.f32 %f194, %f194, %f96;  add.f32 %f194, %f194, %f97;
    add.f32 %f195, %f195, %f98;  add.f32 %f195, %f195, %f99;
    cvt.rn.bf16.f32 %h0, %f96;  cvt.rn.bf16.f32 %h1, %f97;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 128], %r100;
    cvt.rn.bf16.f32 %h0, %f98;  cvt.rn.bf16.f32 %h1, %f99;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 128], %r100;

    // ng9
    sub.f32 %f100, %f100, %f131;  mul.f32 %f100, %f100, LOG2E;  ex2.approx.f32 %f100, %f100;
    sub.f32 %f101, %f101, %f131;  mul.f32 %f101, %f101, LOG2E;  ex2.approx.f32 %f101, %f101;
    sub.f32 %f102, %f102, %f132; mul.f32 %f102, %f102, LOG2E;  ex2.approx.f32 %f102, %f102;
    sub.f32 %f103, %f103, %f132; mul.f32 %f103, %f103, LOG2E;  ex2.approx.f32 %f103, %f103;
    add.f32 %f194, %f194, %f100;  add.f32 %f194, %f194, %f101;
    add.f32 %f195, %f195, %f102;  add.f32 %f195, %f195, %f103;
    cvt.rn.bf16.f32 %h0, %f100;  cvt.rn.bf16.f32 %h1, %f101;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 144], %r100;
    cvt.rn.bf16.f32 %h0, %f102;  cvt.rn.bf16.f32 %h1, %f103;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r76 + 144], %r100;

    // ng10
    sub.f32 %f104, %f104, %f131;  mul.f32 %f104, %f104, LOG2E;  ex2.approx.f32 %f104, %f104;
    sub.f32 %f105, %f105, %f131;  mul.f32 %f105, %f105, LOG2E;  ex2.approx.f32 %f105, %f105;
    sub.f32 %f106, %f106, %f132; mul.f32 %f106, %f106, LOG2E;  ex2.approx.f32 %f106, %f106;
    sub.f32 %f107, %f107, %f132; mul.f32 %f107, %f107, LOG2E;  ex2.approx.f32 %f107, %f107;
    add.f32 %f194, %f194, %f104;  add.f32 %f194, %f194, %f105;
    add.f32 %f195, %f195, %f106;  add.f32 %f195, %f195, %f107;
    cvt.rn.bf16.f32 %h0, %f104;  cvt.rn.bf16.f32 %h1, %f105;
    mov.b32 %r100, {%h0, %h1};
    st.shared.b32 [%r75 + 160], %r100;
