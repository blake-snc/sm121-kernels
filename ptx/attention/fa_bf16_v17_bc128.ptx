// fa_bf16_v17_bc128.ptx
//
// Flash Attention (non-causal) for BF16 with d=128.
// FlashAttention-2 online softmax algorithm.
//
// 8 warps (256 threads), Br=128, Bc=128, d=128.
// Grid: (ceil(seq_q/128), num_heads, batch_size)
//
// Q,K,V: [batch, num_heads, seq, 128] row-major bf16
// O:     [batch, num_heads, seq, 128] row-major bf16
//
// MMA: mma.sync.aligned.m16n8k16.row.col.f32.bf16.bf16.f32
//
// SMEM layout (65536 bytes = 64 KB):
//   [0 ..  32767]  K tile / P tile: 128 rows x 128 cols x 2B = 32768 bytes
//   [32768..65535]  V tile: 128 rows x 128 cols x 2B = 32768 bytes
//
// During Q loading, all 32KB of first half is used for Q[128,128].
//
// Each warp independently computes 16 rows of output.
// Warp w computes rows [q_block*128 + w*16 .. q_block*128 + w*16 + 15].
//
// Register budget per thread:
//   Q fragments:      8 k-chunks x 4 regs = 32 regs (.b32)
//   S accumulators:  16 n-groups x 4 regs = 64 regs (.f32) [reused per KV block]
//   O accumulators:  16 n-groups x 4 regs = 64 regs (.f32)
//   Softmax state:   row_max(2) + row_sum(2) = 4 regs (.f32)
//   Temps + addrs:   ~30 regs
//   Total:           ~194 regs (within 256 limit)

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

// Tile dimensions
#define BR 128
#define BC 128
#define D  128

// SMEM layout (must fit in 99KB = 101376 bytes for SM121a):
//   [0, 32768)      K tile (BC*D*2 = 128*128*2 = 32768 bytes), reused for P matrix
//   [32768, 65536)   V tile (BC*D*2 = 128*128*2 = 32768 bytes)
//   Total: 65536 bytes (64 KB) — within 99 KB limit
#define SMEM_KP   0
#define SMEM_V    (BC * D * 2)

// Row strides (bytes per row in SMEM, including XOR swizzle padding)
#define KV_ROW_STRIDE (D * 2)
#define P_ROW_STRIDE  (BC * 2)

.visible .entry flash_attn_bf16_v17_bc128(
    .param .u64 param_Q,        // [B, H, Sq, 128] bf16
    .param .u64 param_K,        // [B, H, Skv, 128] bf16
    .param .u64 param_V,        // [B, H, Skv, 128] bf16
    .param .u64 param_O,        // [B, H, Sq, 128] bf16 (output)
    .param .u32 param_seq_q,    // sequence length Q
    .param .u32 param_seq_kv,   // sequence length KV
    .param .u32 param_num_heads,
    .param .f32 param_scale     // 1/sqrt(d)
)
{
    // ================================================================
    // Register declarations
    // ================================================================
    .reg .b32  %r<200>;
    .reg .b64  %rd<48>;
    .reg .f32  %f<260>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    // Shared memory: K/P tile (32768) + V tile (32768) = 65536 bytes
    .shared .align 128 .b8 smem[65536];

    // ================================================================
    // Thread/block identification
    // ================================================================
    mov.u32         %r0, %tid.x;               // tid [0..255]
    mov.u32         %r1, %ctaid.x;             // q_block_idx
    mov.u32         %r2, %ctaid.y;             // head_idx
    mov.u32         %r3, %ctaid.z;             // batch_idx

    // Warp and lane decomposition
    and.b32         %r10, %r0, 31;             // lane = tid % 32 [0..31]
    shr.b32         %r9, %r0, 5;              // warp_id = tid / 32 [0..7]

    // MMA thread decomposition (based on LANE, not tid)
    shr.b32         %r4, %r10, 2;             // groupID = lane / 4  [0..7]
    and.b32         %r5, %r10, 3;             // tidInGroup = lane % 4  [0..3]

    // ================================================================
    // Load parameters
    // ================================================================
    ld.param.u64    %rd0, [param_Q];
    ld.param.u64    %rd1, [param_K];
    ld.param.u64    %rd2, [param_V];
    ld.param.u64    %rd3, [param_O];
    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f196, [param_scale];

    // ================================================================
    // Compute base pointers for this (batch, head, q_block)
    // ================================================================
    // Q base: param_Q + (batch * num_heads * seq_q * 128 + head * seq_q * 128 + q_block * BR * 128) * 2
    mul.lo.u32      %r11, %r6, D;             // seq_q * 128
    mul.lo.u32      %r12, %r8, %r11;          // num_heads * seq_q * 128 (batch stride)
    mul.lo.u32      %r13, %r3, %r12;          // batch * batch_stride
    mul.lo.u32      %r14, %r2, %r11;          // head * head_stride
    add.u32         %r13, %r13, %r14;         // batch_off + head_off (Q/O)

    shl.b32         %r15, %r1, 7;             // q_block * BR = q_block * 128
    mul.lo.u32      %r16, %r15, D;            // q_block * BR * 128
    add.u32         %r17, %r13, %r16;         // total Q element offset

    mul.wide.u32    %rd4, %r17, 2;            // byte offset
    add.u64         %rd5, %rd0, %rd4;         // Q base ptr for this block

    // O base: batch+head offset only (store uses global row)
    mul.wide.u32    %rd40, %r13, 2;           // batch+head byte offset
    add.u64         %rd6, %rd3, %rd40;        // O base ptr (no q_block)

    // K/V base: param_K + (batch * num_heads * seq_kv * 128 + head * seq_kv * 128) * 2
    mul.lo.u32      %r18, %r7, D;             // seq_kv * 128
    mul.lo.u32      %r19, %r8, %r18;          // num_heads * seq_kv * 128 (batch stride)
    mul.lo.u32      %r20, %r3, %r19;          // batch * batch_stride
    mul.lo.u32      %r23, %r2, %r18;          // head * head_stride
    add.u32         %r20, %r20, %r23;         // batch_off + head_off (K/V)
    mul.wide.u32    %rd7, %r20, 2;            // byte offset
    add.u64         %rd8, %rd1, %rd7;         // K base ptr
    add.u64         %rd9, %rd2, %rd7;         // V base ptr

    // smem base
    mov.u32         %r21, smem;

    // ================================================================
    // Precompute ldmatrix addresses for Q (A-operand)
    // ================================================================
    // For m16n8k16 A-operand: ldmatrix.x4
    //   lane < 16: smem_base + lane * 32
    //   lane >= 16: smem_base + (lane-16)*32 + 16
    setp.lt.u32     %p0, %r10, 16;
    @%p0 mul.lo.u32 %r22, %r10, 32;
    @!%p0 sub.u32   %r22, %r10, 16;
    @!%p0 mad.lo.u32 %r22, %r22, 32, 16;
    // %r22 = per-lane Q ldmatrix offset within a 16x16 tile (512 bytes)

    // ================================================================
    // Cooperative Q load: 256 threads load Q[128,128] to first 32KB SMEM
    // ================================================================
    // Q tile: 128 rows x 128 cols x 2B = 32768 bytes
    // 256 threads: each thread loads half a row (128 bytes = 8 x v4.b32)
    //   row = tid / 2  [0..127]
    //   half = tid % 2  [0 or 1]
    //   global_addr = Q_base + row * 256 + half * 128
    //   smem_addr = smem + row * 256 + half * 128

    shr.b32         %r24, %r0, 1;             // q_load_row = tid / 2 [0..127]
    and.b32         %r25, %r0, 1;             // q_load_half = tid % 2 [0 or 1]

    // Global address
    mul.lo.u32      %r26, %r24, 256;          // row * 256 bytes
    cvt.u64.u32     %rd10, %r26;
    add.u64         %rd11, %rd5, %rd10;       // &Q[row][0]
    shl.b32         %r27, %r25, 7;            // half * 128 bytes
    cvt.u64.u32     %rd12, %r27;
    add.u64         %rd13, %rd11, %rd12;      // &Q[row][half*64] (byte addr)

    // SMEM store address
    add.u32         %r28, %r26, %r27;         // row*256 + half*128
    add.u32         %r29, %r21, %r28;         // smem + row*256 + half*128

    // Bounds check: q_block*128 + row < seq_q
    add.u32         %r30, %r15, %r24;         // q_block*128 + row
    setp.lt.u32     %p1, %r30, %r6;

    // Load 128 bytes via cp.async: 8 x 16B (register-bypass, global->SMEM direct)
    // src_size: 16 if in-bounds, 0 if OOB (zero-fills destination)
    selp.b32        %r100, 16, 0, %p1;
    cp.async.cg.shared.global [%r29],       [%rd13],       16, %r100;
    cp.async.cg.shared.global [%r29 + 16],  [%rd13 + 16],  16, %r100;
    cp.async.cg.shared.global [%r29 + 32],  [%rd13 + 32],  16, %r100;
    cp.async.cg.shared.global [%r29 + 48],  [%rd13 + 48],  16, %r100;
    cp.async.cg.shared.global [%r29 + 64],  [%rd13 + 64],  16, %r100;
    cp.async.cg.shared.global [%r29 + 80],  [%rd13 + 80],  16, %r100;
    cp.async.cg.shared.global [%r29 + 96],  [%rd13 + 96],  16, %r100;
    cp.async.cg.shared.global [%r29 + 112], [%rd13 + 112], 16, %r100;
    cp.async.commit_group;
    cp.async.wait_group 0;
    bar.sync 0;

    // ================================================================
    // Per-warp ldmatrix: load Q fragments from SMEM to registers
    // ================================================================
    // Each warp's Q tile is at smem + warp_id * 16 * 256 = smem + warp_id * 4096
    // Within the warp tile, ldmatrix uses the same offset formula as V1
    // warp_q_smem_base = smem + warp_id * 4096 + per_lane_ldmatrix_offset (%r22)

    mul.lo.u32      %r62, %r9, 4096;          // warp_id * 4096
    add.u32         %r62, %r62, %r22;         // + ldmatrix offset
    add.u32         %r63, %r21, %r62;         // smem + warp_id*4096 + ldm_offset

    // Q is 16x128 in SMEM with row stride 256 bytes.
    // Each k-chunk occupies 16 cols = 32 bytes stride.
    // Within the warp's 16x128 tile:
    //   k-chunk kc: ldmatrix at base + kc * 32

    // But wait: Q is stored as 128 rows x 128 cols with row stride 256.
    // Warp w's tile starts at row w*16, so SMEM base = smem + w*16*256 = smem + w*4096.
    // Within this 16-row region, the layout is 16 rows x 128 cols with stride 256.
    // For ldmatrix.x4 loading a 16x16 subtile at k-chunk kc:
    //   The 16x16 subtile starts at column kc*16 (byte offset kc*32).
    //   Address = warp_base + per_lane_offset + kc*32
    //   where per_lane_offset = %r22 (already computed, spans rows with stride 32 for a 16x16 tile)
    //
    // PROBLEM: The ldmatrix offset %r22 assumes row stride = 32 bytes (for a 16x16 tile).
    // But our SMEM has row stride = 256 bytes (full 128-col row).
    // We need to adjust: for ldmatrix of a 16x16 subtile from a 16x128-stored matrix,
    // the address formula becomes:
    //   lane < 16: warp_base + lane * 256 + kc * 32
    //   lane >= 16: warp_base + (lane-16) * 256 + kc * 32 + 16
    //
    // This is different from %r22 which uses stride 32. Recompute.

    mul.lo.u32      %r62, %r9, 4096;          // warp_id * 4096 (byte offset to warp's Q rows)
    @%p0 mul.lo.u32 %r63, %r10, 256;          // lane < 16: lane * 256 (row stride)
    @!%p0 sub.u32   %r63, %r10, 16;
    @!%p0 mul.lo.u32 %r63, %r63, 256;         // (lane-16) * 256
    @!%p0 add.u32   %r63, %r63, 16;           // + 16 bytes (second 8 cols within 16-col chunk)
    add.u32         %r63, %r63, %r62;         // + warp offset
    add.u32         %r64, %r21, %r63;         // smem + warp_q_ldm_base

    // Load Q k-chunk 0..7 via ldmatrix.x4 (no sync needed between chunks)
    // kc=0: offset +0
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r30, %r31, %r32, %r33}, [%r64];
    // kc=1: offset +32
    add.u32         %r65, %r64, 32;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r34, %r35, %r36, %r37}, [%r65];
    // kc=2: offset +64
    add.u32         %r65, %r64, 64;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r38, %r39, %r40, %r41}, [%r65];
    // kc=3: offset +96
    add.u32         %r65, %r64, 96;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r42, %r43, %r44, %r45}, [%r65];
    // kc=4: offset +128
    add.u32         %r65, %r64, 128;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r46, %r47, %r48, %r49}, [%r65];
    // kc=5: offset +160
    add.u32         %r65, %r64, 160;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r50, %r51, %r52, %r53}, [%r65];
    // kc=6: offset +192
    add.u32         %r65, %r64, 192;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r54, %r55, %r56, %r57}, [%r65];
    // kc=7: offset +224
    add.u32         %r65, %r64, 224;
    ldmatrix.sync.aligned.m8n8.x4.shared.b16 {%r58, %r59, %r60, %r61}, [%r65];

    // Q is now in registers:
    //   k-chunk 0: %r30..%r33, k-chunk 1: %r34..%r37
    //   k-chunk 2: %r38..%r41, k-chunk 3: %r42..%r45
    //   k-chunk 4: %r46..%r49, k-chunk 5: %r50..%r53
    //   k-chunk 6: %r54..%r57, k-chunk 7: %r58..%r61

    // Sync so SMEM can be reused for K/V/P
    bar.sync 0;

    // ================================================================
    // Initialize O accumulators and softmax state
    // ================================================================
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    // Softmax state (moved to %f192..%f195 to avoid conflict with S accumulators)
    mov.b32         %f192, 0xff800000;         // row_max[0] = -inf
    mov.b32         %f193, 0xff800000;         // row_max[1] = -inf
    mov.f32         %f194, 0.0;                // row_sum[0] = 0
    mov.f32         %f195, 0.0;                // row_sum[1] = 0

    // ================================================================
    // Precompute K/V/P SMEM address helpers
    // ================================================================

    // K ldmatrix addresses (B-operand for QK^T, at SMEM offset 0)
    // K[seq, d] row-major = K^T[d, seq] col-major, so no .trans needed.
    // ldmatrix.x2: addr = smem + (ng*8 + sub_lane)*256 + kc*32 + half*16
    //   sub_lane = lane % 8, half = (lane/8) % 2
    and.b32         %r68, %r10, 7;             // sub_lane = lane % 8
    mul.lo.u32      %r69, %r68, KV_ROW_STRIDE; // sub_lane * 256
    shr.b32         %r94, %r10, 3;
    and.b32         %r94, %r94, 1;            // half = (lane/8) % 2
    shl.b32         %r94, %r94, 4;            // half * 16
    add.u32         %r69, %r69, %r94;         // sub_lane*256 + half*16

    // V ldmatrix addresses (B-operand for PV, at SMEM offset 32768)
    // ldmatrix.x2.trans: addr = SMEM_V + (kp*16 + lane%16)*256 + ng*16
    and.b32         %r95, %r10, 15;            // lane % 16
    mul.lo.u32      %r96, %r95, KV_ROW_STRIDE; // (lane%16) * 256

    // P store addresses (warp-specific offset in K buffer)
    // P_smem_base = smem + warp_id * 4096
    // P layout: 16 rows x 128 cols x 2B = 4096 bytes per warp, row stride = 256
    mul.lo.u32      %r70, %r9, 4096;          // warp_id * 4096
    add.u32         %r71, %r21, %r70;         // P_smem_base = smem + warp_id*4096

    // P store: row0 = groupID, row1 = groupID+8 (within warp's 16 rows)
    mul.lo.u32      %r72, %r4, P_ROW_STRIDE;  // groupID * 256
    add.u32         %r73, %r72, 2048;          // (groupID+8) * 256
    shl.b32         %r74, %r5, 2;              // tidInGroup * 2 * 2 = col byte offset

    // P store base for row0: P_smem_base + groupID*256 + tidInGroup*4
    add.u32         %r75, %r71, %r72;
    add.u32         %r75, %r75, %r74;
    // P store base for row1: P_smem_base + (groupID+8)*256 + tidInGroup*4
    add.u32         %r76, %r71, %r73;
    add.u32         %r76, %r76, %r74;

    // P ldmatrix addresses (A-operand for P*V MMA):
    // P is 16x128 bf16 at P_smem_base. Row stride = 256 bytes.
    //   lane < 16: P_smem_base + lane * 256 + kp * 32
    //   lane >= 16: P_smem_base + (lane-16) * 256 + kp * 32 + 16
    @%p0 mul.lo.u32 %r77, %r10, P_ROW_STRIDE;            // lane * 256
    @!%p0 sub.u32   %r77, %r10, 16;
    @!%p0 mul.lo.u32 %r77, %r77, P_ROW_STRIDE;            // (lane-16)*256
    @!%p0 add.u32   %r77, %r77, 16;
    add.u32         %r78, %r71, %r77;          // P ldmatrix base (add kp*32 per chunk)

    // ================================================================
    // Precompute cooperative K/V load helpers
    // ================================================================
    // 256 threads load K/V [128, 128] bf16 = 32768 bytes cooperatively
    //   kv_load_row = tid / 2  [0..127]
    //   kv_load_half = tid % 2  [0,1], each half = 128 bytes
    //   smem_addr = smem_base + row * 256 + half * 128
    //   Each thread loads 128 bytes = 8 x cp.async(16B)

    shr.b32         %r110, %r0, 1;            // kv_load_row = tid / 2 [0..127]
    and.b32         %r111, %r0, 1;            // kv_load_half = tid % 2 [0,1]
    mul.lo.u32      %r112, %r110, KV_ROW_STRIDE; // row * 256
    shl.b32         %r113, %r111, 7;          // half * 128
    add.u32         %r114, %r112, %r113;      // row*256 + half*128 (smem offset within tile)

    // ================================================================
    // KV BLOCK LOOP
    // ================================================================
    mov.u32         %r80, 0;                   // kv_block = 0
    add.u32         %r81, %r7, 127;
    shr.b32         %r81, %r81, 7;             // num_kv_blocks = ceil(seq_kv / 128)

kv_loop:
    setp.ge.u32     %p2, %r80, %r81;
    @%p2 bra        kv_done;

    // ================================================================
    // Cooperative K load: 256 threads -> K[128,128] to SMEM [0..32767]
    // ================================================================
    shl.b32         %r82, %r80, 7;             // kv_block * 128

    // Global address: K_base + (kv_block*128 + kv_load_row) * D * 2 + half * 128
    // half selects which 128-byte chunk of the 256-byte row.
    //   half 0: bytes [0..127], half 1: [128..255]
    // Element offset = half * 64 (64 bf16 elements per half)
    add.u32         %r83, %r82, %r110;        // global_row = kv_block*128 + kv_load_row
    mul.lo.u32      %r84, %r83, D;            // global_row * 128 (elements)
    add.u32         %r84, %r84, %r20;         // + batch/head offset (elements)
    shl.b32         %r85, %r111, 6;           // half * 64 (element offset)
    add.u32         %r84, %r84, %r85;         // total element offset
    mul.wide.u32    %rd14, %r84, 2;           // byte offset
    add.u64         %rd15, %rd1, %rd14;       // K global addr

    // Bounds check
    setp.lt.u32     %p3, %r83, %r7;           // global_row < seq_kv

    // SMEM addr = smem + SMEM_KP + row*256 + half*128
    add.u32         %r86, %r21, %r114;        // smem + kv tile offset

    // Load 128 bytes via cp.async: 8 x 16B (register-bypass, global->SMEM direct)
    selp.b32        %r100, 16, 0, %p3;
    cp.async.cg.shared.global [%r86],      [%rd15],      16, %r100;
    cp.async.cg.shared.global [%r86 + 16], [%rd15 + 16], 16, %r100;
    cp.async.cg.shared.global [%r86 + 32], [%rd15 + 32], 16, %r100;
    cp.async.cg.shared.global [%r86 + 48], [%rd15 + 48], 16, %r100;
    cp.async.cg.shared.global [%r86 + 64], [%rd15 + 64], 16, %r100;
    cp.async.cg.shared.global [%r86 + 80], [%rd15 + 80], 16, %r100;
    cp.async.cg.shared.global [%r86 + 96], [%rd15 + 96], 16, %r100;
