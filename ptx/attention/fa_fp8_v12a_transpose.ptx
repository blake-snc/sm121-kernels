// fa_fp8_v12a_transpose.ptx
//
// Flash Attention FP8 V12a: V in standard GMEM layout [Skv, D], SMEM transpose V->V_T.
//
// After TMA loads V FP8[Bc=64, D=128] into SMEM_V (row-major stride 128),
// the 128 MMA threads cooperatively transpose to V_T FP8[D=128, Bc=64] in SMEM_VT.
// V_T[d*64 + k] = V[k, d], enabling single ld.shared.b32 for each B-fragment
// (replacing 4xld.u8 + 3xbfi.b32 in V11).
//
// Transpose sync: bar.sync 0, 128 (MMA warps only) after transpose, before PV GEMM.
// No extra mbarriers needed -- the mbar_v arrival (which signals V TMA done) ensures
// V data is visible; bar.sync 0 ensures V_T write visibility.
//
// SMEM: ~60 KB (adds 2x8192 bytes for V_T double-buffering vs V11's ~45 KB).
//
// 5 warps (160 threads): warps 0-3 = MMA, warp 4 = DMA.
// Br=64, Bc=64, D=128. Grid: (ceil(seq_q/64), num_heads, batch), Block: (160,1,1).

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"
#include "mma.ptxh"
#include "reduction.ptxh"

#define BR 64
#define BC 64
#define D  128
#define NUM_MMA_WARPS 4
#define DMA_WARP_ID   4

// SMEM layout (~60 KB total)
#define SMEM_Q            0
#define SMEM_K0           8192
#define SMEM_K1           16384
#define SMEM_V0           24576     // V raw stage 0 (from TMA, row-major stride 128)
#define SMEM_V1           32768     // V raw stage 1
#define SMEM_VT0          40960     // V_T stage 0 (transposed, row-major stride 64)
#define SMEM_VT1          49152     // V_T stage 1
#define SMEM_P            57344     // P FP8 (4096 bytes)
#define SMEM_MBAR_Q       61440
#define SMEM_MBAR_K0      61456
#define SMEM_MBAR_K1      61472
#define SMEM_MBAR_V0      61488
#define SMEM_MBAR_V1      61504
#define SMEM_MBAR_DONE0   61520
#define SMEM_MBAR_DONE1   61536
#define SMEM_TOTAL        61552

#define P_ROW_STRIDE  64

.extern .shared .align 128 .b8 smem[];

// ================================================================
// QK GEMM (identical to V11 FP8)
// ================================================================
#define QK_NG8_FP8(q0,q1,q2,q3, Klo, Khi) \
    ld.shared.b32 %r100, [Klo];          ld.shared.b32 %r101, [Khi]; \
    MMA_FP8_M16N8K32(%f64,%f65,%f66,%f67, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 1024];   ld.shared.b32 %r101, [Khi + 1024]; \
    MMA_FP8_M16N8K32(%f68,%f69,%f70,%f71, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 2048];   ld.shared.b32 %r101, [Khi + 2048]; \
    MMA_FP8_M16N8K32(%f72,%f73,%f74,%f75, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 3072];   ld.shared.b32 %r101, [Khi + 3072]; \
    MMA_FP8_M16N8K32(%f76,%f77,%f78,%f79, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 4096];   ld.shared.b32 %r101, [Khi + 4096]; \
    MMA_FP8_M16N8K32(%f80,%f81,%f82,%f83, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 5120];   ld.shared.b32 %r101, [Khi + 5120]; \
    MMA_FP8_M16N8K32(%f84,%f85,%f86,%f87, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 6144];   ld.shared.b32 %r101, [Khi + 6144]; \
    MMA_FP8_M16N8K32(%f88,%f89,%f90,%f91, q0,q1,q2,q3, %r100,%r101) \
    ld.shared.b32 %r100, [Klo + 7168];   ld.shared.b32 %r101, [Khi + 7168]; \
    MMA_FP8_M16N8K32(%f92,%f93,%f94,%f95, q0,q1,q2,q3, %r100,%r101)

// ================================================================
// PV GEMM using V_T SMEM (identical macro to V12c option)
// ================================================================
#define PV_NG16_VT(p0,p1,p2,p3, vtb, kp_off) \
    ld.shared.b32 %r104, [vtb + kp_off];       ld.shared.b32 %r105, [vtb + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f0 ,%f1 ,%f2 ,%f3 , p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 512 + kp_off]; ld.shared.b32 %r105, [vtb + 512 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f4 ,%f5 ,%f6 ,%f7 , p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 1024 + kp_off]; ld.shared.b32 %r105, [vtb + 1024 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f8 ,%f9 ,%f10,%f11, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 1536 + kp_off]; ld.shared.b32 %r105, [vtb + 1536 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f12,%f13,%f14,%f15, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 2048 + kp_off]; ld.shared.b32 %r105, [vtb + 2048 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f16,%f17,%f18,%f19, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 2560 + kp_off]; ld.shared.b32 %r105, [vtb + 2560 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f20,%f21,%f22,%f23, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 3072 + kp_off]; ld.shared.b32 %r105, [vtb + 3072 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f24,%f25,%f26,%f27, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 3584 + kp_off]; ld.shared.b32 %r105, [vtb + 3584 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f28,%f29,%f30,%f31, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 4096 + kp_off]; ld.shared.b32 %r105, [vtb + 4096 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f32,%f33,%f34,%f35, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 4608 + kp_off]; ld.shared.b32 %r105, [vtb + 4608 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f36,%f37,%f38,%f39, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 5120 + kp_off]; ld.shared.b32 %r105, [vtb + 5120 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f40,%f41,%f42,%f43, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 5632 + kp_off]; ld.shared.b32 %r105, [vtb + 5632 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f44,%f45,%f46,%f47, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 6144 + kp_off]; ld.shared.b32 %r105, [vtb + 6144 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f48,%f49,%f50,%f51, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 6656 + kp_off]; ld.shared.b32 %r105, [vtb + 6656 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f52,%f53,%f54,%f55, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 7168 + kp_off]; ld.shared.b32 %r105, [vtb + 7168 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f56,%f57,%f58,%f59, p0,p1,p2,p3, %r104,%r105) \
    ld.shared.b32 %r104, [vtb + 7680 + kp_off]; ld.shared.b32 %r105, [vtb + 7680 + kp_off + 16]; \
    MMA_FP8_M16N8K32(%f60,%f61,%f62,%f63, p0,p1,p2,p3, %r104,%r105)

// P store helpers (identical to V11)
#define EXP_CLAMP_EX2(s, neg_mx_log2e) \
    fma.rn.f32 s, s, %f199, neg_mx_log2e; \
    max.f32 s, s, 0fC2FA0000; \
    ex2.approx.ftz.f32 s, s;

#define EXP_STORE_NG_FP8(s0,s1,s2,s3, nmx0, nmx1, pa0, pa1, ng_off) \
    EXP_CLAMP_EX2(s0, nmx0)  EXP_CLAMP_EX2(s1, nmx0) \
    EXP_CLAMP_EX2(s2, nmx1)  EXP_CLAMP_EX2(s3, nmx1) \
    add.f32 %f194, %f194, s0;  add.f32 %f194, %f194, s1; \
    add.f32 %f195, %f195, s2;  add.f32 %f195, %f195, s3; \
    cvt.rn.satfinite.e4m3x2.f32 %h0, s1, s0; \
    st.shared.b16 [pa0 + ng_off], %h0; \
    cvt.rn.satfinite.e4m3x2.f32 %h0, s3, s2; \
    st.shared.b16 [pa1 + ng_off], %h0;

.visible .entry flash_attn_fp8_v12a_transpose(
    .param .u64 param_Q_tma_ptr,
    .param .u64 param_K_tma_ptr,
    .param .u64 param_V_tma_ptr,    // V in standard [Skv, D] GMEM layout
    .param .u64 param_O,
    .param .u32 param_seq_q,
    .param .u32 param_seq_kv,
    .param .u32 param_num_heads,
    .param .f32 param_scale
)
{
    .reg .b32  %r<200>;
    .reg .b64  %rd<32>;
    .reg .f32  %f<200>;
    .reg .b16  %h<8>;
    .reg .pred %p<16>;

    mov.u32         %r0, %tid.x;
    shr.b32         %r1, %r0, 5;
    and.b32         %r2, %r0, 31;

    mov.u32         %r3, %ctaid.x;
    mov.u32         %r4, %ctaid.y;
    mov.u32         %r5, %ctaid.z;

    ld.param.u32    %r6, [param_seq_q];
    ld.param.u32    %r7, [param_seq_kv];
    ld.param.u32    %r8, [param_num_heads];
    ld.param.f32    %f196, [param_scale];

    setp.eq.u32     %p0, %r0, 0;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_Q], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_K0], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_K1], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_V0], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_V1], 1;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_DONE0], NUM_MMA_WARPS;
    @%p0 mbarrier.init.shared.b64 [smem + SMEM_MBAR_DONE1], NUM_MMA_WARPS;
    fence.mbarrier_init.release.cluster;
    bar.sync 0;

    mul.lo.u32      %r9, %r5, %r8;
    add.u32         %r9, %r9, %r4;
    mul.lo.u32      %r10, %r9, %r6;
    shl.b32         %r11, %r3, 6;
    add.u32         %r10, %r10, %r11;
    mul.lo.u32      %r12, %r9, %r7;

    ld.param.u64    %rd0, [param_Q_tma_ptr];
    ld.param.u64    %rd1, [param_K_tma_ptr];
    ld.param.u64    %rd2, [param_V_tma_ptr];

    setp.eq.u32     %p1, %r1, DMA_WARP_ID;
    @%p1 bra        dma_path;

    // ================================================================
    // MMA WARP PATH (warps 0-3)
    // ================================================================

    shr.b32         %r13, %r2, 2;
    and.b32         %r14, %r2, 3;
    mov.u32         %r20, smem;

    shl.b32         %r160, %r13, 4;
    shl.b32         %r23, %r13, 7;
    shl.b32         %r24, %r14, 2;

    mul.lo.u32      %r161, %r1, 2048;
    add.u32         %r162, %r20, SMEM_Q;
    add.u32         %r162, %r162, %r161;
    add.u32         %r162, %r162, %r23;
    add.u32         %r163, %r162, 1024;

mma_wait_q:
    mbarrier.try_wait.parity.shared.b64 %p2, [smem + SMEM_MBAR_Q], 0;
    @!%p2 bra mma_wait_q;

    // Load Q (SWIZZLE_128B, 4 kc groups)
    xor.b32         %r25, %r24, %r160;
    add.u32         %r82, %r162, %r25;
    ld.shared.b32   %r30, [%r82];
    add.u32         %r82, %r163, %r25;
    ld.shared.b32   %r31, [%r82];
    add.u32         %r26, %r24, 16;
    xor.b32         %r26, %r26, %r160;
    add.u32         %r82, %r162, %r26;
    ld.shared.b32   %r32, [%r82];
    add.u32         %r82, %r163, %r26;
    ld.shared.b32   %r33, [%r82];

    add.u32         %r25, %r24, 32;
    xor.b32         %r25, %r25, %r160;
    add.u32         %r82, %r162, %r25;
    ld.shared.b32   %r34, [%r82];
    add.u32         %r82, %r163, %r25;
    ld.shared.b32   %r35, [%r82];
    add.u32         %r26, %r24, 48;
    xor.b32         %r26, %r26, %r160;
    add.u32         %r82, %r162, %r26;
    ld.shared.b32   %r36, [%r82];
    add.u32         %r82, %r163, %r26;
    ld.shared.b32   %r37, [%r82];

    add.u32         %r25, %r24, 64;
    xor.b32         %r25, %r25, %r160;
    add.u32         %r82, %r162, %r25;
    ld.shared.b32   %r38, [%r82];
    add.u32         %r82, %r163, %r25;
    ld.shared.b32   %r39, [%r82];
    add.u32         %r26, %r24, 80;
    xor.b32         %r26, %r26, %r160;
    add.u32         %r82, %r162, %r26;
    ld.shared.b32   %r40, [%r82];
    add.u32         %r82, %r163, %r26;
    ld.shared.b32   %r41, [%r82];

    add.u32         %r25, %r24, 96;
    xor.b32         %r25, %r25, %r160;
    add.u32         %r82, %r162, %r25;
    ld.shared.b32   %r42, [%r82];
    add.u32         %r82, %r163, %r25;
    ld.shared.b32   %r43, [%r82];
    add.u32         %r26, %r24, 112;
    xor.b32         %r26, %r26, %r160;
    add.u32         %r82, %r162, %r26;
    ld.shared.b32   %r44, [%r82];
    add.u32         %r82, %r163, %r26;
    ld.shared.b32   %r45, [%r82];

    // Initialize O accumulators and softmax
    mov.f32 %f0, 0.0;   mov.f32 %f1, 0.0;   mov.f32 %f2, 0.0;   mov.f32 %f3, 0.0;
    mov.f32 %f4, 0.0;   mov.f32 %f5, 0.0;   mov.f32 %f6, 0.0;   mov.f32 %f7, 0.0;
    mov.f32 %f8, 0.0;   mov.f32 %f9, 0.0;   mov.f32 %f10, 0.0;  mov.f32 %f11, 0.0;
    mov.f32 %f12, 0.0;  mov.f32 %f13, 0.0;  mov.f32 %f14, 0.0;  mov.f32 %f15, 0.0;
    mov.f32 %f16, 0.0;  mov.f32 %f17, 0.0;  mov.f32 %f18, 0.0;  mov.f32 %f19, 0.0;
    mov.f32 %f20, 0.0;  mov.f32 %f21, 0.0;  mov.f32 %f22, 0.0;  mov.f32 %f23, 0.0;
    mov.f32 %f24, 0.0;  mov.f32 %f25, 0.0;  mov.f32 %f26, 0.0;  mov.f32 %f27, 0.0;
    mov.f32 %f28, 0.0;  mov.f32 %f29, 0.0;  mov.f32 %f30, 0.0;  mov.f32 %f31, 0.0;
    mov.f32 %f32, 0.0;  mov.f32 %f33, 0.0;  mov.f32 %f34, 0.0;  mov.f32 %f35, 0.0;
    mov.f32 %f36, 0.0;  mov.f32 %f37, 0.0;  mov.f32 %f38, 0.0;  mov.f32 %f39, 0.0;
    mov.f32 %f40, 0.0;  mov.f32 %f41, 0.0;  mov.f32 %f42, 0.0;  mov.f32 %f43, 0.0;
    mov.f32 %f44, 0.0;  mov.f32 %f45, 0.0;  mov.f32 %f46, 0.0;  mov.f32 %f47, 0.0;
    mov.f32 %f48, 0.0;  mov.f32 %f49, 0.0;  mov.f32 %f50, 0.0;  mov.f32 %f51, 0.0;
    mov.f32 %f52, 0.0;  mov.f32 %f53, 0.0;  mov.f32 %f54, 0.0;  mov.f32 %f55, 0.0;
    mov.f32 %f56, 0.0;  mov.f32 %f57, 0.0;  mov.f32 %f58, 0.0;  mov.f32 %f59, 0.0;
    mov.f32 %f60, 0.0;  mov.f32 %f61, 0.0;  mov.f32 %f62, 0.0;  mov.f32 %f63, 0.0;

    mov.b32         %f192, 0xff800000;
    mov.b32         %f193, 0xff800000;
    mov.f32         %f194, 0.0;
    mov.f32         %f195, 0.0;

    // P store addresses
    mul.lo.u32      %r170, %r1, 1024;
    add.u32         %r115, %r20, SMEM_P;
    add.u32         %r115, %r115, %r170;
    mul.lo.u32      %r116, %r13, 64;
    add.u32         %r115, %r115, %r116;
    shl.b32         %r117, %r14, 1;
    add.u32         %r111, %r115, %r117;
    add.u32         %r112, %r111, 512;

    add.u32         %r118, %r115, %r24;
    add.u32         %r119, %r118, 512;

    // V_T per-thread offset: gid*64 + tip*4
    mul.lo.u32      %r130, %r13, 64;
    shl.b32         %r131, %r14, 2;
    add.u32         %r131, %r130, %r131;

    mul.f32         %f199, %f196, LOG2E;

    add.u32         %r120, %r7, 63;
    shr.b32         %r120, %r120, 6;

    mov.u32         %r121, 0;
    mov.u32         %r150, 0;
    mov.u32         %r151, 0;  mov.u32 %r152, 0;
    mov.u32         %r153, 0;  mov.u32 %r154, 0;

kv_loop:
    setp.ge.u32     %p7, %r121, %r120;
    @%p7 bra        kv_done;

    mul.lo.u32      %r172, %r150, 8192;
    add.u32         %r75, %r20, SMEM_K0;
    add.u32         %r75, %r75, %r172;
    add.u32         %r75, %r75, %r23;

    mul.lo.u32      %r171, %r150, 16;
    add.u32         %r157, %r20, SMEM_MBAR_K0;
    add.u32         %r157, %r157, %r171;
    setp.eq.u32     %p14, %r150, 0;
    selp.u32        %r155, %r151, %r152, %p14;

mma_wait_k:
    mbarrier.try_wait.parity.shared.b64 %p4, [%r157], %r155;
    @!%p4 bra mma_wait_k;

    mov.f32 %f64, 0.0;  mov.f32 %f65, 0.0;  mov.f32 %f66, 0.0;  mov.f32 %f67, 0.0;
    mov.f32 %f68, 0.0;  mov.f32 %f69, 0.0;  mov.f32 %f70, 0.0;  mov.f32 %f71, 0.0;
    mov.f32 %f72, 0.0;  mov.f32 %f73, 0.0;  mov.f32 %f74, 0.0;  mov.f32 %f75, 0.0;
    mov.f32 %f76, 0.0;  mov.f32 %f77, 0.0;  mov.f32 %f78, 0.0;  mov.f32 %f79, 0.0;
    mov.f32 %f80, 0.0;  mov.f32 %f81, 0.0;  mov.f32 %f82, 0.0;  mov.f32 %f83, 0.0;
    mov.f32 %f84, 0.0;  mov.f32 %f85, 0.0;  mov.f32 %f86, 0.0;  mov.f32 %f87, 0.0;
    mov.f32 %f88, 0.0;  mov.f32 %f89, 0.0;  mov.f32 %f90, 0.0;  mov.f32 %f91, 0.0;
    mov.f32 %f92, 0.0;  mov.f32 %f93, 0.0;  mov.f32 %f94, 0.0;  mov.f32 %f95, 0.0;

    // QK GEMM
    xor.b32         %r76, %r24, %r160;
    add.u32         %r76, %r75, %r76;
    add.u32         %r27, %r24, 16;
    xor.b32         %r27, %r27, %r160;
    add.u32         %r77, %r75, %r27;
    QK_NG8_FP8(%r30,%r31,%r32,%r33, %r76, %r77)

    add.u32         %r76, %r24, 32;
    xor.b32         %r76, %r76, %r160;
    add.u32         %r76, %r75, %r76;
    add.u32         %r77, %r24, 48;
    xor.b32         %r77, %r77, %r160;
    add.u32         %r77, %r75, %r77;
    QK_NG8_FP8(%r34,%r35,%r36,%r37, %r76, %r77)

    add.u32         %r76, %r24, 64;
    xor.b32         %r76, %r76, %r160;
    add.u32         %r76, %r75, %r76;
    add.u32         %r77, %r24, 80;
    xor.b32         %r77, %r77, %r160;
    add.u32         %r77, %r75, %r77;
