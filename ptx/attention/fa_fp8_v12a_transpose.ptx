    mul.f32 %f58, %f58, %f102;  mul.f32 %f59, %f59, %f102;
    mul.f32 %f60, %f60, %f101;  mul.f32 %f61, %f61, %f101;
    mul.f32 %f62, %f62, %f102;  mul.f32 %f63, %f63, %f102;

    mul.f32         %f194, %f194, %f101;
    mul.f32         %f195, %f195, %f102;
    mov.f32         %f192, %f99;
    mov.f32         %f193, %f100;

    // P store
    mul.f32         %f197, %f99, LOG2E;
    neg.f32         %f197, %f197;
    mul.f32         %f198, %f100, LOG2E;
    neg.f32         %f198, %f198;

    EXP_STORE_NG_FP8(%f64,%f65,%f66,%f67, %f197, %f198, %r111, %r112, 0)
    EXP_STORE_NG_FP8(%f68,%f69,%f70,%f71, %f197, %f198, %r111, %r112, 8)
    EXP_STORE_NG_FP8(%f72,%f73,%f74,%f75, %f197, %f198, %r111, %r112, 16)
    EXP_STORE_NG_FP8(%f76,%f77,%f78,%f79, %f197, %f198, %r111, %r112, 24)
    EXP_STORE_NG_FP8(%f80,%f81,%f82,%f83, %f197, %f198, %r111, %r112, 32)
    EXP_STORE_NG_FP8(%f84,%f85,%f86,%f87, %f197, %f198, %r111, %r112, 40)
    EXP_STORE_NG_FP8(%f88,%f89,%f90,%f91, %f197, %f198, %r111, %r112, 48)
    EXP_STORE_NG_FP8(%f92,%f93,%f94,%f95, %f197, %f198, %r111, %r112, 56)

    // ================================================================
    // Wait V (raw)
    // ================================================================
    add.u32         %r158, %r20, SMEM_MBAR_V0;
    add.u32         %r158, %r158, %r171;
    selp.u32        %r156, %r153, %r154, %p14;

mma_wait_v:
    mbarrier.try_wait.parity.shared.b64 %p8, [%r158], %r156;
    @!%p8 bra mma_wait_v;

    // ================================================================
    // COOPERATIVE V -> V_T TRANSPOSE
    //
    // Only MMA warps (128 threads, IDs 0..127) run the transpose.
    // DMA warp (warp 4, IDs 128..159) is in dma_path and never reaches here.
    // Transpose V[Bc=64, D=128] (row-major stride 128) -> V_T[D=128, Bc=64] (stride 64).
    //
    // V source:   SMEM_V0 + stage*8192 (filled by TMA, stride 128)
    // V_T dest:   SMEM_VT0 + stage*8192 (target, stride 64)
    //
    // For each byte at linear index e (0..8191):
    //   V_row = e / 128, V_col = e % 128
    //   V_T_addr = V_col * 64 + V_row
    //
    // Thread t handles bytes e = t, t+128, t+256, ..., while e < 8192.
    // 8192 / 128 = 64 iterations per thread.
    // ================================================================

    // SMEM_V_stage base (without tip/gid offset)
    add.u32         %r185, %r20, SMEM_V0;
    add.u32         %r185, %r185, %r172;       // SMEM_V_stage

    // SMEM_VT_stage base
    add.u32         %r186, %r20, SMEM_VT0;
    add.u32         %r186, %r186, %r172;       // SMEM_VT_stage

    // Byte index for this thread
    mov.u32         %r187, %r0;               // e = tid (0..127 for MMA warps)

trans_loop:
    setp.ge.u32     %p15, %r187, 8192;
    @%p15 bra       trans_done;

    // V_row = e >> 7 (= e / 128), V_col = e & 127 (= e % 128)
    shr.b32         %r188, %r187, 7;          // V_row
    and.b32         %r189, %r187, 127;        // V_col

    // Read V[V_row, V_col]
    add.u32         %r190, %r185, %r187;
    ld.shared.u8    %r191, [%r190];

    // Write V_T[V_col, V_row] = V_T[V_col*64 + V_row]
    mul.lo.u32      %r192, %r189, 64;
    add.u32         %r192, %r192, %r188;
    add.u32         %r192, %r192, %r186;
    st.shared.u8    [%r192], %r191;

    add.u32         %r187, %r187, 128;        // e += 128 (stride = 4 MMA warps x 32 = 128)
    bra             trans_loop;

trans_done:
    // Synchronize only the 128 MMA threads (DMA warp not involved)
    bar.sync 0, 128;

    // ================================================================
    // PV GEMM using V_T
    // ================================================================
    add.u32         %r110, %r20, SMEM_VT0;
    add.u32         %r110, %r110, %r172;       // SMEM_VT_stage
    add.u32         %r110, %r110, %r131;       // + gid*64 + tip*4 = vtb

    ld.shared.b32   %r106, [%r118];
    ld.shared.b32   %r107, [%r119];
    ld.shared.b32   %r108, [%r118 + 16];
    ld.shared.b32   %r109, [%r119 + 16];

    PV_NG16_VT(%r106,%r107,%r108,%r109, %r110, 0)

    ld.shared.b32   %r106, [%r118 + 32];
    ld.shared.b32   %r107, [%r119 + 32];
    ld.shared.b32   %r108, [%r118 + 48];
    ld.shared.b32   %r109, [%r119 + 48];

    PV_NG16_VT(%r106,%r107,%r108,%r109, %r110, 32)

    // Signal DONE[stage]
    add.u32         %r159, %r20, SMEM_MBAR_DONE0;
    add.u32         %r159, %r159, %r171;
    setp.eq.u32     %p13, %r2, 0;
    @%p13 mbarrier.arrive.shared.b64 _, [%r159];

    @%p14 xor.b32   %r151, %r151, 1;
    @!%p14 xor.b32  %r152, %r152, 1;
    @%p14 xor.b32   %r153, %r153, 1;
    @!%p14 xor.b32  %r154, %r154, 1;

    add.u32         %r121, %r121, 1;
    xor.b32         %r150, %r150, 1;
    bra             kv_loop;

kv_done:
    // Epilogue
    GROUP4_REDUCE_SUM_F32(%f194, %f98)
    GROUP4_REDUCE_SUM_F32(%f195, %f98)

    setp.eq.f32     %p10, %f194, 0f00000000;
    @%p10 mov.f32   %f194, 0f3f800000;
    setp.eq.f32     %p10, %f195, 0f00000000;
    @%p10 mov.f32   %f195, 0f3f800000;

    rcp.approx.f32  %f101, %f194;
    rcp.approx.f32  %f102, %f195;

    mul.f32 %f0, %f0, %f101;    mul.f32 %f1, %f1, %f101;
    mul.f32 %f2, %f2, %f102;    mul.f32 %f3, %f3, %f102;
    mul.f32 %f4, %f4, %f101;    mul.f32 %f5, %f5, %f101;
    mul.f32 %f6, %f6, %f102;    mul.f32 %f7, %f7, %f102;
    mul.f32 %f8, %f8, %f101;    mul.f32 %f9, %f9, %f101;
    mul.f32 %f10, %f10, %f102;  mul.f32 %f11, %f11, %f102;
    mul.f32 %f12, %f12, %f101;  mul.f32 %f13, %f13, %f101;
    mul.f32 %f14, %f14, %f102;  mul.f32 %f15, %f15, %f102;
    mul.f32 %f16, %f16, %f101;  mul.f32 %f17, %f17, %f101;
    mul.f32 %f18, %f18, %f102;  mul.f32 %f19, %f19, %f102;
    mul.f32 %f20, %f20, %f101;  mul.f32 %f21, %f21, %f101;
    mul.f32 %f22, %f22, %f102;  mul.f32 %f23, %f23, %f102;
    mul.f32 %f24, %f24, %f101;  mul.f32 %f25, %f25, %f101;
    mul.f32 %f26, %f26, %f102;  mul.f32 %f27, %f27, %f102;
    mul.f32 %f28, %f28, %f101;  mul.f32 %f29, %f29, %f101;
    mul.f32 %f30, %f30, %f102;  mul.f32 %f31, %f31, %f102;
    mul.f32 %f32, %f32, %f101;  mul.f32 %f33, %f33, %f101;
    mul.f32 %f34, %f34, %f102;  mul.f32 %f35, %f35, %f102;
    mul.f32 %f36, %f36, %f101;  mul.f32 %f37, %f37, %f101;
    mul.f32 %f38, %f38, %f102;  mul.f32 %f39, %f39, %f102;
    mul.f32 %f40, %f40, %f101;  mul.f32 %f41, %f41, %f101;
    mul.f32 %f42, %f42, %f102;  mul.f32 %f43, %f43, %f102;
    mul.f32 %f44, %f44, %f101;  mul.f32 %f45, %f45, %f101;
