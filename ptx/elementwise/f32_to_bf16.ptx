// f32_to_bf16.ptx
//
// Elementwise cast F32 → BF16: out[i] = bf16(in[i]) for i in [0, n).
// Used to bring `moe_unpermute`'s f32 output into the BF16 residual stream
// without a host roundtrip.
//
// Grid: ceil(n / 256), Block: 256 threads. Grid-stride loop.

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"

.visible .entry f32_to_bf16(
    .param .u64 param_in,       // in: [n] f32
    .param .u64 param_out,      // out: [n] bf16
    .param .u32 param_n
)
{
    .reg .b32 %r<12>;
    .reg .b64 %rd<8>;
    .reg .f32 %f<4>;
    .reg .b16 %h<2>;
    .reg .pred %p<2>;

    mov.u32         %r0, BLOCK_ID_X;
    mov.u32         %r1, %ntid.x;
    mov.u32         %r2, THREAD_ID;
    mad.lo.u32      %r3, %r0, %r1, %r2;
    mov.u32         %r4, %nctaid.x;
    mul.lo.u32      %r5, %r4, %r1;

    ld.param.u64    %rd0, [param_in];
    ld.param.u64    %rd1, [param_out];
    ld.param.u32    %r6, [param_n];

loop:
    setp.ge.u32     %p0, %r3, %r6;
    @%p0 bra        done;

    mul.wide.u32    %rd3, %r3, 4;            // f32 stride = 4 bytes
    add.u64         %rd4, %rd0, %rd3;
    ld.global.f32   %f0, [%rd4];
    CVT_F32_BF16(%h0, %f0)

    mul.wide.u32    %rd5, %r3, 2;            // bf16 stride = 2 bytes
    add.u64         %rd6, %rd1, %rd5;
    st.global.b16   [%rd6], %h0;

    add.u32         %r3, %r3, %r5;
    bra             loop;

done:
    ret;
}
