// bf16_to_f32.ptx
//
// Elementwise cast BF16 -> F32: out[i] = f32(in[i]) for i in [0, n).
// Used to widen the MoE routing weights (BF16, kept on device) into the F32
// buffer that f32_weighted_sum_to_bf16 expects -- avoids a host roundtrip in
// the grouped MoE decode path.
//
// Grid: ceil(n / 256), Block: 256 threads. Grid-stride loop.

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"

.visible .entry bf16_to_f32(
    .param .u64 param_in,       // in: [n] bf16
    .param .u64 param_out,      // out: [n] f32
    .param .u32 param_n
)
{
    .reg .b32 %r<12>;
    .reg .b64 %rd<8>;
    .reg .f32 %f<4>;
    .reg .b16 %h<2>;
    .reg .pred %p<2>;

    mov.u32         %r0, BLOCK_ID_X;
    mov.u32         %r1, %ntid.x;
    mov.u32         %r2, THREAD_ID;
    mad.lo.u32      %r3, %r0, %r1, %r2;
    mov.u32         %r4, %nctaid.x;
    mul.lo.u32      %r5, %r4, %r1;

    ld.param.u64    %rd0, [param_in];
    ld.param.u64    %rd1, [param_out];
    ld.param.u32    %r6, [param_n];

loop:
    setp.ge.u32     %p0, %r3, %r6;
    @%p0 bra        done;

    mul.wide.u32    %rd3, %r3, 2;            // bf16 stride = 2 bytes
    add.u64         %rd4, %rd0, %rd3;
    ld.global.b16   %h0, [%rd4];
    CVT_BF16_F32(%f0, %h0)

    mul.wide.u32    %rd5, %r3, 4;            // f32 stride = 4 bytes
    add.u64         %rd6, %rd1, %rd5;
    st.global.f32   [%rd6], %f0;

    add.u32         %r3, %r3, %r5;
    bra             loop;

done:
    ret;
}
