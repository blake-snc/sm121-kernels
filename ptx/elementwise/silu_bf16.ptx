// silu_bf16.ptx
//
// Plain SiLU activation: y[i] = x[i] * sigmoid(x[i]) = x[i] / (1 + exp(-x[i]))
//
// Companion to silu_backward_bf16 and silu_mul_bf16 (gated SwiGLU
// variant). This is the unfused activation used by simple MLP feedforwards
// (e.g., a research training demo or a non-SwiGLU model).
//
// Grid: ceil(n / 256), Block: 256 threads.

.version 8.8
.target sm_121a
.address_size 64

#include "macros.ptxh"
#include "convert.ptxh"

.visible .entry silu_bf16(
    .param .u64 param_x,
    .param .u64 param_y,
    .param .u32 param_n
)
{
    .reg .b32 %r<10>;
    .reg .b64 %rd<8>;
    .reg .f32 %f<8>;
    .reg .b16 %h<4>;
    .reg .pred %p<2>;

    mov.u32         %r0, BLOCK_ID_X;
    mov.u32         %r1, %ntid.x;
    mov.u32         %r2, THREAD_ID;
    mad.lo.u32      %r3, %r0, %r1, %r2;
    mov.u32         %r4, %nctaid.x;
    mul.lo.u32      %r5, %r4, %r1;

    ld.param.u64    %rd0, [param_x];
    ld.param.u64    %rd1, [param_y];
    ld.param.u32    %r6, [param_n];

loop:
    setp.ge.u32     %p0, %r3, %r6;
    @%p0 bra        done;

    mul.wide.u32    %rd2, %r3, 2;
    add.u64         %rd3, %rd0, %rd2;
    add.u64         %rd4, %rd1, %rd2;

    ld.global.b16   %h0, [%rd3];
    CVT_BF16_F32(%f0, %h0)
    SILU_F32(%f3, %f0, %f1, %f2)
    CVT_F32_BF16(%h1, %f3)
    st.global.b16   [%rd4], %h1;

    add.u32         %r3, %r3, %r5;
    bra             loop;

done:
    ret;
}
